@* _CsvImportModal.cshtml
   Usage: <partial name="_CsvImportModal" model='("Routes", "bus routes")' />
   model = (string entityType, string entityLabel)
*@
@model (string EntityType, string EntityLabel)
@{
    var modalId   = $"importModal_{Model.EntityType}";
    var formId    = $"importForm_{Model.EntityType}";
    var resultId  = $"importResult_{Model.EntityType}";
    var fileId    = $"importFile_{Model.EntityType}";
    var previewId = $"importPreview_{Model.EntityType}";
}

@if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
{
    <!-- Import CSV Trigger Button -->
    <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('@modalId').style.display=''"
            title="Bulk import @Model.EntityLabel from a CSV file">
        <i class="bi bi-cloud-upload"></i> Import CSV
    </button>

    <!-- Import Modal -->
    <div class="announcement-modal" id="@modalId" style="display:none;">
        <div class="announcement-modal-backdrop" onclick="closeImportModal('@modalId')"></div>
        <div class="announcement-modal-content" style="max-width:520px;">
            <div class="announcement-modal-header">
                <i class="bi bi-cloud-upload"></i>
                <span>Import @Model.EntityLabel from CSV</span>
                <button type="button" class="announcement-modal-close" onclick="closeImportModal('@modalId')">&times;</button>
            </div>
            <div class="announcement-modal-body">

                <!-- Format hint -->
                <div style="background:rgba(124,143,255,0.08);border:1px solid rgba(124,143,255,0.2);border-radius:8px;padding:12px 14px;margin-bottom:16px;font-size:13px;color:var(--text-secondary);">
                    <strong style="color:var(--text-primary);">CSV Format:</strong>
                    The first row is treated as a header and skipped. Each subsequent row should have the name in the <strong>first column</strong>.
                    Duplicates are skipped automatically.
                    <br/><span style="font-size:12px;color:var(--text-dim);margin-top:4px;display:block;">Example:&nbsp;&nbsp;<code>Name</code> / <code>10</code> / <code>10A</code> / <code>15B</code></span>
                </div>

                <form id="@formId" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="entityType" value="@Model.EntityType" />

                    <div style="margin-bottom:14px;">
                        <label class="form-label" style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);">Select CSV File</label>
                        <input type="file" id="@fileId" name="csvFile" accept=".csv" class="form-control" onchange="previewCsv('@fileId','@previewId')" />
                    </div>

                    <!-- Live row preview -->
                    <div id="@previewId" style="display:none;background:var(--bg-elevated);border:1px solid var(--border);border-radius:8px;padding:10px 14px;max-height:180px;overflow-y:auto;margin-bottom:14px;font-size:13px;">
                        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--text-muted);margin-bottom:6px;">Preview (first 20 rows after header)</div>
                        <div class="preview-list"></div>
                    </div>

                    <!-- Result banner -->
                    <div id="@resultId" style="display:none;border-radius:8px;padding:10px 14px;font-size:13.5px;margin-bottom:4px;"></div>
                </form>
            </div>
            <div class="announcement-modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeImportModal('@modalId')">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="submitImport('@formId','@resultId','@modalId')">
                    <i class="bi bi-cloud-upload me-1"></i> Import
                </button>
            </div>
        </div>
    </div>
}

<script>
(function() {
    // Preview CSV rows before submit
    window.previewCsv = window.previewCsv || function(fileInputId, previewId) {
        var input   = document.getElementById(fileInputId);
        var preview = document.getElementById(previewId);
        if (!input || !input.files[0]) { preview.style.display = 'none'; return; }
        var reader = new FileReader();
        reader.onload = function(e) {
            var lines = e.target.result.split(/\r?\n/).filter(l => l.trim());
            if (lines.length < 2) { preview.style.display = 'none'; return; }
            var dataLines = lines.slice(1, 21); // skip header, show up to 20
            var html = dataLines.map(function(l) {
                var name = l.split(',')[0].trim().replace(/^"|"$/g, '');
                return '<div style="padding:2px 0;border-bottom:1px solid var(--border);color:var(--text-secondary);">' + name + '</div>';
            }).join('');
            if (lines.length - 1 > 20) html += '<div style="color:var(--text-dim);font-size:12px;margin-top:4px;">… and ' + (lines.length - 21) + ' more rows</div>';
            preview.querySelector('.preview-list').innerHTML = html;
            preview.style.display = '';
        };
        reader.readAsText(input.files[0]);
    };

    // Submit via fetch, show result inline
    window.submitImport = window.submitImport || function(formId, resultId, modalId) {
        var form   = document.getElementById(formId);
        var result = document.getElementById(resultId);
        var data   = new FormData(form);
        result.style.display = 'none';

        fetch('/MasterData/ImportCsv', { method: 'POST', body: data })
            .then(r => r.json())
            .then(function(json) {
                result.style.display = '';
                if (json.success) {
                    result.style.background = 'rgba(74,222,128,0.1)';
                    result.style.border     = '1px solid rgba(74,222,128,0.3)';
                    result.style.color      = 'var(--green)';
                    result.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i>' + json.message;
                    // Reload page after short delay to show new records
                    if (json.inserted > 0) setTimeout(function() { window.location.reload(); }, 1800);
                } else {
                    result.style.background = 'rgba(239,68,68,0.1)';
                    result.style.border     = '1px solid rgba(239,68,68,0.3)';
                    result.style.color      = 'var(--red)';
                    result.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-2"></i>' + json.message;
                }
            })
            .catch(function() {
                result.style.display    = '';
                result.style.background = 'rgba(239,68,68,0.1)';
                result.style.border     = '1px solid rgba(239,68,68,0.3)';
                result.style.color      = 'var(--red)';
                result.innerHTML        = '<i class="bi bi-exclamation-triangle-fill me-2"></i>Network error. Please try again.';
            });
    };

    window.closeImportModal = window.closeImportModal || function(modalId) {
        document.getElementById(modalId).style.display = 'none';
    };
})();
</script>
