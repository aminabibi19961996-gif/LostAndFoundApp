@{
    // Using dynamic model to support any PaginatedList<T> type
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "MasterData";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
    string sortBy = Model.SortBy ?? "Name";
    string sortOrder = Model.SortOrder ?? "asc";
}

@if (Model.TotalCount > 0)
{
    <div class="pagination-wrapper">
        @* ── Page number nav (only when more than 1 page) ── *@
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-modern mb-0">
                    @* First *@
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link" href="@Url.Action(action, controller, new { pageIndex = 1, pageSize = Model.PageSize, sortBy = sortBy, sortOrder = sortOrder })" tabindex="-1">&#171;&#171;</a>
                    </li>
                    @* Previous *@
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link" href="@Url.Action(action, controller, new { pageIndex = Model.PageIndex - 1, pageSize = Model.PageSize, sortBy = sortBy, sortOrder = sortOrder })" tabindex="-1">&#171;</a>
                    </li>

                    @* Page numbers *@
                    @{
                        int startPage = Math.Max(1, Model.PageIndex - 2);
                        int endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                        if (endPage - startPage < 4)
                        {
                            if (startPage == 1)
                                endPage = Math.Min(5, Model.TotalPages);
                            else if (endPage == Model.TotalPages)
                                startPage = Math.Max(1, Model.TotalPages - 4);
                        }
                    }
                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" href="@Url.Action(action, controller, new { pageIndex = i, pageSize = Model.PageSize, sortBy = sortBy, sortOrder = sortOrder })">@i</a>
                        </li>
                    }

                    @* Next *@
                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link" href="@Url.Action(action, controller, new { pageIndex = Model.PageIndex + 1, pageSize = Model.PageSize, sortBy = sortBy, sortOrder = sortOrder })">&#187;</a>
                    </li>
                    @* Last *@
                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link" href="@Url.Action(action, controller, new { pageIndex = Model.TotalPages, pageSize = Model.PageSize, sortBy = sortBy, sortOrder = sortOrder })">&#187;&#187;</a>
                    </li>
                </ul>
            </nav>
        }
        else
        {
            @* Spacer so the info+dropdown still aligns right *@
            <div></div>
        }

        @* ── Count info + per-page selector — always visible ── *@
        <div class="pagination-info">
            Showing @Model.StartRecord to @Model.EndRecord of @Model.TotalCount records
            <select class="page-size-select" onchange="window.location.href = '@Url.Action(action, controller, new { pageIndex = 1, pageSize = "__SIZE__", sortBy = sortBy, sortOrder = sortOrder })'.replace('__SIZE__', this.value);">
                @{
                    var pageSizes = new[] { 25, 50, 100, 200, 500 };
                }
                @foreach (var size in pageSizes)
                {
                    if (Model.PageSize == size)
                    {
                        <option value="@size" selected="selected">@size per page</option>
                    }
                    else
                    {
                        <option value="@size">@size per page</option>
                    }
                }
            </select>
        </div>
    </div>
}