@model LostAndFoundApp.ViewModels.PaginatedList<dynamic>
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "MasterData";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
}
@if (Model.TotalPages > 1)
{
    <div class="pagination-wrapper">
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-modern mb-0">
                @* First *@
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="@Url.Action(action, controller, new { pageIndex = 1, pageSize = Model.PageSize })" tabindex="-1">««</a>
                </li>
                @* Previous *@
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="@Url.Action(action, controller, new { pageIndex = Model.PageIndex - 1, pageSize = Model.PageSize })" tabindex="-1">«</a>
                </li>
                
                @* Page numbers *@
                @{
                    int startPage = Math.Max(1, Model.PageIndex - 2);
                    int endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                    if (endPage - startPage < 4)
                    {
                        if (startPage == 1)
                            endPage = Math.Min(5, Model.TotalPages);
                        else if (endPage == Model.TotalPages)
                            startPage = Math.Max(1, Model.TotalPages - 4);
                    }
                }
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" href="@Url.Action(action, controller, new { pageIndex = i, pageSize = Model.PageSize })">@i</a>
                    </li>
                }
                
                @* Next *@
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="@Url.Action(action, controller, new { pageIndex = Model.PageIndex + 1, pageSize = Model.PageSize })">»</a>
                </li>
                @* Last *@
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="@Url.Action(action, controller, new { pageIndex = Model.TotalPages, pageSize = Model.PageSize })">»»</a>
                </li>
            </ul>
        </nav>
        <div class="pagination-info">
            Showing @Model.StartRecord to @Model.EndRecord of @Model.TotalCount records
            <select class="page-size-select" onchange="window.location.href = '@Url.Action(action, controller, new { pageIndex = Model.PageIndex, pageSize = "__SIZE__" })'.replace('__SIZE__', this.value);">
                @{
                    var pageSizes = new[] { 5, 10, 25, 50 };
                }
                @foreach (var size in pageSizes)
                {
                    if (Model.PageSize == size)
                    {
                        <option value="@size" selected="selected">@size per page</option>
                    }
                    else
                    {
                        <option value="@size">@size per page</option>
                    }
                }
            </select>
        </div>
    </div>
}
else if (Model.TotalCount > 0)
{
    <div class="pagination-info">
        Showing @Model.StartRecord to @Model.EndRecord of @Model.TotalCount records
    </div>
}