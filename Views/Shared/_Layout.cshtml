<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Lost &amp; Found</title>
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <link href="~/css/site.css" rel="stylesheet" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- LOADING OVERLAY — shows magnifier animation while page loads -->
<div id="loadingOverlay" style="
    position:fixed;inset:0;z-index:99999;
    background:linear-gradient(135deg, #0F1117 0%, #161927 50%, #0F1117 100%);
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    transition:opacity 0.5s ease, visibility 0.5s ease;
">
    <!-- Animated magnifying glass -->
    <div style="position:relative;width:120px;height:120px;margin-bottom:32px;">
        <svg viewBox="0 0 120 120" style="width:120px;height:120px;animation:loaderBounce 1.8s ease-in-out infinite;">
            <!-- Glass circle -->
            <circle cx="48" cy="48" r="28" fill="none" stroke="#7C8FFF" stroke-width="4" opacity="0.25"/>
            <circle cx="48" cy="48" r="28" fill="none" stroke="url(#loaderGrad)" stroke-width="4"
                    stroke-dasharray="176" stroke-dashoffset="132" stroke-linecap="round"
                    style="animation:loaderSpin 1.4s linear infinite;transform-origin:48px 48px;"/>
            <!-- Handle -->
            <line x1="70" y1="70" x2="100" y2="100" stroke="#7C8FFF" stroke-width="6" stroke-linecap="round" opacity="0.7"/>
            <!-- Sparkle inside lens -->
            <circle cx="38" cy="38" r="4" fill="#A5B4FC" opacity="0.6" style="animation:loaderPulse 1.4s ease-in-out infinite;"/>
            <circle cx="55" cy="42" r="2.5" fill="#67E8F9" opacity="0.4" style="animation:loaderPulse 1.4s ease-in-out 0.3s infinite;"/>
            <defs>
                <linearGradient id="loaderGrad" x1="20" y1="20" x2="76" y2="76" gradientUnits="userSpaceOnUse">
                    <stop offset="0%" stop-color="#7C8FFF"/>
                    <stop offset="100%" stop-color="#67E8F9"/>
                </linearGradient>
            </defs>
        </svg>
    </div>
    <!-- Text -->
    <div style="font-family:'Inter',system-ui,sans-serif;font-size:18px;font-weight:600;color:#A5B4FC;letter-spacing:0.03em;text-align:center;">
        We are finding your thing
        <span id="loadingDots" style="display:inline-block;width:30px;text-align:left;"></span>
    </div>
    <div style="font-family:'Inter',system-ui,sans-serif;font-size:13px;color:rgba(165,180,252,0.45);margin-top:10px;letter-spacing:0.05em;">
        LOST &amp; FOUND
    </div>
</div>

<style>
    @@keyframes loaderSpin {
        to { stroke-dashoffset: -44; transform: rotate(360deg); }
    }
    @@keyframes loaderBounce {
        0%, 100% { transform: translateY(0); }
        50%      { transform: translateY(-10px); }
    }
    @@keyframes loaderPulse {
        0%, 100% { opacity: 0.3; transform: scale(0.75); }
        50%      { opacity: 0.9; transform: scale(1.25); }
    }
    #loadingOverlay.hide {
        opacity: 0;
        visibility: hidden;
    }
</style>

<script>
    // Animate dots
    (function(){
        var d=document.getElementById('loadingDots'),c=0;
        var iv=setInterval(function(){c=(c+1)%4;d.textContent='.'.repeat(c);},400);
        window.__loaderInterval=iv;
    })();
</script>

@if (User.Identity?.IsAuthenticated == true)
{
    var userInitials = string.Join("", (User.Identity.Name ?? "U").Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w.Length > 0 ? w[0].ToString() : ""));

    <!-- NAV -->
    <nav>
        <a class="nav-brand" asp-controller="Home" asp-action="Index" style="display:flex;align-items:center;justify-content:center;height:80px;padding:10px 16px;">
            <img src="/images/logo.png?v=2" alt="Lost &amp; Found Logo" style="height:56px;width:auto;max-width:100%;display:block;object-fit:contain;object-position:center;" />
        </a>

        <div class="nav-links">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                <i class="bi bi-grid-fill"></i> Dashboard
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Create" && ViewContext.RouteData.Values["controller"]?.ToString() == "LostFoundItem" ? "active" : "")" asp-controller="LostFoundItem" asp-action="Create">
                <i class="bi bi-plus"></i> New Record
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Search" ? "active" : "")" asp-controller="LostFoundItem" asp-action="Search">
                <i class="bi bi-search"></i> Search
            </a>

            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin") || User.IsInRole("Supervisor"))
            {
                <div class="dropdown">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "MasterData" ? "active" : "")" href="#">
                        Master Data <i class="bi bi-chevron-down" style="font-size:10px;opacity:.5"></i>
                    </a>
                    <div class="dropdown-menu">
                        <a class="dropdown-item" asp-controller="MasterData" asp-action="Items"><i class="bi bi-box"></i> Items</a>
                        <a class="dropdown-item" asp-controller="MasterData" asp-action="Routes"><i class="bi bi-signpost-2"></i> Routes</a>
                        <a class="dropdown-item" asp-controller="MasterData" asp-action="Vehicles"><i class="bi bi-bus-front"></i> Vehicles</a>
                        <a class="dropdown-item" asp-controller="MasterData" asp-action="StorageLocations"><i class="bi bi-building"></i> Storage Locations</a>
                        <a class="dropdown-item" asp-controller="MasterData" asp-action="Statuses"><i class="bi bi-tag"></i> Statuses</a>
                        <a class="dropdown-item" asp-controller="MasterData" asp-action="FoundByNames"><i class="bi bi-person"></i> Found By Names</a>
                    </div>
                </div>
            }

            @if (User.IsInRole("SuperAdmin"))
            {
                <div class="dropdown">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "UserManagement" || ViewContext.RouteData.Values["controller"]?.ToString() == "Announcement" || ViewContext.RouteData.Values["controller"]?.ToString() == "Logs" ? "active" : "")" href="#">
                        Admin <i class="bi bi-chevron-down" style="font-size:10px;opacity:.5"></i>
                    </a>
                    <div class="dropdown-menu">
                        <a class="dropdown-item" asp-controller="UserManagement" asp-action="Index"><i class="bi bi-people"></i> User Management</a>
                        <a class="dropdown-item" asp-controller="UserManagement" asp-action="AdGroups"><i class="bi bi-diagram-3"></i> AD Groups &amp; Sync</a>
                        <a class="dropdown-item" asp-controller="UserManagement" asp-action="AdUsers"><i class="bi bi-person-badge"></i> AD Users</a>
                        <a class="dropdown-item" asp-controller="UserManagement" asp-action="PasswordPolicy"><i class="bi bi-key"></i> Password Policy</a>
                        <a class="dropdown-item" asp-controller="UserManagement" asp-action="OverdueSettings"><i class="bi bi-clock-history"></i> Overdue Settings</a>
                        <a class="dropdown-item" asp-controller="Announcement" asp-action="Index"><i class="bi bi-megaphone"></i> Announcements <span id="unreadBadge" style="display:none;padding:1px 7px;border-radius:10px;font-size:11px;font-weight:700;background:var(--accent);color:#fff;margin-left:4px;"></span></a>
                        <div class="dropdown-divider"></div>
                        <a class="dropdown-item" asp-controller="Logs" asp-action="Index"><i class="bi bi-journal-text"></i> Activity Logs</a>
                    </div>
                </div>
            }
            else if (User.IsInRole("Admin"))
            {
                <div class="dropdown">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "UserManagement" || ViewContext.RouteData.Values["controller"]?.ToString() == "Logs" || ViewContext.RouteData.Values["controller"]?.ToString() == "Announcement" ? "active" : "")" href="#">
                        Admin <i class="bi bi-chevron-down" style="font-size:10px;opacity:.5"></i>
                    </a>
                    <div class="dropdown-menu">
                        <a class="dropdown-item" asp-controller="UserManagement" asp-action="Index"><i class="bi bi-people"></i> User Management</a>
                        <a class="dropdown-item" asp-controller="UserManagement" asp-action="AdGroups"><i class="bi bi-diagram-3"></i> AD Groups &amp; Sync</a>
                        <a class="dropdown-item" asp-controller="UserManagement" asp-action="AdUsers"><i class="bi bi-person-badge"></i> AD Users</a>
                        <a class="dropdown-item" asp-controller="UserManagement" asp-action="OverdueSettings"><i class="bi bi-clock-history"></i> Overdue Settings</a>
                        <a class="dropdown-item" asp-controller="Announcement" asp-action="Index"><i class="bi bi-megaphone"></i> Announcements</a>
                        <a class="dropdown-item" asp-controller="Logs" asp-action="Index"><i class="bi bi-journal-text"></i> Activity Logs</a>
                    </div>
                </div>
            }
            else if (User.IsInRole("Supervisor"))
            {
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "UserManagement" ? "active" : "")" asp-controller="UserManagement" asp-action="Index">
                    <i class="bi bi-people"></i> User List
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Announcement" && ViewContext.RouteData.Values["action"]?.ToString() != "Messages" ? "active" : "")" asp-controller="Announcement" asp-action="Index">
                    <i class="bi bi-megaphone"></i> Announcements <span id="navUnreadBadge" style="display:none;padding:1px 7px;border-radius:10px;font-size:11px;font-weight:700;background:var(--accent);color:#fff;margin-left:2px;"></span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Announcement" && ViewContext.RouteData.Values["action"]?.ToString() == "Messages" ? "active" : "")" asp-controller="Announcement" asp-action="Messages">
                    <i class="bi bi-envelope"></i> Messages
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Logs" ? "active" : "")" asp-controller="Logs" asp-action="Index">
                    <i class="bi bi-journal-text"></i> My Logs
                </a>
            }
            else
            {
                @* User role: no log access, only messages *@
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Announcement" ? "active" : "")" asp-controller="Announcement" asp-action="Messages">
                    <i class="bi bi-envelope"></i> Messages
                </a>
            }
        </div>

        <button type="button" class="btn btn-ghost btn-icon mobile-menu-toggle" id="mobileMenuToggle" style="display: none;" aria-label="Toggle menu">
            <i class="bi bi-list" style="font-size:20px"></i>
        </button>

        <div class="nav-actions" style="gap:14px;">
            <a class="btn btn-primary btn-sm" asp-controller="LostFoundItem" asp-action="Create" style="padding:9px 18px;font-size:14px;font-weight:700;">
                <i class="bi bi-plus" style="font-size:16px;"></i> <span>New Record</span>
            </a>
            <div style="display:flex;align-items:center;gap:6px;">
                <a class="btn btn-ghost btn-icon" asp-controller="Account" asp-action="Profile" title="My Profile">
                    <i class="bi bi-person" style="font-size:19px;color:#E0E0E0;"></i>
                </a>
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-ghost btn-icon" title="Logout">
                        <i class="bi bi-box-arrow-right" style="font-size:19px;color:#E0E0E0;"></i>
                    </button>
                </form>
            </div>
            <div class="avatar" title="@User.Identity.Name" style="width:36px;height:36px;font-size:14px;font-weight:800;">@userInitials</div>
        </div>
    </nav>
}

<!-- MAIN CONTENT -->
<main class="page">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible">
            <i class="bi bi-check-circle" style="font-size:16px"></i>
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["WarningMessage"] != null)
    {
        <div class="alert alert-dismissible" style="background:rgba(252,211,77,0.12);border:1px solid rgba(252,211,77,0.3);color:#D97706;display:flex;align-items:center;gap:10px;padding:12px 18px;border-radius:8px;margin-bottom:14px;font-size:14px;font-weight:500;">
            <i class="bi bi-exclamation-triangle-fill" style="font-size:16px;flex-shrink:0;"></i>
            @TempData["WarningMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible">
            <i class="bi bi-exclamation-triangle" style="font-size:16px"></i>
            @TempData["ErrorMessage"]
        </div>
    }

    @RenderBody()
</main>

@if (User.Identity?.IsAuthenticated == true)
{
    <div id="announcementModal" class="modal" style="display:none;">
        <div class="modal-backdrop" id="modalBackdrop"></div>
        <div class="modal-content">
            <div class="modal-header">
                <i class="bi bi-megaphone" style="font-size:16px;color:var(--accent)"></i>
                <span>Announcement</span>
                <button type="button" class="modal-close" id="closeAnnouncementModal">&times;</button>
            </div>
            <div class="modal-body" id="announcementModalBody"></div>
            <div class="modal-footer" style="justify-content:space-between;align-items:center;">
                <span class="text-muted" style="font-size:12px;" id="announcementCounter"></span>
                <div style="display:flex;gap:8px;align-items:center;">
                    <button type="button" class="btn btn-secondary btn-sm" id="prevAnnouncement" style="display:none;">Previous</button>
                    <button type="button" class="btn btn-sm" id="markReadAnnouncement" style="background:rgba(34,197,94,0.12);color:#22C55E;border:1px solid rgba(34,197,94,0.25);font-weight:700;"><i class="bi bi-check-circle" style="margin-right:4px;"></i>Mark as Read</button>
                    <button type="button" class="btn btn-primary btn-sm" id="nextAnnouncement" style="display:none;">Next</button>
                </div>
            </div>
        </div>
    </div>
}

<script src="~/js/site.js"></script>
<script>
    // Mobile menu toggle
    (function() {
        var toggle = document.getElementById('mobileMenuToggle');
        var navLinks = document.querySelector('.nav-links');

        if (toggle && navLinks) {
            toggle.addEventListener('click', function(e) {
                e.preventDefault();
                navLinks.classList.toggle('mobile-open');
            });

            // Close mobile menu when a non-dropdown nav-link is clicked
            navLinks.querySelectorAll('.nav-link').forEach(function(link) {
                // Skip dropdown trigger links
                if (link.closest('.dropdown')) {
                    var dropdown = link.closest('.dropdown');
                    // Toggle dropdown open/close on mobile
                    link.addEventListener('click', function(e) {
                        if (window.innerWidth <= 768) {
                            e.preventDefault();
                            dropdown.classList.toggle('mobile-open');
                        }
                    });
                } else {
                    link.addEventListener('click', function() {
                        navLinks.classList.remove('mobile-open');
                    });
                }
            });

            function checkMobile() {
                if (window.innerWidth <= 768) {
                    toggle.style.display = 'flex';
                } else {
                    toggle.style.display = 'none';
                    navLinks.classList.remove('mobile-open');
                    // Also close any mobile-open dropdowns
                    navLinks.querySelectorAll('.dropdown.mobile-open').forEach(function(dd) {
                        dd.classList.remove('mobile-open');
                    });
                }
            }
            checkMobile();
            window.addEventListener('resize', checkMobile);
        }
    })();
</script>
@await RenderSectionAsync("Scripts", required: false)

<script>
    // Dismiss loading overlay once page is ready
    window.addEventListener('load', function() {
        var overlay = document.getElementById('loadingOverlay');
        if (overlay) {
            // Small delay so user sees the animation at least briefly
            setTimeout(function() {
                overlay.classList.add('hide');
                clearInterval(window.__loaderInterval);
                // Remove from DOM after fade completes
                setTimeout(function() { overlay.remove(); }, 600);
            }, 400);
        }
    });
</script>
</body>
</html>
