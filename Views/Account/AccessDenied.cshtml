@{
    ViewData["Title"] = "Access Denied";
}

<div style="display:flex;align-items:center;justify-content:center;min-height:60vh;text-align:center;padding:32px;">
    <div>
        <div style="font-size:4.5rem;color:var(--accent);margin-bottom:20px;">
            <i class="bi bi-shield-x"></i>
        </div>
        <div style="font-family:var(--font-mono);font-size:4.5rem;font-weight:800;color:var(--text-primary);line-height:1;margin-bottom:8px;">
            403
        </div>
        <h2 style="font-family:var(--font-display);font-weight:800;font-size:1.625rem;color:var(--text-primary);margin-bottom:8px;">
            Access Denied
        </h2>
        <p style="font-size:15px;color:var(--text-muted);max-width:360px;margin:0 auto 24px;">
            You don't have permission to access this resource.
            Contact your administrator if you believe this is an error.
        </p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-house"></i> Go to Dashboard
        </a>
    </div>
</div>
