@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

@section Styles {
<style>
    .cpw-header { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
    .cpw-header h1 { font-family: var(--font-display); font-size: 1.625rem; font-weight: 800; color: var(--text-primary); letter-spacing: -.02em; display: flex; align-items: center; gap: 8px; }
    .cpw-header h1 i { font-size: 20px; color: var(--accent); }
    .cpw-header .subtitle { font-size: 14px; color: var(--text-muted); font-weight: 500; }
    .cpw-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; max-width: 480px; }
    .cpw-body { padding: 22px 20px; }
    .cpw-body .form-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); margin-bottom: 6px; }
    .cpw-body .form-hint { font-size: 12.5px; color: var(--text-dim); margin-top: 4px; }
    .cpw-footer { display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; border-top: 1px solid var(--border); background: var(--bg-elevated); margin: 4px -18px -20px; border-radius: 0 0 12px 12px; }
    .cpw-group { margin-bottom: 18px; }
</style>
}

<div class="cpw-header">
    <div>
        <h1><i class="bi bi-key"></i> Change Password</h1>
        <div class="subtitle">Update your password</div>
    </div>
</div>

<div class="cpw-card">
    <div class="cpw-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        }
        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            <div class="cpw-group">
                <label asp-for="CurrentPassword" class="form-label">Current Password</label>
                <input asp-for="CurrentPassword" class="form-control" />
                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
            </div>
            <div class="cpw-group">
                <label asp-for="NewPassword" class="form-label">New Password</label>
                <input asp-for="NewPassword" class="form-control" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                <div class="form-hint">Password must meet the configured policy requirements.</div>
            </div>
            <div class="cpw-group">
                <label asp-for="ConfirmPassword" class="form-label">Confirm New Password</label>
                <input asp-for="ConfirmPassword" class="form-control" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            <div class="cpw-footer">
                <a asp-controller="Account" asp-action="Profile" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Cancel</a>
                <button type="submit" class="btn btn-primary"><i class="bi bi-key"></i> Change Password</button>
            </div>
        </form>
    </div>
</div>
