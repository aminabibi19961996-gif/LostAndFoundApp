@model ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="page page-full">
    <div class="page-header">
        <div>
            <div class="page-title">My Profile</div>
            <div class="page-subtitle">Update your personal information</div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 16px;">
        <div class="card">
            <div class="card-header">
                <span class="card-title">Profile Information</span>
            </div>
            <div class="card-body">
                <form method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="form-group">
                        <label class="form-label">Username</label>
                        <input value="@Model.UserName" class="form-control" disabled />
                        <div class="form-hint">Username cannot be changed.</div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="DisplayName"></label>
                        <input asp-for="DisplayName" class="form-control" />
                        <span asp-validation-for="DisplayName" class="text-danger small"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Email"></label>
                        @if (Model.IsAdUser)
                        {
                            <input value="@Model.Email" class="form-control" disabled />
                            <div class="form-hint">Email is managed by Active Directory and cannot be changed here.</div>
                        }
                        else
                        {
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        }
                    </div>

                    <div class="form-actions">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                            Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <span class="card-title">Account Info</span>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label class="form-label">Account Type</label>
                    <div>
                        @if (Model.IsAdUser)
                        {
                            <span class="badge-role badge-ad">
                                <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
                                Active Directory
                            </span>
                        }
                        else
                        {
                            <span class="badge-role badge-local">
                                <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                Local Account
                            </span>
                        }
                    </div>
                </div>
                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Password</label>
                    <div>
                        @if (Model.IsAdUser)
                        {
                            <span class="text-muted">Managed by Active Directory</span>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="ChangePassword" class="btn btn-secondary btn-sm">
                                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
                                Change Password
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>