@model ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

@section Styles {
<style>
    .profile-header { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
    .profile-header h1 { font-family: var(--font-display); font-size: 1.625rem; font-weight: 800; color: var(--text-primary); letter-spacing: -.02em; display: flex; align-items: center; gap: 8px; }
    .profile-header h1 i { font-size: 20px; color: var(--accent); }
    .profile-header .subtitle { font-size: 14px; color: var(--text-muted); font-weight: 500; }

    .pc { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    .pc-head { padding: 14px 20px; border-bottom: 1px solid var(--border); background: var(--bg-elevated); font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--text-primary); display: flex; align-items: center; gap: 8px; }
    .pc-head i { color: var(--accent); font-size: 16px; }
    .pc-body { padding: 22px 20px; }
    .pg { display: flex; flex-direction: column; gap: 18px; }
    .pg .form-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); margin-bottom: 6px; }
    .pg .form-hint { font-size: 12.5px; color: var(--text-dim); margin-top: 4px; }
    .pc-footer { display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; border-top: 1px solid var(--border); background: var(--bg-elevated); margin: 20px -18px -20px; border-radius: 0 0 12px 12px; }
    .profile-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    @@media (max-width: 768px) { .profile-grid { grid-template-columns: 1fr; } }
</style>
}

<div class="profile-header">
    <div>
        <h1><i class="bi bi-person-circle"></i> My Profile</h1>
        <div class="subtitle">Update your personal information</div>
    </div>
</div>

<div class="profile-grid">
    <div class="pc">
        <div class="pc-head"><i class="bi bi-person"></i> Profile Information</div>
        <div class="pc-body">
            <form method="post">
                @Html.AntiForgeryToken()
                <div class="pg">
                    <div>
                        <label class="form-label">Username</label>
                        <input value="@Model.UserName" class="form-control" disabled />
                        <div class="form-hint">Username cannot be changed.</div>
                    </div>
                    <div>
                        <label class="form-label" asp-for="DisplayName"></label>
                        <input asp-for="DisplayName" class="form-control" />
                        <span asp-validation-for="DisplayName" class="text-danger small"></span>
                    </div>
                    <div>
                        <label class="form-label" asp-for="Email"></label>
                        @if (Model.IsAdUser)
                        {
                            <input value="@Model.Email" class="form-control" disabled />
                            <div class="form-hint">Email is managed by Active Directory.</div>
                        }
                        else
                        {
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        }
                    </div>
                </div>
                <div class="pc-footer">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save Changes</button>
                </div>
            </form>
        </div>
    </div>

    <div class="pc">
        <div class="pc-head"><i class="bi bi-info-circle"></i> Account Info</div>
        <div class="pc-body">
            <div class="pg">
                <div>
                    <label class="form-label">Account Type</label>
                    <div>
                        @if (Model.IsAdUser)
                        {
                            <span class="badge-role badge-ad"><i class="bi bi-diagram-3"></i> Active Directory</span>
                        }
                        else
                        {
                            <span class="badge-role badge-local"><i class="bi bi-person"></i> Local Account</span>
                        }
                    </div>
                </div>
                <div>
                    <label class="form-label">Password</label>
                    <div>
                        @if (Model.IsAdUser)
                        {
                            <span style="font-size:13px;color:var(--text-dim);">Managed by Active Directory</span>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="ChangePassword" class="btn btn-secondary btn-sm">
                                <i class="bi bi-key"></i> Change Password
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>