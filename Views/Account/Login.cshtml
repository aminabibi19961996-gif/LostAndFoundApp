@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — Lost &amp; Found</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
    <style>
        body { background: #000; min-height: 100vh; display: flex; align-items: center; justify-content: center; font-family: 'Inter', sans-serif; }
        .lp { width: 100%; max-width: 420px; padding: 20px; }
        .lc { background: #0C0C0C; border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 40px 32px 28px; }
        .lc-icon { width: 90px; height: 90px; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; }
        .lc-title { font-family: 'Syne', sans-serif; font-size: 1.625rem; font-weight: 800; color: #fff; text-align: center; letter-spacing: -.025em; margin-bottom: 4px; }
        .lc-sub { font-size: 14.5px; color: #8B8D9E; text-align: center; margin-bottom: 28px; font-weight: 500; }
        .lc .form-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #8B8D9E; margin-bottom: 6px; }
        .lc .form-control { font-size: 14.5px; padding: 10px 12px; background: #111; border: 1px solid rgba(255,255,255,0.08); color: #fff; border-radius: 12px; font-family: inherit; font-weight: 500; }
        .lc .form-control:focus { border-color: rgba(124,143,255,0.6); outline: none; box-shadow: 0 0 0 3px rgba(124,143,255,0.18); }
        .lc .form-control::placeholder { color: #5A5C6E; }
        .ig { display: flex; align-items: stretch; }
        .ig-icon { display: flex; align-items: center; justify-content: center; width: 42px; background: #141414; border: 1px solid rgba(255,255,255,0.08); border-right: none; border-radius: 12px 0 0 8px; color: #8B8D9E; font-size: 15px; flex-shrink: 0; }
        .ig .form-control { border-radius: 0 8px 8px 0; }
        .fg { margin-bottom: 18px; }
        .lc .btn-primary { width: 100%; padding: 12px; font-size: 14.5px; font-weight: 600; border-radius: 12px; background: #7C8FFF; color: #fff; border: none; cursor: pointer; font-family: inherit; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background .14s, box-shadow .14s; }
        .lc .btn-primary:hover { background: #6B7EF0; box-shadow: 0 3px 14px rgba(124,143,255,0.35); }
        .lc-footer { text-align: center; margin-top: 18px; font-size: 14px; }
        .lc-footer a { color: #8B8D9E; text-decoration: none; font-weight: 500; transition: color .14s; }
        .lc-footer a:hover { color: #C8C9D4; }
        .lc-secured { text-align: center; margin-top: 14px; font-size: 12.5px; color: #5A5C6E; font-weight: 500; }
        .remember-row { display: flex; align-items: center; gap: 6px; margin-bottom: 22px; }
        .remember-row input { accent-color: #7C8FFF; }
        .remember-row label { font-size: 14px; color: #C8C9D4; font-weight: 500; cursor: pointer; }
    </style>
</head>
<body>
    <div class="lp">
        <div class="lc">
            <div class="lc-icon"><img src="/images/logo.png" alt="Lost & Found" style="width:90px;height:90px;object-fit:contain;" /></div>
            <h1 class="lc-title">Lost &amp; Found</h1>
            <p class="lc-sub">Sign in to your account</p>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display: @(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <div class="fg">
                    <label asp-for="UserName" class="form-label">Username</label>
                    <div class="ig">
                        <span class="ig-icon"><i class="bi bi-person"></i></span>
                        <input asp-for="UserName" class="form-control" placeholder="Enter your username" autofocus />
                    </div>
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>

                <div class="fg">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="ig">
                        <span class="ig-icon"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" class="form-control" placeholder="Enter your password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="remember-row">
                    <input asp-for="RememberMe" />
                    <label asp-for="RememberMe">Remember me</label>
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-box-arrow-in-right"></i> Sign In
                </button>
            </form>

            <p class="lc-secured"><i class="bi bi-shield-check me-1"></i> Secured by Active Directory &amp; Microsoft Identity</p>
        </div>
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
