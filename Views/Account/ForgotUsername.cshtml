@model ForgotUsernameViewModel
@{
    ViewData["Title"] = "Forgot Username";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Lost &amp; Found</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
    <style>
        body { background: var(--black); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-card { background: var(--black-light); border: 1px solid var(--border); border-radius: 16px; padding: 2.5rem; max-width: 420px; width: 100%; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); }
        .brand-icon { width: 48px; height: 48px; background: var(--accent); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: var(--white); margin: 0 auto 1.5rem; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center mb-4">
            <div class="brand-icon"><i class="bi bi-search-heart"></i></div>
            <h2 class="fw-bold">Lost &amp; Found</h2>
            <p class="text-muted">Recover your username</p>
        </div>

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label" asp-for="Email"></label>
                <input asp-for="Email" class="form-control" placeholder="Enter your email address" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2">
                <i class="bi bi-envelope me-2"></i> Recover Username
            </button>
        </form>

        <div class="text-center mt-4">
            <a asp-controller="Account" asp-action="Login" class="text-muted">
                <i class="bi bi-arrow-left me-1"></i> Back to Login
            </a>
        </div>
    </div>
</body>
</html>