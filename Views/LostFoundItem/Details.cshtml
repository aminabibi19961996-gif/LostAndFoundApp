@model LostFoundItemDetailViewModel
@{
    ViewData["Title"] = $"Record #{Model.TrackingId}";
    var statusClass = (Model.StatusName?.ToLower()) switch {
        "found" => "sb-found",
        "claimed" => "sb-claimed",
        "stored" => "sb-stored",
        "transferred" => "sb-transferred",
        "disposed" => "sb-disposed",
        _ => "sb-unknown"
    };
}

@section Styles {
<style>
    .detail-header { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; }
    .detail-header h1 { font-family: var(--font-display); font-size: 1.625rem; font-weight: 800; color: var(--text-primary); letter-spacing: -.02em; display: flex; align-items: center; gap: 8px; }
    .detail-header h1 i { font-size: 20px; color: var(--accent); }
    .detail-header .meta { display: flex; align-items: center; gap: 8px; margin-top: 4px; font-size: 14px; color: var(--text-muted); }
    .detail-actions { display: flex; gap: 8px; }

    .sb { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; border-radius: 20px; font-size: 12.5px; font-weight: 700; border: 1px solid transparent; white-space: nowrap; }
    .sb::before { content:''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
    .sb-found       { background: var(--status-found-bg);       color: var(--status-found-text);       border-color: var(--status-found-border); }
    .sb-claimed     { background: var(--status-claimed-bg);     color: var(--status-claimed-text);     border-color: var(--status-claimed-border); }
    .sb-stored      { background: var(--status-stored-bg);      color: var(--status-stored-text);      border-color: var(--status-stored-border); }
    .sb-transferred { background: var(--status-transferred-bg); color: var(--status-transferred-text); border-color: var(--status-transferred-border); }
    .sb-disposed    { background: var(--status-disposed-bg);    color: var(--status-disposed-text);    border-color: var(--status-disposed-border); }
    .sb-unknown     { background: var(--bg-hover); color: var(--text-muted); }

    .dc { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; margin-bottom: 20px; }
    .dc-head { padding: 14px 20px; border-bottom: 1px solid var(--border); font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--text-primary); background: var(--bg-elevated); display: flex; align-items: center; gap: 8px; }
    .dc-head i { color: var(--accent); font-size: 16px; }
    .dc-body { padding: 20px; }

    .dg { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
    .dg .span-2 { grid-column: span 2; }
    .dg .span-3 { grid-column: span 3; }
    .dg-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); margin-bottom: 5px; }
    .dg-value { font-size: 15px; font-weight: 500; color: var(--text-primary); }
    .dg-empty { color: var(--text-dim); }

    .detail-layout { display: grid; grid-template-columns: 1fr 320px; gap: 16px; }
    @@media (max-width: 992px) {
        .detail-layout { grid-template-columns: 1fr; }
        .dg { grid-template-columns: repeat(2, 1fr); }
    }
</style>
}

<!-- HEADER -->
<div class="detail-header">
    <div>
        <h1><i class="bi bi-file-earmark-text"></i> Record #@Model.CustomTrackingId</h1>
        <div class="meta">
            <span class="sb @statusClass">@(Model.StatusName ?? "Unknown")</span>
            <span>— Found @Model.DaysSinceFound days ago</span>
        </div>
    </div>
    <div class="detail-actions">
        @{
            var canEdit = User.IsInRole("Admin") || User.IsInRole("SuperAdmin") || User.IsInRole("Supervisor") || Model.CreatedBy == User.Identity?.Name;
        }
        @if (canEdit)
        {
            <a asp-action="Edit" asp-route-id="@Model.TrackingId" class="btn btn-secondary">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-action="PrintLabel" asp-route-id="@Model.TrackingId" target="_blank" class="btn btn-primary">
                <i class="bi bi-qr-code"></i> Print Label
            </a>
        }
        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
        {
            <form asp-action="Delete" asp-route-id="@Model.TrackingId" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger" data-confirm="Are you sure you want to permanently delete Record #@Model.CustomTrackingId? This cannot be undone.">
                    <i class="bi bi-trash3"></i> Delete
                </button>
            </form>
        }
    </div>
</div>

<div class="detail-layout">
    <!-- MAIN DETAILS -->
    <div>
        <div class="dc">
            <div class="dc-head"><i class="bi bi-clipboard-data"></i> Item Details</div>
            <div class="dc-body">
                <div class="dg">
                    <div>
                        <div class="dg-label">Tracking ID</div>
                        <div class="dg-value" style="font-family:var(--font-mono); color:var(--accent); font-weight:700;">@Model.CustomTrackingId</div>
                    </div>
                    <div>
                        <div class="dg-label">Date Found</div>
                        <div class="dg-value">@Model.DateFound.ToString("dddd, MMM dd, yyyy")</div>
                    </div>
                    <div>
                        <div class="dg-label">Item</div>
                        <div class="dg-value">@(Model.ItemName ?? "—")</div>
                    </div>
                    <div>
                        <div class="dg-label">Status</div>
                        <div class="dg-value"><span class="sb @statusClass">@(Model.StatusName ?? "—")</span></div>
                    </div>
                    <div class="span-2">
                        <div class="dg-label">Location Found</div>
                        <div class="dg-value">@Model.LocationFound</div>
                    </div>
                    <div>
                        <div class="dg-label">Status Date</div>
                        <div class="dg-value @(Model.StatusDate == null ? "dg-empty" : "")">@(Model.StatusDate?.ToString("MM/dd/yyyy") ?? "—")</div>
                    </div>
                    <div>
                        <div class="dg-label">Route</div>
                        <div class="dg-value @(Model.RouteName == null ? "dg-empty" : "")">@(Model.RouteName ?? "—")</div>
                    </div>
                    <div>
                        <div class="dg-label">Vehicle</div>
                        <div class="dg-value @(Model.VehicleName == null ? "dg-empty" : "")">@(Model.VehicleName ?? "—")</div>
                    </div>
                    <div>
                        <div class="dg-label">Storage Location</div>
                        <div class="dg-value @(Model.StorageLocationName == null ? "dg-empty" : "")">@(Model.StorageLocationName ?? "—")</div>
                    </div>
                    <div>
                        <div class="dg-label">Found By</div>
                        <div class="dg-value @(Model.FoundByName == null ? "dg-empty" : "")">@(Model.FoundByName ?? "—")</div>
                    </div>
                    <div>
                        <div class="dg-label">Claimed By</div>
                        <div class="dg-value @(Model.ClaimedBy == null ? "dg-empty" : "")">@(Model.ClaimedBy ?? "—")</div>
                    </div>
                    <div></div>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="span-3">
                            <div class="dg-label">Description</div>
                            <div class="dg-value" style="line-height:1.6;">@Model.Description</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <div class="span-3">
                            <div class="dg-label">Notes</div>
                            <div class="dg-value" style="line-height:1.6;">@Model.Notes</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <a asp-action="Search" class="btn btn-secondary" style="margin-top:4px;">
            <i class="bi bi-arrow-left"></i> Back to Search
        </a>
    </div>

    <!-- SIDEBAR -->
    <div>
        @if (!string.IsNullOrEmpty(Model.PhotoPath))
        {
            <div class="dc">
                <div class="dc-head"><i class="bi bi-image"></i> Photo</div>
                <div class="dc-body" style="text-align:center;">
                    <img src="@Url.Action("Photo", "LostFoundItem", new { id = Model.PhotoPath })" alt="Item photo" style="max-width:100%;max-height:300px;border-radius:6px;" />
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.AttachmentPath))
        {
            <div class="dc">
                <div class="dc-head"><i class="bi bi-paperclip"></i> Attachment</div>
                <div class="dc-body">
                    <a asp-action="Attachment" asp-route-id="@Model.AttachmentPath" class="btn btn-primary w-100">
                        <i class="bi bi-download"></i> Download Attachment
                    </a>
                </div>
            </div>
        }

        <div class="dc">
            <div class="dc-head"><i class="bi bi-clock-history"></i> Audit Trail</div>
            <div class="dc-body">
                <div style="margin-bottom:10px;">
                    <div class="dg-label">Created By</div>
                    <div style="font-size:13px;color:var(--text-secondary);">@(Model.CreatedBy ?? "—") on @Model.CreatedDateTime.ToString("MM/dd/yyyy HH:mm")</div>
                </div>
                @if (!string.IsNullOrEmpty(Model.ModifiedBy))
                {
                    <div>
                        <div class="dg-label">Last Modified</div>
                        <div style="font-size:13px;color:var(--text-secondary);">@Model.ModifiedBy on @Model.ModifiedDateTime?.ToString("MM/dd/yyyy HH:mm")</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
