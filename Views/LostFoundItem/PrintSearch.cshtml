@model SearchViewModel
@{
    ViewData["Title"] = "Print Search Results";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lost &amp; Found — Search Results</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>
        body {
            font-family: 'Inter', sans-serif;
            font-size: 11pt;
            padding: 20px;
            color: #000;
            background: #fff;
        }
        h1 { font-size: 16pt; font-weight: 700; margin: 0; color: #000; }
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
        .filter-summary {
            background: #f3f4f6;
            padding: 8px 12px;
            border-radius: 4px;
            font-size: 9pt;
            margin-bottom: 12px;
            color: #000;
            border: 1px solid #d1d5db;
        }
        table { width: 100%; border-collapse: collapse; font-size: 9pt; }
        th {
            background: #f3f4f6;
            padding: 6px 8px;
            border: 1px solid #d1d5db;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #000;
            font-size: 8pt;
        }
        td {
            padding: 5px 8px;
            border: 1px solid #e5e7eb;
            color: #111;
        }
        tr:nth-child(even) td { background: #f9fafb; }
        .no-print-btn {
            background: #4f46e5;
            color: #fff;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 9pt;
            font-weight: 600;
            cursor: pointer;
        }
        .no-print-btn:hover { background: #4338ca; }

        @@media print {
            body { padding: 10px; }
            .no-print { display: none !important; }
            .filter-summary { background: #f3f4f6; border: 1px solid #000; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            th { background: #e5e7eb; border-color: #000; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            td { border-color: #999; }
            tr:nth-child(even) td { background: #f3f4f6; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>Lost &amp; Found — Search Results</h1>
        <button class="no-print-btn no-print" onclick="window.print()">Print</button>
    </div>
    <div class="filter-summary">
        <strong>Filters:</strong> @Model.FilterSummary | <strong>Total:</strong> @Model.TotalRecords records | <strong>Generated:</strong> @DateTime.UtcNow.ToString("MM/dd/yyyy HH:mm")
    </div>
    <table>
        <thead>
            <tr>
                <th>#</th><th>ID</th><th>Date Found</th><th>Item</th><th>Description</th><th>Notes</th><th>Location</th><th>Route</th><th>Vehicle</th><th>Storage</th><th>Found By</th><th>Claimed By</th><th>Status</th><th>Days</th>
            </tr>
        </thead>
        <tbody>
            @{ var printRowNum = 0; }
            @foreach (var item in Model.Results)
            {
                printRowNum++;
                <tr>
                    <td>@printRowNum</td>
                    <td>@item.CustomTrackingId</td>
                    <td>@item.DateFound.ToString("MM/dd/yy")</td>
                    <td>@item.ItemName</td>
                    <td>@(item.Description?.Length > 50 ? item.Description[..50] + "..." : item.Description)</td>
                    <td>@(item.Notes?.Length > 50 ? item.Notes[..50] + "..." : item.Notes)</td>
                    <td>@item.LocationFound</td>
                    <td>@item.RouteName</td>
                    <td>@item.VehicleName</td>
                    <td>@item.StorageLocationName</td>
                    <td>@item.FoundByName</td>
                    <td>@item.ClaimedBy</td>
                    <td>@item.StatusName</td>
                    <td>@item.DaysSinceFound</td>
                </tr>
            }
        </tbody>
    </table>
    <script>window.onload = function() { window.print(); }</script>
</body>
</html>
