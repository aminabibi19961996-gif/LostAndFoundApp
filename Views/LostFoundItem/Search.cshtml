@model SearchViewModel
@{
    ViewData["Title"] = "Search Records";
}

@section Styles {
<style>
    .search-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; }
    .search-header-left { display: flex; align-items: center; gap: 12px; }
    .search-header-left h1 { font-family: var(--font-display); font-size: 1.625rem; font-weight: 800; color: var(--text-primary); letter-spacing: -.02em; display: flex; align-items: center; gap: 8px; }
    .search-header-left h1 i { font-size: 20px; color: var(--accent); }
    .search-header-left .count { font-size: 14px; color: var(--text-muted); font-weight: 500; }
    .search-actions { display: flex; gap: 8px; align-items: center; }

    /* Filter card */
    .fc { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 20px; overflow: hidden; }
    .fc-body { padding: 18px 20px; }
    .fg { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; }
    .fg .form-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); margin-bottom: 6px; }
    .fg .form-control, .fg .form-select { font-size: 14px; padding: 9px 12px; }
    .fc-actions { display: flex; justify-content: space-between; align-items: center; padding: 12px 20px; border-top: 1px solid var(--border); background: var(--bg-elevated); }

    /* Results card */
    .rc { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    .rc-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; border-bottom: 1px solid var(--border); background: var(--bg-elevated); }
    .rc-title { font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--text-primary); }

    /* Search table */
    .stable { width: 100%; border-collapse: collapse; }
    .stable thead th { padding: 11px 16px; text-align: left; font-size: 12px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .07em; border-bottom: 1px solid var(--border); white-space: nowrap; background: var(--bg-elevated); }
    .stable thead th:first-child { padding-left: 20px; }
    .stable thead th a { color: inherit; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; }
    .stable thead th a:hover { color: var(--text-primary); }
    .stable tbody td { padding: 12px 16px; font-size: 14.5px; font-weight: 500; border-bottom: 1px solid var(--border); color: var(--text-secondary); vertical-align: middle; }
    .stable tbody td:first-child { padding-left: 20px; }
    .stable tbody tr:last-child td { border-bottom: none; }
    .stable tbody tr:hover td { background: var(--bg-elevated); color: var(--text-primary); }
    .stable tbody tr:hover td:first-child { box-shadow: inset 3px 0 0 var(--accent); }
    .stable .tid { font-family: var(--font-mono); font-size: 13px; color: var(--text-primary); font-weight: 600; }

    /* Status badges */
    .sb { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; border-radius: 20px; font-size: 12.5px; font-weight: 700; border: 1px solid transparent; white-space: nowrap; }
    .sb::before { content:''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
    .sb-found       { background: var(--status-found-bg);       color: var(--status-found-text);       border-color: var(--status-found-border); }
    .sb-claimed     { background: var(--status-claimed-bg);     color: var(--status-claimed-text);     border-color: var(--status-claimed-border); }
    .sb-stored      { background: var(--status-stored-bg);      color: var(--status-stored-text);      border-color: var(--status-stored-border); }
    .sb-transferred { background: var(--status-transferred-bg); color: var(--status-transferred-text); border-color: var(--status-transferred-border); }
    .sb-disposed    { background: var(--status-disposed-bg);    color: var(--status-disposed-text);    border-color: var(--status-disposed-border); }
    .sb-unknown     { background: var(--bg-hover); color: var(--text-muted); }

    /* Row actions */
    .ra { display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 6px; background: transparent; border: none; color: var(--text-dim); cursor: pointer; font-size: 14px; text-decoration: none; transition: background .12s, color .12s; }
    .ra:hover { background: var(--bg-hover); color: var(--accent); }
    .cb { cursor: pointer; accent-color: var(--accent); width: 15px; height: 15px; }

    /* Pagination footer */
    .rc-footer { display: flex; align-items: center; justify-content: space-between; padding: 12px 20px; border-top: 1px solid var(--border); background: var(--bg-elevated); }
    .rc-footer-info { font-size: 13.5px; color: var(--text-dim); font-weight: 500; }

    .days-warn  { color: var(--amber); font-weight: 700; }
    .days-crit  { color: var(--red);   font-weight: 700; }
    .overdue-active { display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:20px;background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.3);color:#EF4444;font-size:12.5px;font-weight:700; }
</style>
}

<!-- HEADER -->
<div class="search-header">
    <div class="search-header-left">
        <h1><i class="bi bi-search"></i> Search Records</h1>
        <span class="count">@Model.TotalRecords record(s) found</span>
        @if (Model.ShowOverdueOnly)
        {
            <span class="overdue-active">
                <i class="bi bi-clock-history"></i>
                Overdue filter active (@Model.ShortOverdueDays+ days)
                <a asp-action="Search" style="color:inherit;opacity:.7;margin-left:2px;" title="Clear overdue filter"><i class="bi bi-x-lg"></i></a>
            </span>
        }
    </div>
    @if (Model.Results.Any())
    {
        <div class="search-actions">
            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
            {
                <div class="dropdown">
                    <button class="btn btn-secondary dropdown-toggle" type="button">
                        <i class="bi bi-gear"></i> Bulk Actions
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#" data-modal-target="bulkStatusModal"><i class="bi bi-pencil me-2"></i>Update Status</a></li>
                        <li><a class="dropdown-item text-danger" href="#" data-modal-target="bulkDeleteModal"><i class="bi bi-trash3 me-2"></i>Delete Selected</a></li>
                    </ul>
                </div>
            }
            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin") || User.IsInRole("Supervisor"))
            {
            <a asp-action="Export"
               asp-route-TrackingId="@Model.TrackingId"
               asp-route-CustomTrackingId="@Model.CustomTrackingId"
               asp-route-DateFoundFrom="@Model.DateFoundFrom?.ToString("yyyy-MM-dd")"
               asp-route-DateFoundTo="@Model.DateFoundTo?.ToString("yyyy-MM-dd")"
               asp-route-ItemId="@Model.ItemId"
               asp-route-StatusId="@Model.StatusId"
               asp-route-RouteId="@Model.RouteId"
               asp-route-VehicleId="@Model.VehicleId"
               asp-route-StorageLocationId="@Model.StorageLocationId"
               asp-route-FoundById="@Model.FoundById"
               class="btn btn-secondary" title="Export to CSV">
                <i class="bi bi-download"></i> Export
            </a>
            <a asp-action="PrintSearch"
               asp-route-TrackingId="@Model.TrackingId"
               asp-route-CustomTrackingId="@Model.CustomTrackingId"
               asp-route-DateFoundFrom="@Model.DateFoundFrom?.ToString("yyyy-MM-dd")"
               asp-route-DateFoundTo="@Model.DateFoundTo?.ToString("yyyy-MM-dd")"
               asp-route-ItemId="@Model.ItemId"
               asp-route-StatusId="@Model.StatusId"
               asp-route-RouteId="@Model.RouteId"
               asp-route-VehicleId="@Model.VehicleId"
               asp-route-StorageLocationId="@Model.StorageLocationId"
               asp-route-FoundById="@Model.FoundById"
               class="btn btn-secondary" target="_blank">
                <i class="bi bi-printer"></i> Print
            </a>
            }
        </div>
    }
</div>

@if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
{
<!-- Bulk Status Update Modal -->
<div class="announcement-modal" id="bulkStatusModal" style="display:none;">
    <div class="announcement-modal-backdrop" data-modal-close="bulkStatusModal"></div>
    <div class="announcement-modal-content" style="max-width:480px;">
        <div class="announcement-modal-header">
            <i class="bi bi-pencil-square"></i>
            <span>Bulk Status Update</span>
            <button type="button" class="announcement-modal-close" data-modal-close="bulkStatusModal">&times;</button>
        </div>
        <form asp-action="BulkStatusUpdate" method="post">
            @Html.AntiForgeryToken()
            <div class="announcement-modal-body">
                <p>Update status for <strong><span id="bulkStatusCount">0</span></strong> selected record(s):</p>
                <div class="mb-3">
                    <label class="form-label">New Status</label>
                    <select name="statusId" id="bulkStatusSelect" class="form-select" required>
                        <option value="">Select Status...</option>
                        @if (Model.Statuses != null)
                        {
                            @foreach (var status in Model.Statuses)
                            {
                                <option value="@status.Value">@status.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Status Date</label>
                    <input type="date" name="statusDate" id="bulkStatusDate" class="form-control" required />
                </div>
                <input type="hidden" name="ids" id="bulkStatusIds" />
            </div>
            <div class="announcement-modal-footer">
                <button type="button" class="btn btn-secondary" data-modal-close="bulkStatusModal">Cancel</button>
                <button type="submit" class="btn btn-primary">Update Status</button>
            </div>
        </form>
    </div>
</div>

<!-- Bulk Delete Modal -->
<div class="announcement-modal" id="bulkDeleteModal" style="display:none;">
    <div class="announcement-modal-backdrop" data-modal-close="bulkDeleteModal"></div>
    <div class="announcement-modal-content" style="max-width:480px;">
        <div class="announcement-modal-header" style="background:var(--red);">
            <i class="bi bi-trash3"></i>
            <span>Bulk Delete</span>
            <button type="button" class="announcement-modal-close" data-modal-close="bulkDeleteModal">&times;</button>
        </div>
        <form asp-action="BulkDelete" method="post">
            @Html.AntiForgeryToken()
            <div class="announcement-modal-body">
                <p style="color:var(--red)"><i class="bi bi-exclamation-triangle-fill me-1"></i> Are you sure you want to permanently delete <strong><span id="bulkDeleteCount">0</span></strong> record(s)? This cannot be undone.</p>
                <input type="hidden" name="ids" id="bulkDeleteIds" />
            </div>
            <div class="announcement-modal-footer">
                <button type="button" class="btn btn-secondary" data-modal-close="bulkDeleteModal">Cancel</button>
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash3 me-1"></i>Delete All</button>
            </div>
        </form>
    </div>
</div>
}

<!-- FILTERS -->
<div class="fc">
    <div class="fc-body">
        <form method="get" asp-action="Search">
            @* ── Overdue Quick Filter ── *@
            @if (!Model.ShowOverdueOnly)
            {
                <div style="margin-bottom:14px;display:flex;align-items:center;gap:8px;">
                    <a asp-action="Search" asp-route-ShowOverdueOnly="true" class="btn btn-sm" style="background:rgba(239,68,68,0.1);color:#EF4444;border:1px solid rgba(239,68,68,0.3);font-weight:700;">
                        <i class="bi bi-clock-history me-1"></i> Show Overdue Items (@Model.ShortOverdueDays+ days)
                    </a>
                    <span style="font-size:12px;color:var(--text-dim);">Lists all unresolved items older than @Model.ShortOverdueDays days</span>
                </div>
            }
            @if (Model.ShowOverdueOnly)
            {
                <input type="hidden" name="ShowOverdueOnly" value="true" />
            }
            <div class="fg">
                @* ── ID ── *@
                <div>
                    <label class="form-label">Internal ID</label>
                    <input type="number" name="TrackingId" value="@Model.TrackingId" class="form-control" placeholder="#" />
                </div>
                <div>
                    <label class="form-label">Tracking ID</label>
                    <input type="text" name="CustomTrackingId" value="@Model.CustomTrackingId" class="form-control" placeholder="LF-YYMMDD-XXXX" />
                </div>

                @* ── WHEN ── *@
                <div>
                    <label class="form-label">Date From</label>
                    <input type="date" name="DateFoundFrom" value="@Model.DateFoundFrom?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div>
                    <label class="form-label">Date To</label>
                    <input type="date" name="DateFoundTo" value="@Model.DateFoundTo?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>

                @* ── WHAT ── *@
                <div>
                    <label class="form-label">Item</label>
                    <select name="ItemId" class="form-select">
                        <option value="">All</option>
                        @if (Model.Items != null)
                        {
                            @foreach (var item in Model.Items)
                            {
                                <option value="@item.Value" selected="@(item.Value == Model.ItemId?.ToString() ? "selected" : null)">@item.Text</option>
                            }
                        }
                    </select>
                </div>

                @* ── WHERE ── *@
                <div>
                    <label class="form-label">Route</label>
                    <select name="RouteId" class="form-select">
                        <option value="">All</option>
                        @if (Model.Routes != null)
                        {
                            @foreach (var route in Model.Routes)
                            {
                                <option value="@route.Value" selected="@(route.Value == Model.RouteId?.ToString() ? "selected" : null)">@route.Text</option>
                            }
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Vehicle</label>
                    <select name="VehicleId" class="form-select">
                        <option value="">All</option>
                        @if (Model.Vehicles != null)
                        {
                            @foreach (var vehicle in Model.Vehicles)
                            {
                                <option value="@vehicle.Value" selected="@(vehicle.Value == Model.VehicleId?.ToString() ? "selected" : null)">@vehicle.Text</option>
                            }
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Storage Location</label>
                    <select name="StorageLocationId" class="form-select">
                        <option value="">All</option>
                        @if (Model.StorageLocations != null)
                        {
                            @foreach (var loc in Model.StorageLocations)
                            {
                                <option value="@loc.Value" selected="@(loc.Value == Model.StorageLocationId?.ToString() ? "selected" : null)">@loc.Text</option>
                            }
                        }
                    </select>
                </div>

                @* ── WHO ── *@
                <div>
                    <label class="form-label">Found By</label>
                    <select name="FoundById" class="form-select">
                        <option value="">All</option>
                        @if (Model.FoundByNames != null)
                        {
                            @foreach (var person in Model.FoundByNames)
                            {
                                <option value="@person.Value" selected="@(person.Value == Model.FoundById?.ToString() ? "selected" : null)">@person.Text</option>
                            }
                        }
                    </select>
                </div>

                @* ── STATUS ── *@
                <div>
                    <label class="form-label">Status</label>
                    <select name="StatusId" class="form-select">
                        <option value="">All</option>
                        @if (Model.Statuses != null)
                        {
                            @foreach (var status in Model.Statuses)
                            {
                                <option value="@status.Value" selected="@(status.Value == Model.StatusId?.ToString() ? "selected" : null)">@status.Text</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="fc-actions">
                <a asp-action="Search" class="btn btn-ghost btn-sm">
                    <i class="bi bi-x-circle me-1"></i> Clear Filters
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search me-1"></i> Search
                </button>
            </div>
        </form>
    </div>
</div>

<!-- RESULTS -->
<div class="rc">
    @if (Model.Results.Any())
    {
        <div style="overflow-x:auto;">
            <table class="stable">
                <thead>
                    <tr>
                        @{
                            var sortParams = new Dictionary<string, string?>
                            {
                                { "TrackingId", Model.TrackingId?.ToString() },
                                { "DateFoundFrom", Model.DateFoundFrom?.ToString("yyyy-MM-dd") },
                                { "DateFoundTo", Model.DateFoundTo?.ToString("yyyy-MM-dd") },
                                { "ItemId", Model.ItemId?.ToString() },
                                { "StatusId", Model.StatusId?.ToString() },
                                { "RouteId", Model.RouteId?.ToString() },
                                { "VehicleId", Model.VehicleId?.ToString() },
                                { "StorageLocationId", Model.StorageLocationId?.ToString() },
                                { "FoundById", Model.FoundById?.ToString() },
                            };
                            string SortIcon(string field) => Model.SortField == field ? (Model.SortOrder == "asc" ? "bi-sort-up" : "bi-sort-down") : "bi-chevron-expand";
                            string NextOrder(string field) => Model.SortField == field && Model.SortOrder == "desc" ? "asc" : "desc";
                        }
                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                        {
                            <th style="width:36px;"><input type="checkbox" id="selectAll" class="cb" /></th>
                        }
                        <th><a asp-action="Search" asp-all-route-data="sortParams" asp-route-SortField="TrackingId" asp-route-SortOrder="@NextOrder("TrackingId")">ID <i class="bi @SortIcon("TrackingId")"></i></a></th>
                        <th><a asp-action="Search" asp-all-route-data="sortParams" asp-route-SortField="DateFound" asp-route-SortOrder="@NextOrder("DateFound")">Date Found <i class="bi @SortIcon("DateFound")"></i></a></th>
                        <th><a asp-action="Search" asp-all-route-data="sortParams" asp-route-SortField="ItemName" asp-route-SortOrder="@NextOrder("ItemName")">Item <i class="bi @SortIcon("ItemName")"></i></a></th>
                        <th><a asp-action="Search" asp-all-route-data="sortParams" asp-route-SortField="LocationFound" asp-route-SortOrder="@NextOrder("LocationFound")">Location <i class="bi @SortIcon("LocationFound")"></i></a></th>
                        <th><a asp-action="Search" asp-all-route-data="sortParams" asp-route-SortField="StatusName" asp-route-SortOrder="@NextOrder("StatusName")">Status <i class="bi @SortIcon("StatusName")"></i></a></th>
                        <th>Days</th>
                        <th>Claimed By</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Results)
                    {
                        var statusClass = (item.StatusName?.ToLower()) switch {
                            "found" => "sb-found",
                            "claimed" => "sb-claimed",
                            "stored" => "sb-stored",
                            "transferred" => "sb-transferred",
                            "disposed" => "sb-disposed",
                            _ => "sb-unknown"
                        };
                        <tr>
                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                            {
                                <td><input type="checkbox" class="record-checkbox cb" value="@item.TrackingId" /></td>
                            }
                            <td><span class="tid">@item.CustomTrackingId</span></td>
                            <td>@item.DateFound.ToString("MM/dd/yyyy")</td>
                            <td style="color:var(--text-primary);font-weight:500;">@item.ItemName</td>
                            <td style="font-size:12.5px;">@item.LocationFound</td>
                            <td><span class="sb @statusClass">@(item.StatusName ?? "Unknown")</span></td>
                            <td>
                                @{
                                    var d = item.DaysInSystem;
                                    var dClass = d >= Model.LongOverdueDays ? "days-crit"
                                               : d >= Model.ShortOverdueDays ? "days-warn"
                                               : "";
                                }
                                @if (!string.IsNullOrEmpty(dClass))
                                {
                                    <span class="@dClass">@item.DaysSinceFound</span>
                                }
                                else
                                {
                                    @item.DaysSinceFound
                                }
                            </td>
                            <td>@(item.ClaimedBy ?? "—")</td>
                            <td>
                                <div style="display:flex;gap:3px;">
                                    <a class="ra" asp-action="Details" asp-route-id="@item.TrackingId" title="View"><i class="bi bi-eye"></i></a>
                                    @{
                                        // All authenticated users can edit any record — no ownership restriction
                                        var canEditItem = true;
                                    }
                                    @if (canEditItem)
                                    {
                                        <a class="ra" asp-action="Edit" asp-route-id="@item.TrackingId" title="Edit"><i class="bi bi-pencil"></i></a>
                                    }
                                    <a class="ra" asp-action="PrintLabel" asp-route-id="@item.TrackingId" target="_blank" title="Print Label"><i class="bi bi-qr-code"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="rc-footer">
                <span class="rc-footer-info">Page @Model.CurrentPage of @Model.TotalPages · @Model.TotalRecords records</span>
                <nav>
                    <ul class="pagination">
                        @if (Model.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Search"
                                   asp-route-CurrentPage="@(Model.CurrentPage - 1)"
                                   asp-route-TrackingId="@Model.TrackingId"
                                   asp-route-CustomTrackingId="@Model.CustomTrackingId"
                                   asp-route-DateFoundFrom="@Model.DateFoundFrom?.ToString("yyyy-MM-dd")"
                                   asp-route-DateFoundTo="@Model.DateFoundTo?.ToString("yyyy-MM-dd")"
                                   asp-route-ItemId="@Model.ItemId"
                                   asp-route-StatusId="@Model.StatusId"
                                   asp-route-RouteId="@Model.RouteId"
                                   asp-route-VehicleId="@Model.VehicleId"
                                   asp-route-StorageLocationId="@Model.StorageLocationId"
                                   asp-route-FoundById="@Model.FoundById"
                                   asp-route-SortField="@Model.SortField"
                                   asp-route-SortOrder="@Model.SortOrder">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                        }
                        @for (var i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Search"
                                   asp-route-CurrentPage="@i"
                                   asp-route-TrackingId="@Model.TrackingId"
                                   asp-route-CustomTrackingId="@Model.CustomTrackingId"
                                   asp-route-DateFoundFrom="@Model.DateFoundFrom?.ToString("yyyy-MM-dd")"
                                   asp-route-DateFoundTo="@Model.DateFoundTo?.ToString("yyyy-MM-dd")"
                                   asp-route-ItemId="@Model.ItemId"
                                   asp-route-StatusId="@Model.StatusId"
                                   asp-route-RouteId="@Model.RouteId"
                                   asp-route-VehicleId="@Model.VehicleId"
                                   asp-route-StorageLocationId="@Model.StorageLocationId"
                                   asp-route-FoundById="@Model.FoundById"
                                   asp-route-SortField="@Model.SortField"
                                   asp-route-SortOrder="@Model.SortOrder">@i</a>
                            </li>
                        }
                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Search"
                                   asp-route-CurrentPage="@(Model.CurrentPage + 1)"
                                   asp-route-TrackingId="@Model.TrackingId"
                                   asp-route-CustomTrackingId="@Model.CustomTrackingId"
                                   asp-route-DateFoundFrom="@Model.DateFoundFrom?.ToString("yyyy-MM-dd")"
                                   asp-route-DateFoundTo="@Model.DateFoundTo?.ToString("yyyy-MM-dd")"
                                   asp-route-ItemId="@Model.ItemId"
                                   asp-route-StatusId="@Model.StatusId"
                                   asp-route-RouteId="@Model.RouteId"
                                   asp-route-VehicleId="@Model.VehicleId"
                                   asp-route-StorageLocationId="@Model.StorageLocationId"
                                   asp-route-FoundById="@Model.FoundById"
                                   asp-route-SortField="@Model.SortField"
                                   asp-route-SortOrder="@Model.SortOrder">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    }
    else
    {
        <div style="padding:56px 24px;text-align:center;color:var(--text-muted);">
            <i class="bi bi-search" style="font-size:2.5rem;display:block;margin-bottom:20px;color:var(--text-dim);"></i>
            <div style="font-size:1rem;font-weight:600;color:var(--text-secondary);margin-bottom:6px;">No records found</div>
            <div style="font-size:0.875rem;">Try adjusting your search filters or create a new record.</div>
        </div>
    }
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    var selectAll = document.getElementById('selectAll');
    var checkboxes = document.querySelectorAll('.record-checkbox');

    if (selectAll) {
        selectAll.addEventListener('change', function() {
            checkboxes.forEach(function(cb) { cb.checked = selectAll.checked; });
            updateBulkCounts();
        });
    }

    checkboxes.forEach(function(cb) {
        cb.addEventListener('change', updateBulkCounts);
    });

    function updateBulkCounts() {
        var selected = document.querySelectorAll('.record-checkbox:checked');
        var count = selected.length;
        var statusCount = document.getElementById('bulkStatusCount');
        var deleteCount = document.getElementById('bulkDeleteCount');
        if (statusCount) statusCount.textContent = count;
        if (deleteCount) deleteCount.textContent = count;

        var ids = Array.from(selected).map(function(cb) { return cb.value; });
        var statusIds = document.getElementById('bulkStatusIds');
        var deleteIds = document.getElementById('bulkDeleteIds');
        if (statusIds) statusIds.value = ids.join(',');
        if (deleteIds) deleteIds.value = ids.join(',');
    }

    document.querySelectorAll('[data-modal-target]').forEach(function(trigger) {
        trigger.addEventListener('click', function(e) {
            e.preventDefault();
            var modalId = this.getAttribute('data-modal-target');
            var modal = document.getElementById(modalId);
            if (modal) {
                modal.style.display = '';
                document.body.style.overflow = 'hidden';

                // Set default status date to today when opening bulk status modal
                if (modalId === 'bulkStatusModal') {
                    var today = new Date();
                    var dd = String(today.getDate()).padStart(2, '0');
                    var mm = String(today.getMonth() + 1).padStart(2, '0');
                    var yyyy = today.getFullYear();
                    var dateStr = yyyy + '-' + mm + '-' + dd;
                    document.getElementById('bulkStatusDate').value = dateStr;
                }
            }
        });
    });

    // Auto-update status date when bulk status changes
    var bulkStatusSelect = document.getElementById('bulkStatusSelect');
    if (bulkStatusSelect) {
        bulkStatusSelect.addEventListener('change', function() {
            var today = new Date();
            var dd = String(today.getDate()).padStart(2, '0');
            var mm = String(today.getMonth() + 1).padStart(2, '0');
            var yyyy = today.getFullYear();
            document.getElementById('bulkStatusDate').value = yyyy + '-' + mm + '-' + dd;
        });
    }

    document.querySelectorAll('[data-modal-close]').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            var modalId = this.getAttribute('data-modal-close');
            var modal = document.getElementById(modalId);
            if (modal) {
                modal.style.display = 'none';
                document.body.style.overflow = '';
            }
        });
    });
});
</script>
}
