@model LostFoundItemCreateViewModel
@{
    ViewData["Title"] = "New Record";
}

@section Styles {
<style>
    .form-header { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
    .form-header h1 { font-family: var(--font-display); font-size: 1.625rem; font-weight: 800; color: var(--text-primary); letter-spacing: -.02em; display: flex; align-items: center; gap: 8px; }
    .form-header h1 i { font-size: 20px; color: var(--accent); }
    .form-header .subtitle { font-size: 14px; color: var(--text-muted); font-weight: 500; }

    .form-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    .form-card-header { padding: 14px 20px; border-bottom: 1px solid var(--border); background: var(--bg-elevated); font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--text-primary); display: flex; align-items: center; gap: 8px; }
    .form-card-header i { color: var(--accent); font-size: 16px; }
    .form-card-body { padding: 22px 20px; }
    .form-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .form-grid .span-2 { grid-column: span 2; }
    .form-grid .span-3 { grid-column: span 3; }
    .form-grid .span-4 { grid-column: span 4; }

    .fg-item .form-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); margin-bottom: 6px; }
    .fg-item .form-control, .fg-item .form-select { font-size: 14px; padding: 9px 12px; }
    .fg-item .form-text { font-size: 12px; color: var(--text-dim); margin-top: 4px; }

    .tip-panel { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 22px; height: fit-content; position: sticky; top: 80px; }
    .tip-icon { width: 42px; height: 42px; background: var(--accent-subtle); color: var(--accent); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; font-size: 18px; }
    .tip-title { font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--text-primary); margin-bottom: 14px; }
    .tip-item { font-size: 14px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 8px; }
    .tip-item strong { color: var(--accent); font-weight: 600; }
    .tip-footer { font-size: 12.5px; color: var(--text-dim); border-top: 1px solid var(--border); padding-top: 12px; margin-top: 16px; }

    .form-footer { display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; border-top: 1px solid var(--border); background: var(--bg-elevated); }
    .field-with-add { display: flex; gap: 4px; }
    .field-with-add select { flex: 1; }

    @@media (max-width: 992px) {
        .form-grid { grid-template-columns: repeat(2, 1fr); }
        .form-grid .span-2 { grid-column: span 2; }
        .form-grid .span-3 { grid-column: span 2; }
        .form-grid .span-4 { grid-column: span 2; }
        .form-layout { grid-template-columns: 1fr !important; }
    }
    @@media (max-width: 600px) {
        .form-grid { grid-template-columns: 1fr; }
        .form-grid .span-2, .form-grid .span-3 { grid-column: span 1; }
    }
</style>
}

<!-- HEADER -->
<div class="form-header">
    <div>
        <h1><i class="bi bi-plus-circle"></i> New Lost &amp; Found Record</h1>
        <div class="subtitle">Enter details of the found item</div>
    </div>
</div>

<!-- TIPS (inline info bar) -->
<div style="display:flex;align-items:center;gap:12px;background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:14px 20px;margin-bottom:16px;flex-wrap:wrap;">
    <div style="width:36px;height:36px;background:var(--accent-subtle);color:var(--accent);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;"><i class="bi bi-info-circle"></i></div>
    <div style="font-size:14px;color:var(--text-secondary);line-height:1.6;flex:1;"><strong style="color:var(--accent);">Tips:</strong> Ensure Date &amp; Location are precise · Use correct Item Type for faster matching · Clear photos increase return rates · Fields marked * are required</div>
</div>

<!-- MAIN FORM (full width) -->
<div class="form-card">
        <div class="form-card-header"><i class="bi bi-clipboard-data"></i> Item Information</div>
        <div class="form-card-body">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors" style="margin-bottom:14px;"></div>
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="form-grid">
                    <div class="fg-item">
                        <label asp-for="DateFound" class="form-label">Date Found *</label>
                        <input asp-for="DateFound" class="form-control" type="date" />
                        <span asp-validation-for="DateFound" class="text-danger small"></span>
                    </div>
                    <div class="fg-item">
                        <label asp-for="StatusDate" class="form-label">Status Date</label>
                        <input asp-for="StatusDate" class="form-control" type="date" />
                    </div>
                    <div class="fg-item">
                        <label asp-for="ItemId" class="form-label">Item Type *</label>
                        <div class="field-with-add">
                            <select asp-for="ItemId" asp-items="Model.Items" class="form-select">
                                <option value="">Select item type...</option>
                            </select>
                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin") || User.IsInRole("Supervisor"))
                            {
                            <button type="button" class="btn btn-sm btn-secondary" data-inline-create data-target-select="ItemId" data-endpoint="@Url.Action("AddItemAjax", "MasterData")" data-label="item type" title="Add new"><i class="bi bi-plus"></i></button>
                            }
                        </div>
                        <span asp-validation-for="ItemId" class="text-danger small"></span>
                    </div>
                    <div class="fg-item">
                        <label asp-for="StatusId" class="form-label">Status *</label>
                        <div class="field-with-add">
                            <select asp-for="StatusId" asp-items="Model.Statuses" class="form-select">
                                <option value="">Select status...</option>
                            </select>@if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin") || User.IsInRole("Supervisor"))
                            { <button type="button" class="btn btn-sm btn-secondary" data-inline-create data-target-select="StatusId" data-endpoint="@Url.Action("AddStatusAjax", "MasterData")" data-label="status" title="Add new"><i class="bi bi-plus"></i></button> }
                        </div>
                        <span asp-validation-for="StatusId" class="text-danger small"></span>
                    </div>

                    <div class="fg-item">
                        <label asp-for="LocationFound" class="form-label">Location Found *</label>
                        <input asp-for="LocationFound" class="form-control" placeholder="Where was the item found?" />
                        <span asp-validation-for="LocationFound" class="text-danger small"></span>
                    </div>

                    <div class="fg-item">
                        <label asp-for="RouteId" class="form-label">Route #</label>
                        <div class="field-with-add">
                            <select asp-for="RouteId" asp-items="Model.Routes" class="form-select"><option value="">Select route...</option></select>
                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin") || User.IsInRole("Supervisor"))
                            { <button type="button" class="btn btn-sm btn-secondary" data-inline-create data-target-select="RouteId" data-endpoint="@Url.Action("AddRouteAjax", "MasterData")" data-label="route" title="Add new"><i class="bi bi-plus"></i></button> }
                        </div>
                    </div>
                    <div class="fg-item">
                        <label asp-for="VehicleId" class="form-label">Vehicle #</label>
                        <div class="field-with-add">
                            <select asp-for="VehicleId" asp-items="Model.Vehicles" class="form-select"><option value="">Select vehicle...</option></select>
                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin") || User.IsInRole("Supervisor"))
                            { <button type="button" class="btn btn-sm btn-secondary" data-inline-create data-target-select="VehicleId" data-endpoint="@Url.Action("AddVehicleAjax", "MasterData")" data-label="vehicle" title="Add new"><i class="bi bi-plus"></i></button> }
                        </div>
                    </div>
                    <div class="fg-item">
                        <label asp-for="StorageLocationId" class="form-label">Storage Location</label>
                        <div class="field-with-add">
                            <select asp-for="StorageLocationId" asp-items="Model.StorageLocations" class="form-select"><option value="">Select location...</option></select>
                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin") || User.IsInRole("Supervisor"))
                            { <button type="button" class="btn btn-sm btn-secondary" data-inline-create data-target-select="StorageLocationId" data-endpoint="@Url.Action("AddStorageLocationAjax", "MasterData")" data-label="storage location" title="Add new"><i class="bi bi-plus"></i></button> }
                        </div>
                    </div>

                    <div class="fg-item">
                        <label asp-for="FoundById" class="form-label">Found By</label>
                        <div class="field-with-add">
                            <select asp-for="FoundById" asp-items="Model.FoundByNames" class="form-select"><option value="">Select person...</option></select>
                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin") || User.IsInRole("Supervisor"))
                            {
                                <button type="button" class="btn btn-sm btn-secondary" data-inline-create data-target-select="FoundById" data-endpoint="@Url.Action("AddFoundByNameAjax", "MasterData")" data-label="found by name" title="Add new"><i class="bi bi-plus"></i></button>
                            }
                        </div>
                    </div>
                    <div class="fg-item">
                        <label asp-for="ClaimedBy" class="form-label">Claimed By</label>
                        <input asp-for="ClaimedBy" class="form-control" placeholder="Name of claimant" />
                    </div>
                    <div class="fg-item" style="grid-column:span 1;"></div>

                    <div class="fg-item span-2">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Detailed description of the item..."></textarea>
                    </div>

                    <div class="fg-item span-2">
                        <label asp-for="Notes" class="form-label">Notes</label>
                        <textarea asp-for="Notes" class="form-control" rows="4" placeholder="Additional notes..."></textarea>
                    </div>

                    <div class="fg-item">
                        <label asp-for="PhotoFile" class="form-label">Photo</label>
                        <input asp-for="PhotoFile" class="form-control" type="file" accept=".jpg,.jpeg,.png,.gif" />
                        <span asp-validation-for="PhotoFile" class="text-danger small"></span>
                        <div class="form-text">JPG, PNG, or GIF. Max 10MB.</div>
                    </div>
                    <div class="fg-item">
                        <label asp-for="AttachmentFile" class="form-label">Attachment</label>
                        <input asp-for="AttachmentFile" class="form-control" type="file" accept=".pdf,.doc,.docx,.xls,.xlsx,.txt,.jpg,.jpeg,.png" />
                        <span asp-validation-for="AttachmentFile" class="text-danger small"></span>
                        <div class="form-text">PDF, DOC, XLS, TXT, or images. Max 10MB.</div>
                    </div>
                </div>

                <div class="form-footer" style="margin: 20px -20px -22px;border-radius:0 0 12px 12px;">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Create Record
                    </button>
                </div>
            </form>
        </div>
    </div>
