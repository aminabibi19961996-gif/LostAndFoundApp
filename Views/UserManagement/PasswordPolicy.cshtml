@model PasswordPolicyViewModel
@{
    ViewData["Title"] = "Password Policy";
}

<div class="page-header">
    <div class="container-fluid px-4">
        <div class="d-flex justify-content-between align-items-center" style="flex-wrap:wrap; gap:12px;">
            <div>
                <h1><i class="bi bi-shield-lock me-2"></i>Password Policy</h1>
                <p class="subtitle mb-0">Configure password requirements for local users</p>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid px-4">
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card fade-in-up">
                <div class="card-header"><i class="bi bi-key me-2 text-primary"></i>Password Requirements</div>
                <div class="card-body">
                    <form method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-3">
                            <label class="form-label" asp-for="MinimumLength"></label>
                            <input asp-for="MinimumLength" class="form-control" min="6" max="32" />
                            <div class="form-text">Minimum password length (6-32 characters)</div>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RequireDigit" class="form-check-input" />
                            <label class="form-check-label" asp-for="RequireDigit"></label>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RequireLowercase" class="form-check-input" />
                            <label class="form-check-label" asp-for="RequireLowercase"></label>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RequireUppercase" class="form-check-input" />
                            <label class="form-check-label" asp-for="RequireUppercase"></label>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RequireNonAlphanumeric" class="form-check-input" />
                            <label class="form-check-label" asp-for="RequireNonAlphanumeric"></label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i> Save Policy
                            </button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card fade-in-up">
                <div class="card-header"><i class="bi bi-info-circle me-2 text-primary"></i>Current Policy</div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Minimum Length</span>
                            <strong>@Model.MinimumLength characters</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Require Digit (0-9)</span>
                            <span class="badge bg-@(Model.RequireDigit ? \"success\" : \"secondary\")">@(Model.RequireDigit ? "Yes" : "No")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Require Lowercase (a-z)</span>
                            <span class="badge bg-@(Model.RequireLowercase ? \"success\" : \"secondary\")">@(Model.RequireLowercase ? "Yes" : "No")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Require Uppercase (A-Z)</span>
                            <span class="badge bg-@(Model.RequireUppercase ? \"success\" : \"secondary\")">@(Model.RequireUppercase ? "Yes" : "No")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Require Special Characters (!@#$%&*)</span>
                            <span class="badge bg-@(Model.RequireNonAlphanumeric ? \"success\" : \"secondary\")">@(Model.RequireNonAlphanumeric ? "Yes" : "No")</span>
                        </li>
                    </ul>
                    <div class="alert alert-info mt-3">
                        <i class="bi bi-info-circle me-2"></i>
                        Note: Active Directory users are managed by your organization's password policies.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
