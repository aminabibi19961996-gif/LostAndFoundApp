@model PasswordPolicyViewModel
@{
    ViewData["Title"] = "Password Policy";
}

@section Styles {
<style>
    .pp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .dc { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    .dc-head { padding: 14px 20px; border-bottom: 1px solid var(--border); font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--text-primary); background: var(--bg-elevated); display: flex; align-items: center; gap: 8px; }
    .dc-head i { color: var(--accent); font-size: 16px; }
    .dc-body { padding: 20px; }
    .pl-row { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--border); }
    .pl-row:last-child { border-bottom: none; }
    .pl-label { font-size: 15px; color: var(--text-secondary); font-weight: 500; }
    .pl-yes { padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 700; background: var(--green-light); color: var(--green); }
    .pl-no { padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 700; background: var(--bg-hover); color: var(--text-muted); }
    @@media (max-width: 768px) { .pp-grid { grid-template-columns: 1fr; } }
</style>
}

<!-- HEADER -->
<div style="margin-bottom:20px;">
    <h1 style="font-family:var(--font-display);font-size:1.625rem;font-weight:800;color:var(--text-primary);display:flex;align-items:center;gap:8px;">
        <i class="bi bi-shield-check" style="color:var(--accent)"></i> Password Policy
    </h1>
    <div style="font-size:14px;color:var(--text-muted);font-weight:500;">Configure password requirements for local users</div>
</div>

<div class="pp-grid">
    <!-- LEFT: Form -->
    <div class="dc">
        <div class="dc-head"><i class="bi bi-key"></i> Password Requirements</div>
        <div class="dc-body">
            <form method="post">
                @Html.AntiForgeryToken()
                <div style="display:flex;flex-direction:column;gap:14px;">
                    <div>
                        <label class="form-label" asp-for="MinimumLength" style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);"></label>
                        <input asp-for="MinimumLength" class="form-control" min="6" max="32" />
                        <div style="font-size:12.5px;color:var(--text-dim);margin-top:4px;">6-32 characters</div>
                    </div>
                    <div class="form-check">
                        <input asp-for="RequireDigit" class="form-check-input" />
                        <label class="form-check-label" asp-for="RequireDigit"></label>
                    </div>
                    <div class="form-check">
                        <input asp-for="RequireLowercase" class="form-check-input" />
                        <label class="form-check-label" asp-for="RequireLowercase"></label>
                    </div>
                    <div class="form-check">
                        <input asp-for="RequireUppercase" class="form-check-input" />
                        <label class="form-check-label" asp-for="RequireUppercase"></label>
                    </div>
                    <div class="form-check">
                        <input asp-for="RequireNonAlphanumeric" class="form-check-input" />
                        <label class="form-check-label" asp-for="RequireNonAlphanumeric"></label>
                    </div>
                </div>
                <div style="display:flex;gap:8px;margin-top:18px;">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save Policy</button>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>

    <!-- RIGHT: Current Policy Display -->
    <div class="dc">
        <div class="dc-head"><i class="bi bi-info-circle"></i> Current Policy</div>
        <div class="dc-body">
            <div class="pl-row">
                <span class="pl-label">Minimum Length</span>
                <strong style="color:var(--text-primary);font-family:var(--font-mono);">@Model.MinimumLength chars</strong>
            </div>
            <div class="pl-row">
                <span class="pl-label">Require Digit (0-9)</span>
                <span class="@(Model.RequireDigit ? "pl-yes" : "pl-no")">@(Model.RequireDigit ? "Yes" : "No")</span>
            </div>
            <div class="pl-row">
                <span class="pl-label">Require Lowercase (a-z)</span>
                <span class="@(Model.RequireLowercase ? "pl-yes" : "pl-no")">@(Model.RequireLowercase ? "Yes" : "No")</span>
            </div>
            <div class="pl-row">
                <span class="pl-label">Require Uppercase (A-Z)</span>
                <span class="@(Model.RequireUppercase ? "pl-yes" : "pl-no")">@(Model.RequireUppercase ? "Yes" : "No")</span>
            </div>
            <div class="pl-row">
                <span class="pl-label">Require Special Chars</span>
                <span class="@(Model.RequireNonAlphanumeric ? "pl-yes" : "pl-no")">@(Model.RequireNonAlphanumeric ? "Yes" : "No")</span>
            </div>
            <div style="background:var(--accent-subtle);color:var(--accent);border-radius:7px;padding:10px 14px;margin-top:14px;font-size:12.5px;">
                <i class="bi bi-info-circle me-1"></i> AD users are managed by your organization's password policies.
            </div>
        </div>
    </div>
</div>
