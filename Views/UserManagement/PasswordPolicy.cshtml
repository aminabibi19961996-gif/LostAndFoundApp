@model PasswordPolicyViewModel
@{
    ViewData["Title"] = "Password Policy";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center" style="flex-wrap:wrap; gap:12px;">
        <div>
            <h1 class="page-title"><svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display:inline-block;vertical-align:middle;margin-right:8px;"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>Password Policy</h1>
            <p class="page-subtitle">Configure password requirements for local users</p>
        </div>
    </div>
</div>
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header"><i class="bi bi-key me-2 text-primary"></i>Password Requirements</div>
                <div class="card-body">
                    <form method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-3">
                            <label class="form-label" asp-for="MinimumLength"></label>
                            <input asp-for="MinimumLength" class="form-control" min="6" max="32" />
                            <div class="form-text">Minimum password length (6-32 characters)</div>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RequireDigit" class="form-check-input" />
                            <label class="form-check-label" asp-for="RequireDigit"></label>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RequireLowercase" class="form-check-input" />
                            <label class="form-check-label" asp-for="RequireLowercase"></label>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RequireUppercase" class="form-check-input" />
                            <label class="form-check-label" asp-for="RequireUppercase"></label>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RequireNonAlphanumeric" class="form-check-input" />
                            <label class="form-check-label" asp-for="RequireNonAlphanumeric"></label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i> Save Policy
                            </button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card">
                <div class="card-header"><i class="bi bi-info-circle me-2 text-primary"></i>Current Policy</div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Minimum Length</span>
                            <strong>@Model.MinimumLength characters</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Require Digit (0-9)</span>
                            <span class="badge @(Model.RequireDigit ? "bg-success" : "bg-secondary")">@(Model.RequireDigit ? "Yes" : "No")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Require Lowercase (a-z)</span>
                            <span class="badge @(Model.RequireLowercase ? "bg-success" : "bg-secondary")">@(Model.RequireLowercase ? "Yes" : "No")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Require Uppercase (A-Z)</span>
                            <span class="badge @(Model.RequireUppercase ? "bg-success" : "bg-secondary")">@(Model.RequireUppercase ? "Yes" : "No")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Require Special Characters (!@@#$%&amp;*)</span>
                            <span class="badge @(Model.RequireNonAlphanumeric ? "bg-success" : "bg-secondary")">@(Model.RequireNonAlphanumeric ? "Yes" : "No")</span>
                        </li>
                    </ul>
                    <div class="alert alert-info mt-3">
                        <i class="bi bi-info-circle me-2"></i>
                        Note: Active Directory users are managed by your organization's password policies.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
