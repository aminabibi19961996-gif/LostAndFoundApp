@model EditUserRoleViewModel
@{
    ViewData["Title"] = "Edit Role";
}

<div class="card" style="max-width: 500px; margin: 0 auto;">
    <div class="card-header"><span class="card-title">Edit User Role</span></div>
    <div class="card-body">
        <div class="alert alert-info">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Changing the role for <strong>@Model.UserName</strong>
                @if (!string.IsNullOrEmpty(Model.DisplayName))
                {
                    <span class="ms-1">(@Model.DisplayName)</span>
                }
            </div>

            <form asp-action="EditRole" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="UserName" />
                <input type="hidden" asp-for="DisplayName" />

                <div class="mb-3">
                    <label class="form-label">Current Role</label>
                    <input value="@Model.CurrentRole" class="form-control" disabled />
                </div>

                <div class="mb-4">
                    <label asp-for="NewRole" class="form-label">New Role</label>
                    <select asp-for="NewRole" class="form-select">
                        <option value="User">User</option>
                        <option value="Admin">Admin</option>
                        <option value="SuperAdmin">Super Admin</option>
                    </select>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg> Cancel
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Save Role
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
