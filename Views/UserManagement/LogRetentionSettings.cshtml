@model LogRetentionSettingsViewModel
@{
    ViewData["Title"] = "Log Retention Settings";
}

@section Styles {
<style>
    .lr-container { max-width: 560px; margin: 0 auto; }
    .lr-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; }
    .lr-header { padding: 22px 28px 18px; border-bottom: 1px solid var(--border); background: var(--bg-elevated); display: flex; align-items: center; gap: 12px; }
    .lr-header i { font-size: 20px; color: var(--accent); }
    .lr-header h1 { font-family: var(--font-display); font-size: 1.25rem; font-weight: 800; color: var(--text-primary); letter-spacing: -.02em; margin: 0; }
    .lr-body { padding: 28px; }
    .lr-info { background: rgba(124,143,255,0.08); border: 1px solid rgba(124,143,255,0.2); border-radius: 10px; padding: 14px 16px; margin-bottom: 24px; font-size: 13.5px; color: var(--text-secondary); line-height: 1.6; }
    .lr-info strong { color: var(--text-primary); }
    .lr-field { margin-bottom: 22px; }
    .lr-field label { display: block; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); margin-bottom: 10px; }
    .lr-options { display: flex; gap: 12px; flex-wrap: wrap; }
    .lr-option { position: relative; }
    .lr-option input[type=radio] { position: absolute; opacity: 0; width: 0; height: 0; }
    .lr-option .lr-btn {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        min-width: 120px; padding: 16px 20px;
        background: var(--bg-input); border: 2px solid var(--border); border-radius: var(--radius-md);
        color: var(--text-secondary); cursor: pointer; transition: all var(--transition); user-select: none;
    }
    .lr-option .lr-btn:hover { border-color: var(--accent); background: rgba(124,143,255,0.06); }
    .lr-option input[type=radio]:checked + .lr-btn {
        border-color: var(--accent); background: rgba(124,143,255,0.10);
        box-shadow: 0 0 0 3px rgba(124,143,255,0.18);
    }
    .lr-option .lr-val { font-size: 28px; font-weight: 800; font-family: var(--font-mono); color: var(--text-primary); line-height: 1; }
    .lr-option .lr-unit { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; margin-top: 4px; color: var(--text-muted); }
    .lr-option input[type=radio]:checked + .lr-btn .lr-val { color: var(--accent); }
    .lr-field .help { font-size: 12.5px; color: var(--text-dim); margin-top: 10px; }
    .lr-preview { margin-top: 18px; padding: 14px 16px; background: var(--bg-elevated); border-radius: 10px; border: 1px solid var(--border); font-size: 13px; color: var(--text-muted); }
    .lr-preview strong { color: var(--text-secondary); }
    .lr-preview .date { color: var(--accent); font-weight: 700; font-family: var(--font-mono); }
    .lr-footer { padding: 18px 28px; border-top: 1px solid var(--border); background: var(--bg-elevated); display: flex; justify-content: space-between; align-items: center; }
    .lr-warning { background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.2); border-radius: 10px; padding: 12px 16px; margin-top: 18px; font-size: 13px; color: var(--text-secondary); line-height: 1.6; display: flex; align-items: flex-start; gap: 10px; }
    .lr-warning i { color: #F59E0B; font-size: 16px; flex-shrink: 0; margin-top: 1px; }
    .lr-purge-status { margin-top: 18px; padding: 14px 16px; background: var(--bg-elevated); border-radius: 10px; border: 1px solid var(--border); font-size: 13px; color: var(--text-muted); display: flex; align-items: center; gap: 10px; }
    .lr-purge-status i { font-size: 16px; flex-shrink: 0; }
    .lr-purge-status .purge-label { font-weight: 700; color: var(--text-secondary); font-size: 12px; text-transform: uppercase; letter-spacing: .06em; }
    .lr-purge-status .purge-time { color: var(--accent); font-weight: 700; font-family: var(--font-mono); }
    .lr-purge-status .purge-ago { color: var(--text-dim); font-size: 12px; }
    .lr-purge-status .purge-count { color: var(--text-secondary); }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>
}

<div class="lr-container">
    <div class="lr-card">
        <div class="lr-header">
            <i class="bi bi-archive"></i>
            <h1>Log Retention Settings</h1>
        </div>
        <div class="lr-body">
            <div class="lr-info">
                <strong>What is log retention?</strong><br />
                Activity logs capture every action in the system — logins, item changes, role updates,
                AD syncs, and more. This setting controls how long those records are kept.
                A background service automatically purges logs older than the configured period
                every day at <strong>3:00 AM</strong>. Changes take effect immediately.
            </div>

            <form asp-action="LogRetentionSettings" method="post">
                @Html.AntiForgeryToken()

                <div class="lr-field">
                    <label>Retention Period</label>
                    <div class="lr-options">
                        <label class="lr-option">
                            <input type="radio" name="RetentionDays" value="30"
                                   @(Model.RetentionDays == 30 ? "checked" : "") />
                            <span class="lr-btn">
                                <span class="lr-val">30</span>
                                <span class="lr-unit">days</span>
                            </span>
                        </label>
                        <label class="lr-option">
                            <input type="radio" name="RetentionDays" value="60"
                                   @(Model.RetentionDays == 60 ? "checked" : "") />
                            <span class="lr-btn">
                                <span class="lr-val">60</span>
                                <span class="lr-unit">days</span>
                            </span>
                        </label>
                        <label class="lr-option">
                            <input type="radio" name="RetentionDays" value="90"
                                   @(Model.RetentionDays == 90 ? "checked" : "") />
                            <span class="lr-btn">
                                <span class="lr-val">90</span>
                                <span class="lr-unit">days</span>
                            </span>
                        </label>
                    </div>
                    <div class="help">
                        Activity logs older than the selected period are automatically deleted by a daily background task.
                    </div>
                    <span asp-validation-for="RetentionDays" class="text-danger small"></span>
                </div>

                <div class="lr-preview" id="lrPreview">
                    <strong>Current setting:</strong>
                    Logs older than <span class="date" id="previewDays">@Model.RetentionDays days</span> are purged daily.
                    Oldest kept log: <span class="date" id="previewDate"></span>.
                </div>

                <div class="lr-purge-status">
                    <i class="bi bi-clock-history" style="color:var(--accent);"></i>
                    <div>
                        <div class="purge-label">Last Purge</div>
                        @if (Model.LastPurgedAt.HasValue)
                        {
                            <span class="purge-time">@Model.LastPurgedAt.Value.ToString("MMM dd, yyyy 'at' HH:mm")</span>
                            <span class="purge-ago" id="purgeAgo"></span>
                            <span class="purge-count"> — <strong>@(Model.LastPurgedCount?.ToString("N0") ?? "0")</strong> record(s) deleted</span>
                        }
                        else
                        {
                            <span style="color:var(--text-dim);font-style:italic;">No purge has run yet. The service runs daily at 3:00 AM.</span>
                        }
                    </div>
                </div>

                <div class="lr-warning">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>
                        <strong>Reducing the retention period</strong> will permanently delete logs outside the
                        new window on the next daily purge. This action cannot be undone.
                    </span>
                </div>

                <div class="lr-footer" style="margin: 24px -28px -28px; border-radius: 0 0 14px 14px;">
                    <div style="display:flex;gap:8px;">
                        <a asp-action="Index" class="btn btn-ghost">
                            <i class="bi bi-arrow-left me-1"></i> Back
                        </a>
                        <button type="button" class="btn btn-ghost" id="runPurgeBtn" style="color:#F59E0B;border-color:rgba(245,158,11,0.3);">
                            <i class="bi bi-lightning-charge me-1"></i> Run Purge Now
                        </button>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i> Save Setting
                    </button>
                </div>
            </form>

            <!-- Confirmation modal for reducing retention -->
            <div id="confirmReduceModal" class="modal" style="display:none;">
                <div class="modal-backdrop" id="confirmReduceBackdrop"></div>
                <div class="modal-content" style="max-width:440px;">
                    <div class="modal-header">
                        <i class="bi bi-exclamation-triangle-fill" style="font-size:16px;color:#F59E0B"></i>
                        <span>Confirm Retention Reduction</span>
                        <button type="button" class="modal-close" id="confirmReduceClose">&times;</button>
                    </div>
                    <div class="modal-body" style="padding:20px 24px;">
                        <p style="margin:0 0 12px;font-size:14px;color:var(--text-primary);font-weight:600;">
                            You are reducing the retention period.
                        </p>
                        <p style="margin:0 0 14px;font-size:13px;color:var(--text-secondary);line-height:1.6;">
                            Activity logs older than <strong id="confirmNewDays"></strong> will be
                            <strong style="color:#EF4444;">permanently deleted</strong> on the next daily purge.
                            This action cannot be undone.
                        </p>
                        <div id="confirmCountBox" style="background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.18);border-radius:8px;padding:12px 14px;font-size:13px;color:var(--text-secondary);display:none;">
                            <span id="confirmCountLoading"><i class="bi bi-arrow-repeat" style="animation:spin 1s linear infinite;display:inline-block;"></i> Counting affected records…</span>
                            <span id="confirmCountResult" style="display:none;">
                                <i class="bi bi-database-x" style="color:#EF4444;margin-right:4px;"></i>
                                <strong id="confirmCountNum" style="color:#EF4444;font-family:var(--font-mono);"></strong> activity log record(s) will be deleted.
                            </span>
                            <span id="confirmCountError" style="display:none;color:var(--text-muted);">Could not retrieve count.</span>
                        </div>
                    </div>
                    <div class="modal-footer" style="justify-content:flex-end;gap:8px;">
                        <button type="button" class="btn btn-ghost" id="confirmReduceCancel">Cancel</button>
                        <button type="button" class="btn" id="confirmReduceYes" style="background:rgba(239,68,68,0.12);color:#EF4444;border:1px solid rgba(239,68,68,0.25);font-weight:700;">
                            <i class="bi bi-trash3 me-1"></i> Yes, Reduce &amp; Save
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Confirmation modal for manual purge -->
<div id="purgeNowModal" class="modal" style="display:none;">
    <div class="modal-backdrop" id="purgeNowBackdrop"></div>
    <div class="modal-content" style="max-width:440px;">
        <div class="modal-header">
            <i class="bi bi-lightning-charge-fill" style="font-size:16px;color:#F59E0B"></i>
            <span>Run Purge Now</span>
            <button type="button" class="modal-close" id="purgeNowClose">&times;</button>
        </div>
        <div class="modal-body" style="padding:20px 24px;">
            <p style="margin:0 0 12px;font-size:14px;color:var(--text-primary);font-weight:600;">
                Manually run the log retention purge now?
            </p>
            <p style="margin:0;font-size:13px;color:var(--text-secondary);line-height:1.6;">
                This will immediately delete all activity log records older than the configured
                <strong>@Model.RetentionDays days</strong>. This action cannot be undone.
            </p>
        </div>
        <div class="modal-footer" style="justify-content:flex-end;gap:8px;">
            <button type="button" class="btn btn-ghost" id="purgeNowCancel">Cancel</button>
            <form asp-action="RunLogPurgeNow" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn" style="background:rgba(245,158,11,0.12);color:#F59E0B;border:1px solid rgba(245,158,11,0.25);font-weight:700;">
                    <i class="bi bi-lightning-charge me-1"></i> Run Purge Now
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Live preview update
    var radios = document.querySelectorAll('input[name="RetentionDays"]');
    var previewDays = document.getElementById('previewDays');
    var previewDate = document.getElementById('previewDate');

    function updatePreview() {
        var selected = document.querySelector('input[name="RetentionDays"]:checked');
        if (!selected) return;
        var days = parseInt(selected.value);
        previewDays.textContent = days + ' days';
        var cutoff = new Date();
        cutoff.setDate(cutoff.getDate() - days);
        previewDate.textContent = cutoff.toLocaleDateString('en-US', {
            year: 'numeric', month: 'short', day: 'numeric'
        });
    }

    radios.forEach(function (r) {
        r.addEventListener('change', updatePreview);
    });

    // Initial render
    updatePreview();

    // Relative time for last purge
    (function () {
        var purgeAgo = document.getElementById('purgeAgo');
        if (!purgeAgo) return;
        var purgeUtc = new Date('@(Model.LastPurgedAt?.ToString("o") ?? "")');
        if (isNaN(purgeUtc.getTime())) return;
        var diffMs = Date.now() - purgeUtc.getTime();
        var diffMin = Math.floor(diffMs / 60000);
        var diffHr = Math.floor(diffMin / 60);
        var diffDay = Math.floor(diffHr / 24);
        var ago = diffDay > 0 ? diffDay + 'd ago'
                : diffHr > 0 ? diffHr + 'h ago'
                : diffMin > 0 ? diffMin + 'm ago'
                : 'just now';
        purgeAgo.textContent = '(' + ago + ')';
    })();

    // Confirmation dialog when reducing retention period
    (function () {
        var savedDays = @Model.RetentionDays;
        var form = document.querySelector('form[action*="LogRetentionSettings"]');
        var modal = document.getElementById('confirmReduceModal');
        var backdrop = document.getElementById('confirmReduceBackdrop');
        var closeBtn = document.getElementById('confirmReduceClose');
        var cancelBtn = document.getElementById('confirmReduceCancel');
        var yesBtn = document.getElementById('confirmReduceYes');
        var newDaysSpan = document.getElementById('confirmNewDays');

        function hideModal() { modal.style.display = 'none'; }

        var countBox = document.getElementById('confirmCountBox');
        var countLoading = document.getElementById('confirmCountLoading');
        var countResult = document.getElementById('confirmCountResult');
        var countError = document.getElementById('confirmCountError');
        var countNum = document.getElementById('confirmCountNum');

        function fetchAffectedCount(days) {
            countBox.style.display = 'block';
            countLoading.style.display = 'inline';
            countResult.style.display = 'none';
            countError.style.display = 'none';

            fetch('@Url.Action("LogRetentionCount", "UserManagement")?days=' + days)
                .then(function (r) { if (!r.ok) throw new Error(); return r.json(); })
                .then(function (data) {
                    countLoading.style.display = 'none';
                    countNum.textContent = data.count.toLocaleString();
                    countResult.style.display = 'inline';
                })
                .catch(function () {
                    countLoading.style.display = 'none';
                    countError.style.display = 'inline';
                });
        }

        form.addEventListener('submit', function (e) {
            var selected = document.querySelector('input[name="RetentionDays"]:checked');
            if (!selected) return;
            var newDays = parseInt(selected.value);
            if (newDays < savedDays) {
                e.preventDefault();
                newDaysSpan.textContent = newDays + ' days';
                modal.style.display = 'flex';
                fetchAffectedCount(newDays);
            }
        });

        yesBtn.addEventListener('click', function () {
            hideModal();
            form.submit();
        });

        closeBtn.addEventListener('click', hideModal);
        cancelBtn.addEventListener('click', hideModal);
        backdrop.addEventListener('click', hideModal);
    })();

    // Manual purge button
    (function () {
        var purgeBtn = document.getElementById('runPurgeBtn');
        if (!purgeBtn) return;
        var modal = document.getElementById('purgeNowModal');
        var backdrop = document.getElementById('purgeNowBackdrop');
        var closeBtn = document.getElementById('purgeNowClose');
        var cancelBtn = document.getElementById('purgeNowCancel');

        function hideModal() { modal.style.display = 'none'; }
        function showModal() { modal.style.display = 'flex'; }

        purgeBtn.addEventListener('click', showModal);
        closeBtn.addEventListener('click', hideModal);
        cancelBtn.addEventListener('click', hideModal);
        backdrop.addEventListener('click', hideModal);
    })();
</script>
}
