@model OverdueSettingsViewModel
@{
    ViewData["Title"] = "Overdue Settings";
}

@section Styles {
<style>
    .os-container { max-width: 560px; margin: 0 auto; }
    .os-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; }
    .os-header { padding: 22px 28px 18px; border-bottom: 1px solid var(--border); background: var(--bg-elevated); display: flex; align-items: center; gap: 12px; }
    .os-header i { font-size: 20px; color: var(--accent); }
    .os-header h1 { font-family: var(--font-display); font-size: 1.25rem; font-weight: 800; color: var(--text-primary); letter-spacing: -.02em; margin: 0; }
    .os-body { padding: 28px; }
    .os-info { background: rgba(124,143,255,0.08); border: 1px solid rgba(124,143,255,0.2); border-radius: 10px; padding: 14px 16px; margin-bottom: 24px; font-size: 13.5px; color: var(--text-secondary); line-height: 1.6; }
    .os-info strong { color: var(--text-primary); }
    .os-field { margin-bottom: 22px; }
    .os-field label { display: block; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); margin-bottom: 8px; }
    .os-field .input-row { display: flex; align-items: center; gap: 12px; }
    .os-field input[type=number] { width: 120px; background: var(--bg-input); border: 1px solid var(--border); border-radius: var(--radius-md); color: var(--text-primary); font-size: 20px; font-weight: 700; font-family: var(--font-mono); padding: 10px 14px; text-align: center; transition: border-color var(--transition); }
    .os-field input[type=number]:focus { border-color: var(--accent); outline: none; box-shadow: 0 0 0 3px rgba(124,143,255,0.18); }
    .os-field .unit { font-size: 14px; color: var(--text-muted); font-weight: 600; }
    .os-field .help { font-size: 12.5px; color: var(--text-dim); margin-top: 6px; }
    .os-badge { display: inline-flex; align-items: center; gap: 6px; padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 700; }
    .os-badge-amber { background: rgba(245,158,11,0.12); color: #F59E0B; border: 1px solid rgba(245,158,11,0.25); }
    .os-badge-red   { background: rgba(239,68,68,0.12);  color: #EF4444; border: 1px solid rgba(239,68,68,0.25); }
    .os-footer { padding: 18px 28px; border-top: 1px solid var(--border); background: var(--bg-elevated); display: flex; justify-content: space-between; align-items: center; }
    .os-preview { margin-top: 18px; padding: 14px 16px; background: var(--bg-elevated); border-radius: 10px; border: 1px solid var(--border); font-size: 13px; color: var(--text-muted); }
    .os-preview strong { color: var(--text-secondary); }
</style>
}

<div class="os-container">
    <div class="os-card">
        <div class="os-header">
            <i class="bi bi-clock-history"></i>
            <h1>Overdue Thresholds</h1>
        </div>
        <div class="os-body">
            <div class="os-info">
                <strong>What are overdue thresholds?</strong><br />
                Items that remain unresolved (not Claimed, Disposed, or Transferred) are flagged as overdue
                based on how long they have been in the system. These thresholds control when the
                <strong>dashboard alerts</strong> and the <strong>Search "Show Overdue"</strong> filter trigger.
                Changes take effect immediately — no restart required.
            </div>

            <form asp-action="OverdueSettings" method="post">
                @Html.AntiForgeryToken()

                <div class="os-field">
                    <label asp-for="ShortOverdueDays">
                        Short Overdue Threshold
                        <span class="os-badge os-badge-amber ms-1"><i class="bi bi-exclamation-triangle-fill"></i> Warning</span>
                    </label>
                    <div class="input-row">
                        <input asp-for="ShortOverdueDays" type="number" min="1" max="365" />
                        <span class="unit">days</span>
                    </div>
                    <div class="help">Items in the system for <em>this many days or more</em> are flagged on dashboards and listed by the "Show Overdue" button in Search.</div>
                    <span asp-validation-for="ShortOverdueDays" class="text-danger small"></span>
                </div>

                <div class="os-field">
                    <label asp-for="LongOverdueDays">
                        Long Overdue Threshold
                        <span class="os-badge os-badge-red ms-1"><i class="bi bi-exclamation-octagon-fill"></i> Critical</span>
                    </label>
                    <div class="input-row">
                        <input asp-for="LongOverdueDays" type="number" min="1" max="3650" />
                        <span class="unit">days</span>
                    </div>
                    <div class="help">Items in the system for <em>this many days or more</em> are shown in the critical alert cards on the SuperAdmin and Admin dashboards.</div>
                    <span asp-validation-for="LongOverdueDays" class="text-danger small"></span>
                </div>

                <div class="os-preview" id="osPreview">
                    <strong>Live preview:</strong>
                    An item found today would be flagged at
                    <span id="prevShort" style="color:var(--amber);font-weight:700;">@Model.ShortOverdueDays days</span> (short)
                    and
                    <span id="prevLong" style="color:var(--red);font-weight:700;">@Model.LongOverdueDays days</span> (long).
                </div>

                <div class="os-footer" style="margin: 24px -28px -28px; border-radius: 0 0 14px 14px;">
                    <a asp-action="Index" class="btn btn-ghost">
                        <i class="bi bi-arrow-left me-1"></i> Back
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i> Save Thresholds
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Live preview update
    var shortInput = document.querySelector('[name="ShortOverdueDays"]');
    var longInput  = document.querySelector('[name="LongOverdueDays"]');
    var prevShort  = document.getElementById('prevShort');
    var prevLong   = document.getElementById('prevLong');

    function updatePreview() {
        var s = parseInt(shortInput.value) || 0;
        var l = parseInt(longInput.value)  || 0;
        prevShort.textContent = s + ' days';
        prevLong.textContent  = l + ' days';
    }

    shortInput.addEventListener('input', updatePreview);
    longInput.addEventListener('input', updatePreview);
</script>
}
