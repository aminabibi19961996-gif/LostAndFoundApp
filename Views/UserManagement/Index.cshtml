@model List<UserListViewModel>
@{
    ViewData["Title"] = "User Management";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center" style="flex-wrap:wrap; gap:12px;">
        <div>
            <h1 class="page-title"><svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display:inline-block;vertical-align:middle;margin-right:8px;"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>User Management</h1>
            <p class="page-subtitle">
                    @if (ViewBag.TotalCount > 0)
                    {
                        <span>@ViewBag.TotalCount total user(s)</span>
                    }
                    else
                    {
                        <span>Manage local and Active Directory users</span>
                    }
                </p>
            </div>
            @if (User.IsInRole("SuperAdmin"))
            {
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-person-plus"></i> Create Local User
                </a>
            }
        </div>
</div>
    <!-- Filters -->
    <div class="card mb-3 fade-in-up">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Search</label>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Username, name, or email..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Role</label>
                    <select name="role" class="form-select">
                        <option value="All">All Roles</option>
                        <option value="SuperAdmin" selected="@(ViewBag.Role == "SuperAdmin" ? "selected" : null)">SuperAdmin</option>
                        <option value="Admin" selected="@(ViewBag.Role == "Admin" ? "selected" : null)">Admin</option>
                        <option value="User" selected="@(ViewBag.Role == "User" ? "selected" : null)">User</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Account Type</label>
                    <select name="accountType" class="form-select">
                        <option value="All">All Types</option>
                        <option value="Active Directory" selected="@(ViewBag.AccountType == "Active Directory" ? "selected" : null)">Active Directory</option>
                        <option value="Local" selected="@(ViewBag.AccountType == "Local" ? "selected" : null)">Local</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-select">
                        <option value="All">All Status</option>
                        <option value="Active" selected="@(ViewBag.Status == "Active" ? "selected" : null)">Active</option>
                        <option value="Inactive" selected="@(ViewBag.Status == "Inactive" ? "selected" : null)">Inactive</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search me-1"></i> Search
                    </button>
                    <a asp-action="Index" class="btn btn-ghost">
                        <i class="bi bi-x-circle"></i> Clear
                    </a>
                </div>
            </form>
        </div>
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table-modern" id="usersTable">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Display Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Type</th>
                            <th>Status</th>
                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                            {
                                <th>Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td><strong>@user.UserName</strong></td>
                                <td>@(user.DisplayName ?? "—")</td>
                                <td class="text-muted">@(user.Email ?? "—")</td>
                                <td>
                                    @{
                                        var roleClass = user.Role.ToLower() switch
                                        {
                                            "superadmin" => "badge-superadmin",
                                            "admin" => "badge-admin",
                                            _ => "badge-user"
                                        };
                                    }
                                    <span class="badge-role @roleClass">@user.Role</span>
                                </td>
                                <td>
                                    <span class="badge-role @(user.AccountType == "Active Directory" ? "badge-ad" : "badge-local")">
                                        <i class="bi @(user.AccountType == "Active Directory" ? "bi-diagram-3" : "bi-person")"></i>
                                        @user.AccountType
                                    </span>
                                </td>
                                <td>
                                    <span class="badge-role @(user.IsActive ? "badge-active" : "badge-inactive")">
                                        @(user.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                {
                                <td>
                                    <div class="d-flex gap-1">
                                        @if (User.IsInRole("SuperAdmin"))
                                        {
                                            <a asp-action="EditRole" asp-route-id="@user.Id" class="btn btn-ghost btn-icon" title="Edit Role">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                        @if (User.IsInRole("SuperAdmin") && user.AccountType != "Active Directory")
                                        {
                                            <form asp-action="ResetPassword" asp-route-id="@user.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-ghost btn-icon" title="Reset Password"
                                                        data-confirm="Reset password for '@user.UserName'? A temporary password will be generated.">
                                                    <i class="bi bi-key text-warning"></i>
                                                </button>
                                            </form>
                                        }
                                        @if (User.IsInRole("SuperAdmin"))
                                        {
                                            <form asp-action="ToggleActive" asp-route-id="@user.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-ghost btn-icon" title="@(user.IsActive ? "Deactivate" : "Activate")"
                                                        data-confirm="Are you sure you want to @(user.IsActive ? "deactivate" : "activate") this user?">
                                                    <i class="bi @(user.IsActive ? "bi-person-slash text-danger" : "bi-person-check text-success")"></i>
                                                </button>
                                            </form>
                                            <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-ghost btn-icon" title="Delete User"
                                                        data-confirm="PERMANENTLY delete user '@user.UserName'? This cannot be undone.">
                                                    <i class="bi bi-trash3 text-danger"></i>
                                                </button>
                                            </form>
                                        }
                                        @if (User.IsInRole("Admin") && !User.IsInRole("SuperAdmin"))
                                        {
                                            // Admin can only toggle active status, not edit role or delete
                                            <form asp-action="ToggleActive" asp-route-id="@user.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-ghost btn-icon" title="@(user.IsActive ? "Deactivate" : "Activate")"
                                                        data-confirm="Are you sure you want to @(user.IsActive ? "deactivate" : "activate") this user?">
                                                    <i class="bi @(user.IsActive ? "bi-person-slash text-danger" : "bi-person-check text-success")"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalPages > 1)
            {
                <div style="padding: 16px; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border);">
                    <span class="text-muted" style="font-size: 0.8125rem;">
                        Showing page @ViewBag.CurrentPage of @ViewBag.TotalPages
                        (@ViewBag.FilteredCount user(s) found)
                    </span>
                    <div class="d-flex gap-2">
                        @if (ViewBag.CurrentPage > 1)
                        {
                            <a asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage - 1)"
                               asp-route-search="@ViewBag.Search"
                               asp-route-role="@ViewBag.Role"
                               asp-route-accountType="@ViewBag.AccountType"
                               asp-route-status="@ViewBag.Status"
                               class="btn btn-secondary btn-sm">
                                <i class="bi bi-chevron-left"></i> Previous
                            </a>
                        }
                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <a asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage + 1)"
                               asp-route-search="@ViewBag.Search"
                               asp-route-role="@ViewBag.Role"
                               asp-route-accountType="@ViewBag.AccountType"
                               asp-route-status="@ViewBag.Status"
                               class="btn btn-secondary btn-sm">
                                Next <i class="bi bi-chevron-right"></i>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
