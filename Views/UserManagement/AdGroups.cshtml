@model List<AdGroup>
@{
    ViewData["Title"] = "AD Groups & Sync";
}

<div class="page-header">
    <div class="container-fluid px-4">
        <h1><i class="bi bi-diagram-3 me-2"></i>Active Directory Groups & Sync</h1>
        <p class="subtitle mb-0">Configure AD security groups, role mappings, and trigger synchronization</p>
    </div>
</div>

<div class="container-fluid px-4">
    @if (ViewBag.AdEnabled == true)
    {
        <div class="alert d-flex align-items-center gap-2 mb-3" style="background: rgba(108, 99, 255, 0.1); border: 1px solid var(--accent); color: var(--accent); border-radius: 8px; padding: 12px 16px;">
            <i class="bi bi-check-circle-fill"></i>
            <div>
                <strong>Active Directory integration is enabled.</strong>
                <span class="ms-1">Domain: <code>@ViewBag.AdDomain</code></span>
            </div>
        </div>
    }
    else
    {
        <div class="alert d-flex align-items-center gap-2 mb-3" style="background: rgba(245, 245, 245, 0.05); border: 1px solid var(--border-light); color: var(--text-secondary); border-radius: 8px; padding: 12px 16px;">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Active Directory integration is disabled.</strong>
                <span class="ms-1">Set <code>ActiveDirectory:Enabled</code> to <code>true</code> in <code>appsettings.json</code> to enable AD sync and authentication.</span>
            </div>
        </div>
    }

    <div class="row g-4">
        <!-- Left: AD Group Configuration -->
        <div class="col-lg-7">
            <div class="card fade-in-up">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-gear me-2 text-primary"></i>Configured Security Groups</span>
                    <span class="bg-primary" style="display:inline-block; padding:2px 10px; border-radius:100px; font-size:0.75rem;">@Model.Count groups</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table-modern">
                                <thead>
                                    <tr>
                                        <th>AD Group Name</th>
                                        <th>Mapped Role</th>
                                        <th>Status</th>
                                        <th>Date Added</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var group in Model)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="bi bi-diagram-3 text-primary"></i>
                                                    <strong>@group.GroupName</strong>
                                                </div>
                                            </td>
                                            <td>
                                                <form asp-action="UpdateAdGroupRole" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@group.Id" />
                                                    <select name="mappedRole" class="form-select form-select-sm" style="width: 140px;" onchange="this.form.submit()">
                                                        <option value="Admin" selected="@(group.MappedRole == "Admin" ? "selected" : null)">Admin</option>
                                                        <option value="User" selected="@(group.MappedRole == "User" ? "selected" : null)">User</option>
                                                    </select>
                                                </form>
                                            </td>
                                            <td>
                                                <span class="badge-role @(group.IsActive ? "badge-active" : "badge-inactive")">
                                                    @(group.IsActive ? "Active" : "Inactive")
                                                </span>
                                            </td>
                                            <td class="text-muted small">@group.DateAdded.ToString("MM/dd/yyyy")</td>
                                            <td>
                                                <div class="d-flex gap-1">
                                                    <form asp-action="ToggleAdGroupActive" asp-route-id="@group.Id" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-ghost btn-icon" title="@(group.IsActive ? "Deactivate" : "Activate")">
                                                            <i class="bi @(group.IsActive ? "bi-pause-circle text-warning" : "bi-play-circle text-success")"></i>
                                                        </button>
                                                    </form>
                                                    <form asp-action="RemoveAdGroup" asp-route-id="@group.Id" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-ghost btn-icon text-danger" title="Remove"
                                                                data-confirm="Are you sure you want to remove this AD group?">
                                                            <i class="bi bi-trash3"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="bi bi-diagram-3"></i>
                            <h3>No AD groups configured</h3>
                            <p>Add your first Active Directory security group below to start syncing users.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Add New AD Group -->
            <div class="card mt-3 fade-in-up">
                <div class="card-header">
                    <i class="bi bi-plus-circle me-2 text-success"></i>Add New AD Group(s)
                </div>
                <div class="card-body">
                    <!-- Step 1: Search AD -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Step 1: Search Active Directory</label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="adGroupSearch" placeholder="Enter group name to search..." autocomplete="off" />
                            <button type="button" class="btn btn-primary" id="adSearchBtn">
                                <i class="bi bi-search me-1"></i> Search AD
                            </button>
                        </div>
                        <div class="form-text">Type a group name and click Search to find AD groups</div>
                    </div>

                    <!-- Search Results -->
                    <div id="adGroupResults" class="ad-group-results-box mb-3"></div>

                    <!-- Selected Groups -->
                    <div id="adGroupSelected" class="mb-3"></div>

                    <!-- Step 2: Map Role & Add -->
                    <form asp-action="AddAdGroups" method="post" id="addAdGroupForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="groupNames" id="adGroupNamesHidden" />
                        <div class="row g-3 align-items-end">
                            <div class="col-md-5">
                                <label class="form-label fw-semibold">Step 2: Map to Role & Add</label>
                                <select name="mappedRole" class="form-select" required>
                                    <option value="">Select role...</option>
                                    <option value="Admin">Admin</option>
                                    <option value="User">User</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <button type="submit" class="btn btn-success w-100" id="addAdGroupBtn" disabled>
                                    <i class="bi bi-plus-lg me-1"></i> Add Group(s)
                                </button>
                            </div>
                            <div class="col-md-3">
                                <span id="selectedCount" class="small text-muted"></span>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Right: Sync Controls & Info -->
        <div class="col-lg-5">
            <!-- Manual Sync -->
            <div class="card fade-in-up mb-3">
                <div class="card-header">
                    <i class="bi bi-arrow-repeat me-2 text-primary"></i>AD Synchronization
                </div>
                <div class="card-body text-center">
                    <div style="font-size: 3rem; color: var(--accent); margin-bottom: 1rem;">
                        <i class="bi bi-arrow-repeat"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Manual Sync</h5>
                    <p class="text-muted small mb-3">
                        Sync users from all active AD groups now. New users will be created automatically
                        with the mapped application role.
                    </p>
                    <form asp-action="SyncNow" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill px-4"
                                data-confirm="This will sync users from all active AD groups. Continue?">
                            <i class="bi bi-arrow-repeat"></i> Sync Now
                        </button>
                    </form>
                </div>
            </div>

            <!-- Last Sync Status -->
            <div class="card fade-in-up mb-3">
                <div class="card-header">
                    <i class="bi bi-clock-history me-2 text-accent"></i>Last Sync
                </div>
                <div class="card-body">
                    @if (ViewBag.LastSyncTimestamp != null)
                    {
                        <div class="d-flex align-items-center gap-2 mb-2">
                            @if ((bool)ViewBag.LastSyncSuccess)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success" style="background: rgba(108, 99, 255, 0.15) !important; color: var(--accent) !important;">Success</span>
                            }
                            else
                            {
                                <span class="badge" style="background: rgba(245, 245, 245, 0.1); color: var(--text-muted);">Failed</span>
                            }
                            <span class="small text-muted">@((DateTime)ViewBag.LastSyncTimestamp).ToString("MMM dd, yyyy — HH:mm:ss") UTC</span>
                        </div>
                        <div class="small text-muted mb-1">
                            <i class="bi bi-person-check me-1"></i>@ViewBag.LastSyncSummary
                        </div>
                        <div class="small text-muted">
                            <i class="bi bi-gear me-1"></i>@ViewBag.LastSyncTrigger by @ViewBag.LastSyncBy
                        </div>
                        @if (!string.IsNullOrEmpty((string)ViewBag.LastSyncErrors))
                        {
                            <div class="small mt-2" style="color: var(--accent);">
                                <i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.LastSyncErrors
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted small mb-0">No sync has been performed yet.</p>
                    }
                </div>
            </div>

            <!-- Sync Info -->
            <div class="card fade-in-up mb-3">
                <div class="card-header">
                    <i class="bi bi-info-circle me-2 text-info"></i>Sync Information
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="d-flex align-items-start gap-2 mb-3">
                            <i class="bi bi-clock text-primary mt-1"></i>
                            <div>
                                <strong class="d-block small">Automatic Daily Sync</strong>
                                <span class="text-muted small">Runs automatically every day at 2:00 AM UTC</span>
                            </div>
                        </li>
                        <li class="d-flex align-items-start gap-2 mb-3">
                            <i class="bi bi-person-plus text-success mt-1"></i>
                            <div>
                                <strong class="d-block small">New Users</strong>
                                <span class="text-muted small">Automatically created with the mapped role</span>
                            </div>
                        </li>
                        <li class="d-flex align-items-start gap-2 mb-3">
                            <i class="bi bi-arrow-left-right text-warning mt-1"></i>
                            <div>
                                <strong class="d-block small">Role Updates</strong>
                                <span class="text-muted small">Roles updated if AD group mapping changes</span>
                            </div>
                        </li>
                        <li class="d-flex align-items-start gap-2">
                            <i class="bi bi-person-slash text-danger mt-1"></i>
                            <div>
                                <strong class="d-block small">Deactivation</strong>
                                <span class="text-muted small">Users removed from all groups are deactivated (not deleted)</span>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Role Mapping Guide -->
            <div class="card fade-in-up">
                <div class="card-header">
                    <i class="bi bi-map me-2 text-accent"></i>Role Mapping Guide
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                        <span class="small fw-semibold">LostandFound Admin</span>
                        <i class="bi bi-arrow-right text-muted"></i>
                        <span class="badge-role badge-admin">Admin</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="small fw-semibold">LostandFound User</span>
                        <i class="bi bi-arrow-right text-muted"></i>
                        <span class="badge-role badge-user">User</span>
                    </div>
                    <hr />
                    <p class="text-muted small mb-0">
                        <i class="bi bi-shield-fill-exclamation text-warning me-1"></i>
                        <strong>Super Admin</strong> is a local-only role and is NOT mapped from AD groups.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    var searchInput = document.getElementById('adGroupSearch');
    var searchBtn = document.getElementById('adSearchBtn');
    var hiddenInput = document.getElementById('adGroupNamesHidden');
    var resultsDiv = document.getElementById('adGroupResults');
    var selectedListDiv = document.getElementById('adGroupSelected');
    var addBtn = document.getElementById('addAdGroupBtn');
    var form = document.getElementById('addAdGroupForm');
    var selectedCountEl = document.getElementById('selectedCount');
    if (!searchInput || !searchBtn || !hiddenInput || !resultsDiv || !form || !addBtn) return;

    var selectedGroups = [];

    function updateState() {
        hiddenInput.value = selectedGroups.join(',');
        addBtn.disabled = selectedGroups.length === 0;
        if (selectedCountEl) {
            selectedCountEl.textContent = selectedGroups.length > 0
                ? selectedGroups.length + ' group(s) selected'
                : '';
        }
    }

    function renderSelectedChips() {
        if (!selectedListDiv) return;
        if (selectedGroups.length === 0) { selectedListDiv.innerHTML = ''; return; }
        var html = '<label class="form-label fw-semibold small">Selected Groups:</label><div class="selected-groups">';
        selectedGroups.forEach(function(name, idx) {
            html += '<span class="selected-group-item">';
            html += '<i class="bi bi-diagram-3 me-1"></i>' + escapeHtml(name);
            html += '<button type="button" class="btn-remove-group" data-idx="' + idx + '"><i class="bi bi-x"></i></button>';
            html += '</span>';
        });
        html += '</div>';
        selectedListDiv.innerHTML = html;

        selectedListDiv.querySelectorAll('.btn-remove-group').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                selectedGroups.splice(parseInt(this.getAttribute('data-idx')), 1);
                updateState();
                renderSelectedChips();
                refreshResultSelectionUI();
            });
        });
    }

    function refreshResultSelectionUI() {
        resultsDiv.querySelectorAll('.ad-group-item').forEach(function(el) {
            var n = el.getAttribute('data-name');
            var isSel = selectedGroups.includes(n);
            el.classList.toggle('ad-group-item-selected', isSel);
            var checkIcon = el.querySelector('.ad-sel-icon');
            if (checkIcon) {
                checkIcon.className = isSel
                    ? 'bi bi-check-circle-fill text-success ad-sel-icon'
                    : 'bi bi-circle text-muted ad-sel-icon';
            }
        });
    }

    function doSearch() {
        var term = searchInput.value.trim();
        if (term.length < 2) {
            showResults('<div class="ad-group-msg"><i class="bi bi-info-circle me-1"></i>Enter at least 2 characters to search.</div>');
            return;
        }
        showResults('<div class="ad-group-msg"><i class="bi bi-arrow-repeat ad-spin me-1"></i> Searching Active Directory...</div>');

        fetch('/UserManagement/SearchAdGroups?term=' + encodeURIComponent(term))
            .then(function(res) { return res.json(); })
            .then(function(data) {
                if (data.error && data.error.length > 0) {
                    showResults('<div class="ad-group-msg ad-group-err"><i class="bi bi-exclamation-triangle me-1"></i>' + escapeHtml(data.error) + '</div>');
                    return;
                }
                if (!data.results || data.results.length === 0) {
                    showResults('<div class="ad-group-msg"><i class="bi bi-search me-1"></i>No groups found matching "' + escapeHtml(term) + '"</div>');
                    return;
                }
                renderResults(data.results);
            })
            .catch(function() {
                showResults('<div class="ad-group-msg ad-group-err"><i class="bi bi-exclamation-triangle me-1"></i>Failed to search Active Directory.</div>');
            });
    }

    function renderResults(results) {
        var html = '<div class="ad-results-header"><i class="bi bi-list-check me-1"></i>' + results.length + ' group(s) found — click to select</div>';
        for (var i = 0; i < results.length; i++) {
            var r = results[i];
            var isSel = selectedGroups.includes(r.name);
            html += '<div class="ad-group-item' + (isSel ? ' ad-group-item-selected' : '') + '" data-name="' + escapeAttr(r.name) + '">';
            html += '<div class="d-flex align-items-center gap-2 flex-grow-1">';
            html += '<i class="bi bi-diagram-3 text-primary"></i>';
            html += '<div>';
            html += '<div class="ad-group-item-name">' + escapeHtml(r.name) + '</div>';
            if (r.distinguishedName) {
                html += '<div class="ad-group-item-dn">' + escapeHtml(r.distinguishedName) + '</div>';
            }
            html += '</div></div>';
            html += '<i class="' + (isSel ? 'bi bi-check-circle-fill text-success' : 'bi bi-circle text-muted') + ' ad-sel-icon"></i>';
            html += '</div>';
        }
        showResults(html);
    }

    // Search button click
    searchBtn.addEventListener('click', function() { doSearch(); });

    // Enter key triggers search
    searchInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') { e.preventDefault(); doSearch(); }
    });

    // Click result to toggle selection
    resultsDiv.addEventListener('click', function(e) {
        var item = e.target.closest('.ad-group-item');
        if (!item) return;
        var name = item.getAttribute('data-name');
        var idx = selectedGroups.indexOf(name);
        if (idx >= 0) { selectedGroups.splice(idx, 1); } else { selectedGroups.push(name); }
        updateState();
        renderSelectedChips();
        refreshResultSelectionUI();
    });

    // Form submit guard
    form.addEventListener('submit', function(e) {
        if (selectedGroups.length === 0) {
            e.preventDefault();
            searchInput.focus();
            showResults('<div class="ad-group-msg ad-group-err"><i class="bi bi-exclamation-triangle me-1"></i>Search and select at least one group first.</div>');
        }
    });

    function showResults(html) {
        resultsDiv.innerHTML = html;
        resultsDiv.style.display = 'block';
    }
    function escapeHtml(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
    function escapeAttr(s) { return s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/'/g,'&#39;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
})();
</script>
}

<style>
.selected-groups { display: flex; flex-wrap: wrap; gap: 6px; }
.selected-group-item {
    display: inline-flex; align-items: center; gap: 4px;
    background: var(--accent); color: var(--white);
    padding: 4px 10px; border-radius: 20px; font-size: 0.85rem;
}
.selected-group-item .btn-remove-group {
    background: none; border: none; color: var(--white);
    padding: 0; margin-left: 4px; cursor: pointer; opacity: 0.8;
}
.selected-group-item .btn-remove-group:hover { opacity: 1; }
.ad-group-results-box {
    display: none; background: var(--card-bg);
    border: 1px solid var(--border-light); border-radius: 8px;
    max-height: 340px; overflow-y: auto;
}
.ad-group-item {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 14px; cursor: pointer;
    border-bottom: 1px solid var(--border-light);
    transition: background 0.15s;
}
.ad-group-item:hover { background: rgba(108, 99, 255, 0.06); }
.ad-group-item:last-child { border-bottom: none; }
.ad-group-item-selected { background: rgba(108, 99, 255, 0.1); }
.ad-group-item-name { font-weight: 600; font-size: 0.9rem; }
.ad-group-item-dn { font-size: 0.75rem; color: var(--text-muted); opacity: 0.7; }
.ad-results-header {
    padding: 8px 14px; font-size: 0.8rem; color: var(--text-muted);
    border-bottom: 1px solid var(--border-light); background: rgba(108, 99, 255, 0.03);
}
.ad-group-msg { padding: 16px; text-align: center; color: var(--text-muted); font-size: 0.875rem; }
.ad-group-err { color: var(--accent); }
.ad-spin { animation: ad-spin-anim 1s linear infinite; display: inline-block; }
@@keyframes ad-spin-anim { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>