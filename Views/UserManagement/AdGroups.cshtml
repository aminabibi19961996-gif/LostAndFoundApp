@model List<AdGroup>
@{
    ViewData["Title"] = "AD Groups & Sync";
}

@section Styles {
<style>
    .ad-header { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; }
    .ad-header h1 { font-family: var(--font-display); font-size: 1.625rem; font-weight: 800; color: var(--text-primary); display: flex; align-items: center; gap: 8px; letter-spacing: -.02em; }
    .ad-header h1 i { font-size: 20px; color: var(--accent); }
    .ad-header .subtitle { font-size: 14px; color: var(--text-muted); font-weight: 500; }
    .dc { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; margin-bottom: 16px; }
    .dc-head { padding: 14px 20px; border-bottom: 1px solid var(--border); font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--text-primary); background: var(--bg-elevated); display: flex; align-items: center; gap: 8px; justify-content: space-between; }
    .dc-head i { color: var(--accent); font-size: 16px; }
    .dc-body { padding: 20px; }
    .stable { width: 100%; border-collapse: collapse; }
    .stable thead th { padding: 11px 16px; text-align: left; font-size: 12px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .07em; border-bottom: 1px solid var(--border); background: var(--bg-elevated); }
    .stable tbody td { padding: 12px 16px; font-size: 14.5px; font-weight: 500; border-bottom: 1px solid var(--border); color: var(--text-secondary); vertical-align: middle; }
    .stable tbody tr:last-child td { border-bottom: none; }
    .stable tbody tr:hover td { background: var(--bg-elevated); color: var(--text-primary); }
    .stable tbody tr:hover td:first-child { box-shadow: inset 3px 0 0 var(--accent); }
    .ra { display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 6px; background: transparent; border: none; color: var(--text-dim); cursor: pointer; font-size: 14px; text-decoration: none; transition: background .12s, color .12s; }
    .ra:hover { background: var(--bg-hover); color: var(--accent); }
    .info-row { display: flex; align-items: flex-start; gap: 10px; padding: 12px 0; border-bottom: 1px solid var(--border); }
    .info-row:last-child { border-bottom: none; }
    .info-row i { margin-top: 2px; color: var(--accent); }
    .info-row strong { font-size: 14px; color: var(--text-primary); }
    .info-row span { font-size: 13.5px; color: var(--text-muted); }
    .ad-grid { display: grid; grid-template-columns: 1fr 340px; gap: 16px; }
    @@media (max-width: 992px) { .ad-grid { grid-template-columns: 1fr; } }
    .selected-groups { display: flex; flex-wrap: wrap; gap: 6px; }
    .selected-group-item { display: inline-flex; align-items: center; gap: 4px; background: var(--accent); color: #fff; padding: 4px 10px; border-radius: 20px; font-size: 14px; }
    .selected-group-item .btn-remove-group { background: none; border: none; color: #fff; padding: 0; margin-left: 4px; cursor: pointer; opacity: 0.8; }
    .selected-group-item .btn-remove-group:hover { opacity: 1; }
    .ad-group-results-box { display: none; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; max-height: 340px; overflow-y: auto; }
    .ad-group-item { display: flex; align-items: center; justify-content: space-between; padding: 10px 14px; cursor: pointer; border-bottom: 1px solid var(--border); transition: background 0.15s; }
    .ad-group-item:hover { background: var(--bg-hover); }
    .ad-group-item:last-child { border-bottom: none; }
    .ad-group-item-selected { background: var(--accent-subtle); }
    .ad-group-item-name { font-weight: 600; font-size: 14.5px; color: var(--text-primary); }
    .ad-group-item-dn { font-size: 12.5px; color: var(--text-muted); opacity: 0.7; }
    .ad-results-header { padding: 8px 14px; font-size: 13px; color: var(--text-muted); border-bottom: 1px solid var(--border); background: var(--bg-elevated); }
    .ad-group-msg { padding: 16px; text-align: center; color: var(--text-muted); font-size: 14px; }
    .ad-group-err { color: var(--red); }
    .ad-spin { animation: ad-spin-anim 1s linear infinite; display: inline-block; }
    @@keyframes ad-spin-anim { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>
}

<div class="ad-header">
    <div>
        <h1><i class="bi bi-diagram-3"></i> Active Directory Groups &amp; Sync</h1>
        <div class="subtitle">Configure AD security groups, role mappings, and trigger synchronization</div>
    </div>
</div>

@if (ViewBag.AdEnabled == true)
{
    <div style="background:var(--accent-subtle);border:1px solid var(--accent);color:var(--accent);border-radius:12px;padding:12px 16px;margin-bottom:14px;font-size:14.5px;display:flex;align-items:center;gap:8px;">
        <i class="bi bi-check-circle-fill"></i>
        <span><strong>Active Directory enabled.</strong> Domain: <code style="color:var(--text-primary)">@ViewBag.AdDomain</code></span>
    </div>
}
else
{
    <div style="background:var(--bg-card);border:1px solid var(--border);color:var(--text-secondary);border-radius:12px;padding:12px 16px;margin-bottom:14px;font-size:14.5px;display:flex;align-items:center;gap:8px;">
        <i class="bi bi-exclamation-triangle-fill" style="color:var(--amber)"></i>
        <span><strong>AD integration is disabled.</strong> Set <code>ActiveDirectory:Enabled</code> to <code>true</code> in <code>appsettings.json</code>.</span>
    </div>
}

<div class="ad-grid">
    <div>
        <!-- Configured Groups -->
        <div class="dc">
            <div class="dc-head"><span style="display:flex;align-items:center;gap:8px;"><i class="bi bi-gear"></i> Configured Security Groups</span><span style="padding:2px 10px;border-radius:20px;font-size:12px;font-weight:700;background:var(--accent-subtle);color:var(--accent);">@Model.Count groups</span></div>
            @if (Model.Any())
            {
                <div class="md-scroll" style="max-height:400px;">
                    <table class="stable">
                        <thead><tr><th>AD Group Name</th><th>Mapped Role</th><th>Status</th><th>Date Added</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var group in Model)
                            {
                                <tr>
                                    <td style="color:var(--text-primary);font-weight:600;"><i class="bi bi-diagram-3" style="color:var(--accent);margin-right:6px;"></i>@group.GroupName</td>
                                    <td><form asp-action="UpdateAdGroupRole" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@group.Id" /><select name="mappedRole" class="form-select" style="width:120px;font-size:13px;padding:5px 8px;" onchange="this.form.submit()"><option value="Admin" selected="@(group.MappedRole == "Admin" ? "selected" : null)">Admin</option><option value="Supervisor" selected="@(group.MappedRole == "Supervisor" ? "selected" : null)">Supervisor</option><option value="User" selected="@(group.MappedRole == "User" ? "selected" : null)">User</option></select></form></td>
                                    <td><span class="badge-role @(group.IsActive ? "badge-active" : "badge-inactive")">@(group.IsActive ? "Active" : "Inactive")</span></td>
                                    <td style="font-size:12.5px;color:var(--text-muted);">@group.DateAdded.ToString("MM/dd/yyyy")</td>
                                    <td>
                                        <div style="display:flex;gap:3px;">
                                            <form asp-action="ToggleAdGroupActive" asp-route-id="@group.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="ra" title="@(group.IsActive ? "Deactivate" : "Activate")"><i class="bi @(group.IsActive ? "bi-pause-circle" : "bi-play-circle")" style="color:@(group.IsActive ? "var(--amber)" : "var(--green)")"></i></button></form>
                                            <form asp-action="RemoveAdGroup" asp-route-id="@group.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="ra" title="Remove" data-confirm="Remove this AD group?"><i class="bi bi-trash3" style="color:var(--red)"></i></button></form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div style="padding:40px 24px;text-align:center;color:var(--text-muted);"><i class="bi bi-diagram-3" style="font-size:2rem;display:block;margin-bottom:12px;color:var(--text-dim);"></i><div style="font-weight:600;color:var(--text-secondary);margin-bottom:4px;">No AD groups configured</div><div style="font-size:13px;">Add your first group below.</div></div>
            }
        </div>

        <!-- Add New -->
        <div class="dc">
            <div class="dc-head"><span style="display:flex;align-items:center;gap:8px;"><i class="bi bi-plus-circle" style="color:var(--green)"></i> Add New AD Group(s)</span></div>
            <div class="dc-body">
                <div style="margin-bottom:14px;">
                    <label class="form-label" style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);">Step 1: Search Active Directory</label>
                    <div style="display:flex;gap:6px;">
                        <input type="text" class="form-control" id="adGroupSearch" placeholder="Enter group name to search..." autocomplete="off" />
                        <button type="button" class="btn btn-primary" id="adSearchBtn"><i class="bi bi-search"></i> Search</button>
                    </div>
                    <div style="font-size:12.5px;color:var(--text-dim);margin-top:4px;">Type a group name and click Search</div>
                </div>
                <div id="adGroupResults" class="ad-group-results-box" style="margin-bottom:14px;"></div>
                <div id="adGroupSelected" style="margin-bottom:14px;"></div>
                <form asp-action="AddAdGroups" method="post" id="addAdGroupForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="groupNames" id="adGroupNamesHidden" />
                    <div style="display:grid;grid-template-columns:1fr auto auto;gap:8px;align-items:end;">
                        <div>
                            <label class="form-label" style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);">Step 2: Map to Role</label>
                            <select name="mappedRole" class="form-select" required><option value="">Select role...</option><option value="Admin">Admin</option><option value="Supervisor">Supervisor</option><option value="User">User</option></select>
                        </div>
                        <button type="submit" class="btn btn-primary" id="addAdGroupBtn" disabled><i class="bi bi-plus-lg"></i> Add</button>
                        <span id="selectedCount" style="font-size:12px;color:var(--text-muted);"></span>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Right sidebar -->
    <div>
        <div class="dc">
            <div class="dc-head"><span style="display:flex;align-items:center;gap:8px;"><i class="bi bi-arrow-repeat"></i> AD Synchronization</span></div>
            <div class="dc-body" style="text-align:center;">
                <i class="bi bi-arrow-repeat" style="font-size:2.5rem;color:var(--accent);display:block;margin-bottom:12px;"></i>
                <div style="font-weight:700;font-size:14px;color:var(--text-primary);margin-bottom:6px;">Manual Sync</div>
                <p style="font-size:14px;color:var(--text-muted);margin-bottom:14px;">Sync users from all active AD groups now.</p>
                <form asp-action="SyncNow" method="post">@Html.AntiForgeryToken()<button type="submit" class="btn btn-primary" data-confirm="Sync users from all active AD groups?"><i class="bi bi-arrow-repeat"></i> Sync Now</button></form>
            </div>
        </div>

        <div class="dc">
            <div class="dc-head"><span style="display:flex;align-items:center;gap:8px;"><i class="bi bi-clock-history"></i> Last Sync</span></div>
            <div class="dc-body">
                @if (ViewBag.LastSyncTimestamp != null)
                {
                    var syncTime = (DateTime)ViewBag.LastSyncTimestamp;
                    var syncSuccess = (bool)ViewBag.LastSyncSuccess;
                    <div style="display:flex;align-items:center;gap:8px;">
                        @if (syncSuccess)
                        {
                            <span style="padding:2px 8px;border-radius:20px;font-size:12px;font-weight:700;background:var(--green-light);color:var(--green);">Success</span>
                        }
                        else
                        {
                            <span style="padding:2px 8px;border-radius:20px;font-size:12px;font-weight:700;background:var(--red-light);color:var(--red);">Failed</span>
                        }
                        <span style="font-size:12.5px;color:var(--text-muted);">@syncTime.ToString("MMM dd, yyyy — HH:mm:ss")</span>
                    </div>
                }
                else
                {
                    <p style="font-size:13px;color:var(--text-muted);margin:0;">No sync performed yet.</p>
                }
            </div>
        </div>

        <div class="dc">
            <div class="dc-head"><span style="display:flex;align-items:center;gap:8px;"><i class="bi bi-info-circle"></i> Sync Information</span></div>
            <div class="dc-body">
                <div class="info-row"><i class="bi bi-clock"></i><div><strong>Automatic Daily Sync</strong><br><span>Runs at 2:00 AM</span></div></div>
                <div class="info-row"><i class="bi bi-person-plus" style="color:var(--green)"></i><div><strong>New Users</strong><br><span>Auto-created with mapped role</span></div></div>
                <div class="info-row"><i class="bi bi-arrow-left-right" style="color:var(--amber)"></i><div><strong>Role Updates</strong><br><span>Updated on mapping changes</span></div></div>
                <div class="info-row"><i class="bi bi-person-slash" style="color:var(--red)"></i><div><strong>Deactivation</strong><br><span>Removed users are deactivated</span></div></div>
            </div>
        </div>

        <div class="dc">
            <div class="dc-head"><span style="display:flex;align-items:center;gap:8px;"><i class="bi bi-map"></i> Role Mapping</span></div>
            <div class="dc-body">
                <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:8px;margin-bottom:8px;border-bottom:1px solid var(--border);"><span style="font-size:14px;font-weight:600;color:var(--text-primary);">LostAndFound Admin</span><span class="badge-role badge-admin">Admin</span></div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;"><span style="font-size:14px;font-weight:600;color:var(--text-primary);">LostAndFound User</span><span class="badge-role badge-user">User</span></div>
                <div style="font-size:12px;color:var(--text-dim);border-top:1px solid var(--border);padding-top:10px;"><i class="bi bi-shield-exclamation" style="color:var(--amber);margin-right:4px;"></i><strong>Super Admin</strong> is local-only, not mapped from AD.</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    var searchInput = document.getElementById('adGroupSearch');
    var searchBtn = document.getElementById('adSearchBtn');
    var hiddenInput = document.getElementById('adGroupNamesHidden');
    var resultsDiv = document.getElementById('adGroupResults');
    var selectedListDiv = document.getElementById('adGroupSelected');
    var addBtn = document.getElementById('addAdGroupBtn');
    var form = document.getElementById('addAdGroupForm');
    var selectedCountEl = document.getElementById('selectedCount');
    if (!searchInput || !searchBtn || !hiddenInput || !resultsDiv || !form || !addBtn) return;
    var selectedGroups = [];
    function updateState() { hiddenInput.value = selectedGroups.join(','); addBtn.disabled = selectedGroups.length === 0; if (selectedCountEl) { selectedCountEl.textContent = selectedGroups.length > 0 ? selectedGroups.length + ' selected' : ''; } }
    function renderSelectedChips() { if (!selectedListDiv) return; if (selectedGroups.length === 0) { selectedListDiv.innerHTML = ''; return; } var html = '<label class="form-label" style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);">Selected:</label><div class="selected-groups">'; selectedGroups.forEach(function(name, idx) { html += '<span class="selected-group-item"><i class="bi bi-diagram-3 me-1"></i>' + escapeHtml(name) + '<button type="button" class="btn-remove-group" data-idx="' + idx + '"><i class="bi bi-x"></i></button></span>'; }); html += '</div>'; selectedListDiv.innerHTML = html; selectedListDiv.querySelectorAll('.btn-remove-group').forEach(function(btn) { btn.addEventListener('click', function(e) { e.stopPropagation(); selectedGroups.splice(parseInt(this.getAttribute('data-idx')), 1); updateState(); renderSelectedChips(); refreshResultSelectionUI(); }); }); }
    function refreshResultSelectionUI() { resultsDiv.querySelectorAll('.ad-group-item').forEach(function(el) { var n = el.getAttribute('data-name'); var isSel = selectedGroups.includes(n); el.classList.toggle('ad-group-item-selected', isSel); var checkIcon = el.querySelector('.ad-sel-icon'); if (checkIcon) { checkIcon.className = isSel ? 'bi bi-check-circle-fill text-success ad-sel-icon' : 'bi bi-circle text-muted ad-sel-icon'; } }); }
    function doSearch() { var term = searchInput.value.trim(); if (term.length < 2) { showResults('<div class="ad-group-msg"><i class="bi bi-info-circle me-1"></i>Enter at least 2 characters.</div>'); return; } showResults('<div class="ad-group-msg"><i class="bi bi-arrow-repeat ad-spin me-1"></i> Searching...</div>'); fetch('/UserManagement/SearchAdGroups?term=' + encodeURIComponent(term)).then(function(res) { return res.json(); }).then(function(data) { if (data.error && data.error.length > 0) { showResults('<div class="ad-group-msg ad-group-err"><i class="bi bi-exclamation-triangle me-1"></i>' + escapeHtml(data.error) + '</div>'); return; } if (!data.results || data.results.length === 0) { showResults('<div class="ad-group-msg"><i class="bi bi-search me-1"></i>No groups found for "' + escapeHtml(term) + '"</div>'); return; } renderResults(data.results); }).catch(function() { showResults('<div class="ad-group-msg ad-group-err"><i class="bi bi-exclamation-triangle me-1"></i>Search failed.</div>'); }); }
    function renderResults(results) { var html = '<div class="ad-results-header"><i class="bi bi-list-check me-1"></i>' + results.length + ' group(s) — click to select</div>'; for (var i = 0; i < results.length; i++) { var r = results[i]; var isSel = selectedGroups.includes(r.name); html += '<div class="ad-group-item' + (isSel ? ' ad-group-item-selected' : '') + '" data-name="' + escapeAttr(r.name) + '"><div class="d-flex align-items-center gap-2 flex-grow-1"><i class="bi bi-diagram-3" style="color:var(--accent)"></i><div><div class="ad-group-item-name">' + escapeHtml(r.name) + '</div>' + (r.distinguishedName ? '<div class="ad-group-item-dn">' + escapeHtml(r.distinguishedName) + '</div>' : '') + '</div></div><i class="' + (isSel ? 'bi bi-check-circle-fill text-success' : 'bi bi-circle text-muted') + ' ad-sel-icon"></i></div>'; } showResults(html); }
    searchBtn.addEventListener('click', function() { doSearch(); });
    searchInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); doSearch(); } });
    resultsDiv.addEventListener('click', function(e) { var item = e.target.closest('.ad-group-item'); if (!item) return; var name = item.getAttribute('data-name'); var idx = selectedGroups.indexOf(name); if (idx >= 0) { selectedGroups.splice(idx, 1); } else { selectedGroups.push(name); } updateState(); renderSelectedChips(); refreshResultSelectionUI(); });
    form.addEventListener('submit', function(e) { if (selectedGroups.length === 0) { e.preventDefault(); searchInput.focus(); showResults('<div class="ad-group-msg ad-group-err"><i class="bi bi-exclamation-triangle me-1"></i>Select at least one group first.</div>'); } });
    function showResults(html) { resultsDiv.innerHTML = html; resultsDiv.style.display = 'block'; }
    function escapeHtml(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
    function escapeAttr(s) { return s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/'/g,'&#39;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
})();
</script>
}