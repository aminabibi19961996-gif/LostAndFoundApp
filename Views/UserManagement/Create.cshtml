@model CreateUserViewModel
@{
    ViewData["Title"] = "Create User";
}

<div style="max-width:520px;margin:0 auto;">
    <div style="margin-bottom:20px;"><h1 style="font-family:var(--font-display);font-size:1.625rem;font-weight:800;color:var(--text-primary);display:flex;align-items:center;gap:8px;"><i class="bi bi-person-plus" style="color:var(--accent)"></i> Create Local User</h1></div>
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;">
        <div style="padding:14px 20px;border-bottom:1px solid var(--border);background:var(--bg-elevated);font-size:14.5px;font-weight:600;color:var(--text-primary);display:flex;align-items:center;gap:8px;"><i class="bi bi-person" style="color:var(--accent)"></i> User Details</div>
        <div style="padding:22px 20px;">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div style="display:flex;flex-direction:column;gap:14px;">
                    <div class="fg-item"><label asp-for="UserName" class="form-label" style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);">Username</label><input asp-for="UserName" class="form-control" /><span asp-validation-for="UserName" class="text-danger small"></span></div>
                    <div class="fg-item"><label asp-for="Email" class="form-label" style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);">Email</label><input asp-for="Email" class="form-control" type="email" /><span asp-validation-for="Email" class="text-danger small"></span></div>
                    <div class="fg-item"><label asp-for="DisplayName" class="form-label" style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);">Display Name</label><input asp-for="DisplayName" class="form-control" /></div>
                    <div class="fg-item"><label asp-for="Password" class="form-label" style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);">Password</label><input asp-for="Password" class="form-control" /><span asp-validation-for="Password" class="text-danger small"></span><div style="font-size:12.5px;color:var(--text-dim);margin-top:4px;">Must meet configured policy requirements.</div></div>
                    <div class="fg-item"><label asp-for="Role" class="form-label" style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);">Role</label><select asp-for="Role" class="form-select"><option value="User">User</option><option value="Supervisor">Supervisor</option><option value="Admin">Admin</option>@if (User.IsInRole("SuperAdmin")) { <option value="SuperAdmin">Super Admin</option> }</select></div>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;padding:14px 20px;border-top:1px solid var(--border);background:var(--bg-elevated);margin:20px -18px -20px;border-radius:0 0 12px 12px;">
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-person-plus"></i> Create User</button>
                </div>
            </form>
        </div>
    </div>
</div>
