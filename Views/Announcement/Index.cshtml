@model AnnouncementListViewModel
@{
    ViewData["Title"] = "Announcements";
}

@section Styles {
<style>
    .an-header { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; }
    .an-header h1 { font-family: var(--font-display); font-size: 1.625rem; font-weight: 800; color: var(--text-primary); display: flex; align-items: center; gap: 8px; letter-spacing: -.02em; }
    .an-header h1 i { font-size: 20px; color: var(--accent); }
    .an-header .count { font-size: 14px; color: var(--text-muted); font-weight: 500; }
    .rc { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    .stable { width: 100%; border-collapse: collapse; }
    .stable thead th { padding: 11px 16px; text-align: left; font-size: 12px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .07em; border-bottom: 1px solid var(--border); background: var(--bg-elevated); white-space: nowrap; }
    .stable tbody td { padding: 12px 16px; font-size: 14.5px; font-weight: 500; border-bottom: 1px solid var(--border); color: var(--text-secondary); vertical-align: middle; }
    .stable tbody tr:last-child td { border-bottom: none; }
    .stable tbody tr:hover td { background: var(--bg-elevated); color: var(--text-primary); }
    .stable tbody tr:hover td:first-child { box-shadow: inset 3px 0 0 var(--accent); }
    .ra { display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 6px; background: transparent; border: none; color: var(--text-dim); cursor: pointer; font-size: 14px; transition: background .12s, color .12s; }
    .ra:hover { background: var(--bg-hover); color: var(--accent); }
    .rc-footer { display: flex; align-items: center; justify-content: space-between; padding: 12px 20px; border-top: 1px solid var(--border); background: var(--bg-elevated); }
</style>
}

<div class="an-header">
    <div>
        <h1><i class="bi bi-megaphone"></i> Announcements</h1>
        <div class="count">@Model.TotalCount announcement(s) — Messages to Admin and User roles</div>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Announcement</a>
</div>

<div class="rc">
    @if (Model.Announcements.Any())
    {
        <div style="overflow-x:auto;">
            <table class="stable">
                <thead><tr><th>Title</th><th>Target</th><th>Created</th><th>Expires</th><th>Read</th><th>Status</th><th></th></tr></thead>
                <tbody>
                    @foreach (var item in Model.Announcements)
                    {
                        var targetClass = item.TargetRole switch { "Admin" => "badge-admin", "User" => "badge-user", _ => "badge-active" };
                        var targetLabel = item.TargetRole == "All" ? "All Users" : item.TargetRole;
                        <tr style="@(item.IsActive ? "" : "opacity:0.5;")">
                            <td><strong style="color:var(--text-primary);">@item.Title</strong><div style="font-size:12px;color:var(--text-muted);max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@item.Message</div></td>
                            <td><span class="badge-role @targetClass">@targetLabel</span></td>
                            <td style="font-size:12.5px;white-space:nowrap;">@item.CreatedAt.ToString("MM/dd/yyyy HH:mm")<div style="color:var(--text-muted);">by @item.CreatedBy</div></td>
                            <td style="font-size:12.5px;">@if (item.ExpiresAt.HasValue) { if (item.IsExpired) { <span style="color:var(--red)">@item.ExpiresAt.Value.ToString("MM/dd/yyyy")</span> } else { @item.ExpiresAt.Value.ToString("MM/dd/yyyy") } } else { <span style="color:var(--text-muted)">Never</span> }</td>
                            <td><span style="padding:2px 8px;border-radius:20px;font-size:12px;font-weight:700;background:var(--blue-light);color:var(--blue);">@item.ReadCount</span></td>
                            <td>@if (item.IsExpired) { <span class="badge-role badge-inactive">Expired</span> } else { <span class="badge-role @(item.IsActive ? "badge-active" : "badge-inactive")">@(item.IsActive ? "Active" : "Inactive")</span> }</td>
                            <td>
                                <div style="display:flex;gap:3px;">
                                    <form asp-action="ToggleActive" asp-route-id="@item.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="ra" title="@(item.IsActive ? "Deactivate" : "Activate")"><i class="bi @(item.IsActive ? "bi-eye-slash" : "bi-eye")"></i></button></form>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="ra" title="Delete" data-confirm="Delete this announcement?"><i class="bi bi-trash3" style="color:var(--red)"></i></button></form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="rc-footer">
                <span style="font-size:12.5px;color:var(--text-dim);">Page @Model.CurrentPage of @Model.TotalPages · @Model.TotalCount entries</span>
                <div style="display:flex;gap:6px;">
                    @if (Model.CurrentPage > 1) { <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" class="btn btn-secondary btn-sm"><i class="bi bi-chevron-left"></i></a> }
                    @for (var i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++) { <a asp-action="Index" asp-route-page="@i" class="btn btn-sm @(i == Model.CurrentPage ? "btn-primary" : "btn-secondary")">@i</a> }
                    @if (Model.CurrentPage < Model.TotalPages) { <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" class="btn btn-secondary btn-sm"><i class="bi bi-chevron-right"></i></a> }
                </div>
            </div>
        }
    }
    else
    {
        <div style="padding:48px 24px;text-align:center;"><i class="bi bi-megaphone" style="font-size:2.5rem;color:var(--text-dim);display:block;margin-bottom:12px;"></i><div style="font-weight:700;color:var(--text-secondary);margin-bottom:4px;">No announcements yet</div><div style="font-size:14px;color:var(--text-muted);margin-bottom:20px;">Create your first to notify users.</div><a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Announcement</a></div>
    }
</div>
