@model UserMessageViewModel
@{
    ViewData["Title"] = "Messages";
}

@section Styles {
<style>
    .msg-header h1 { font-family: var(--font-display); font-size: 1.625rem; font-weight: 800; color: var(--text-primary); display: flex; align-items: center; gap: 8px; letter-spacing: -.02em; }
    .msg-header h1 i { font-size: 20px; color: var(--accent); }
    .msg-header .count { font-size: 14px; color: var(--text-muted); font-weight: 500; }
    .msg-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; margin-bottom: 12px; }
    .msg-card.dismissed { opacity: 0.5; }
    .msg-top { display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; border-bottom: 1px solid var(--border); background: var(--bg-elevated); }
    .msg-title { display: flex; align-items: center; gap: 8px; font-family: var(--font-display); font-weight: 700; font-size: 15px; color: var(--text-primary); }
    .msg-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
    .msg-meta { display: flex; align-items: center; gap: 8px; font-size: 13.5px; color: var(--text-muted); }
    .msg-body { padding: 18px 20px; font-size: 15px; color: var(--text-secondary); line-height: 1.6; }
    .msg-dismissed-badge { padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 700; background: var(--bg-hover); color: var(--text-muted); display: inline-flex; align-items: center; gap: 4px; }
</style>
}

<div class="msg-header" style="margin-bottom:20px;">
    <h1><i class="bi bi-envelope"></i> Messages</h1>
    <div class="count">@if (Model.UnreadCount > 0) { <span>@Model.UnreadCount unread announcement@(Model.UnreadCount != 1 ? "s" : "")</span> } else { <span>All caught up — no unread announcements</span> }</div>
</div>

@if (Model.Messages.Any())
{
    @foreach (var msg in Model.Messages)
    {
        <div class="msg-card @(msg.IsDismissed ? "dismissed" : "")">
            <div class="msg-top">
                <div class="msg-title">
                    @if (!msg.IsDismissed) { <span class="msg-dot"></span> }
                    <i class="bi bi-megaphone" style="color:var(--accent);font-size:13px;"></i>
                    @msg.Title
                </div>
                <div class="msg-meta">
                    <span>@msg.CreatedAt.ToString("MMM dd, yyyy") · by @msg.CreatedBy</span>
                    @if (!msg.IsDismissed)
                    {
                        <form asp-action="Dismiss" asp-route-id="@msg.AnnouncementId" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="btn btn-sm btn-secondary"><i class="bi bi-check-lg"></i> Dismiss</button></form>
                    }
                    else { <span class="msg-dismissed-badge"><i class="bi bi-check-lg"></i> Dismissed</span> }
                </div>
            </div>
            <div class="msg-body"><p style="white-space:pre-line;margin:0;">@msg.Message</p></div>
        </div>
    }
}
else
{
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:48px 24px;text-align:center;"><i class="bi bi-envelope-open" style="font-size:2.5rem;color:var(--text-dim);display:block;margin-bottom:12px;"></i><div style="font-weight:700;color:var(--text-secondary);margin-bottom:4px;">No messages</div><div style="font-size:13px;color:var(--text-muted);">Announcements from the system administrator will appear here.</div></div>
}
