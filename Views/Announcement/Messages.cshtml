@model UserMessageViewModel
@{
    ViewData["Title"] = "Messages";
}

@section Styles {
<style>
    .msg-header { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
    .msg-header h1 { font-family: var(--font-display); font-size: 1.625rem; font-weight: 800; color: var(--text-primary); display: flex; align-items: center; gap: 8px; letter-spacing: -.02em; }
    .msg-header h1 i { font-size: 20px; color: var(--accent); }
    .msg-header .count { font-size: 14px; color: var(--text-muted); font-weight: 500; }
    .msg-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; margin-bottom: 12px; transition: opacity .2s; }
    .msg-card.is-read { opacity: 0.45; }
    .msg-top { display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; border-bottom: 1px solid var(--border); background: var(--bg-elevated); flex-wrap: wrap; gap: 8px; }
    .msg-title { display: flex; align-items: center; gap: 8px; font-family: var(--font-display); font-weight: 700; font-size: 15px; color: var(--text-primary); }
    .msg-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); flex-shrink: 0; animation: pulse-dot 2s ease-in-out infinite; }
    @@keyframes pulse-dot { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
    .msg-meta { display: flex; align-items: center; gap: 10px; font-size: 13.5px; color: var(--text-muted); }
    .msg-body { padding: 18px 20px; font-size: 15px; color: var(--text-secondary); line-height: 1.6; }
    .msg-read-badge { padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 700; background: rgba(34,197,94,0.1); color: #22C55E; display: inline-flex; align-items: center; gap: 5px; border: 1px solid rgba(34,197,94,0.2); }
    .btn-mark-read { background: rgba(34,197,94,0.12); color: #22C55E; border: 1px solid rgba(34,197,94,0.25); font-weight: 700; font-size: 13px; padding: 5px 14px; border-radius: 6px; cursor: pointer; display: inline-flex; align-items: center; gap: 5px; transition: background .14s, border-color .14s; }
    .btn-mark-read:hover { background: rgba(34,197,94,0.2); border-color: rgba(34,197,94,0.4); color: #22C55E; }
</style>
}

<div class="msg-header" style="margin-bottom:20px;">
    <div>
        <h1><i class="bi bi-envelope"></i> Messages</h1>
        <div class="count">@if (Model.UnreadCount > 0) { <span>@Model.UnreadCount unread announcement@(Model.UnreadCount != 1 ? "s" : "")</span> } else { <span>All caught up — no unread announcements</span> }</div>
    </div>
    @if (Model.UnreadCount > 1)
    {
        <form asp-action="DismissAll" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-mark-read" style="padding:8px 18px;font-size:14px;">
                <i class="bi bi-check-all"></i> Mark All as Read
            </button>
        </form>
    }
</div>

@if (Model.Messages.Any())
{
    @foreach (var msg in Model.Messages)
    {
        <div class="msg-card @(msg.IsDismissed ? "is-read" : "")">
            <div class="msg-top">
                <div class="msg-title">
                    @if (!msg.IsDismissed) { <span class="msg-dot"></span> }
                    <i class="bi bi-megaphone" style="color:var(--accent);font-size:13px;"></i>
                    @msg.Title
                </div>
                <div class="msg-meta">
                    <span>@msg.CreatedAt.ToString("MMM dd, yyyy") · by @msg.CreatedBy</span>
                    @if (!msg.IsDismissed)
                    {
                        <form asp-action="Dismiss" asp-route-id="@msg.AnnouncementId" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="btn-mark-read"><i class="bi bi-check-circle"></i> Mark as Read</button></form>
                    }
                    else { <span class="msg-read-badge"><i class="bi bi-check-circle"></i> Read</span> }
                </div>
            </div>
            <div class="msg-body"><p style="white-space:pre-line;margin:0;">@msg.Message</p></div>
        </div>
    }
}
else
{
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:48px 24px;text-align:center;">
        <i class="bi bi-envelope-open" style="font-size:2.5rem;color:var(--text-dim);display:block;margin-bottom:12px;"></i>
        <div style="font-weight:700;color:var(--text-secondary);margin-bottom:4px;">No messages</div>
        <div style="font-size:13px;color:var(--text-muted);">Announcements from administrators will appear here.</div>
    </div>
}
