@model CreateAnnouncementViewModel
@{
    ViewData["Title"] = "New Announcement";
}

<div class="page page-full">
    <div class="page-header">
        <div>
            <div class="page-title">New Announcement</div>
            <div class="page-subtitle">Create and send an announcement to users</div>
        </div>
    </div>

    <div class="card" style="max-width: 620px;">
        <div class="card-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label asp-for="Title" class="form-label">Title</label>
                    <input asp-for="Title" class="form-control" placeholder="e.g. System Maintenance Scheduled" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Message" class="form-label">Message</label>
                    <textarea asp-for="Message" class="form-control" rows="5" placeholder="Write your announcement message here..."></textarea>
                    <span asp-validation-for="Message" class="text-danger small"></span>
                    <div class="form-hint">This message will appear as a popup and in the user's message inbox.</div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="TargetRole" class="form-label">Send To</label>
                        <select asp-for="TargetRole" class="form-control">
                            <option value="All">All Users (Admin + User)</option>
                            <option value="Admin">Admin Only</option>
                            <option value="User">User Only</option>
                        </select>
                        <span asp-validation-for="TargetRole" class="text-danger small"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="ExpiresAt" class="form-label">Expires On (Optional)</label>
                        <input asp-for="ExpiresAt" class="form-control" type="date" />
                        <span asp-validation-for="ExpiresAt" class="text-danger small"></span>
                        <div class="form-hint">Leave blank for no expiry.</div>
                    </div>
                </div>

                <div class="form-actions">
                    <a asp-action="Index" class="btn btn-secondary">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                        Send Announcement
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
