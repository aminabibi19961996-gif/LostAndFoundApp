@model CreateAnnouncementViewModel
@{
    ViewData["Title"] = "New Announcement";
}

<div style="max-width:600px;">
    <!-- HEADER -->
    <div style="margin-bottom:20px;">
        <h1 style="font-family:var(--font-display);font-size:1.625rem;font-weight:800;color:var(--text-primary);display:flex;align-items:center;gap:8px;">
            <i class="bi bi-megaphone" style="color:var(--accent)"></i> New Announcement
        </h1>
        <div style="font-size:14px;color:var(--text-muted);font-weight:500;">Create and send an announcement to users</div>
    </div>

    <!-- FORM CARD -->
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;">
        <div style="padding:22px 20px;">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div style="display:flex;flex-direction:column;gap:14px;">
                    <!-- Title -->
                    <div>
                        <label asp-for="Title" class="form-label" style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);">Title</label>
                        <input asp-for="Title" class="form-control" placeholder="e.g. System Maintenance Scheduled" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <!-- Message -->
                    <div>
                        <label asp-for="Message" class="form-label" style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);">Message</label>
                        <textarea asp-for="Message" class="form-control" rows="5" placeholder="Write your announcement..."></textarea>
                        <span asp-validation-for="Message" class="text-danger small"></span>
                        <div style="font-size:12.5px;color:var(--text-dim);margin-top:4px;">Appears as popup and in message inbox.</div>
                    </div>

                    <!-- Target & Expiry -->
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
                        <div>
                            <label asp-for="TargetRole" class="form-label" style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);">Send To</label>
                            <select asp-for="TargetRole" class="form-select">
                                <option value="All">All Users</option>
                                <option value="SupervisorAndAbove">Supervisor &amp; Above</option>
                                <option value="AdminAndAbove">Admin Only</option>
                                <option value="Supervisor">Supervisor Only</option>
                                <option value="User">User Only</option>
                            </select>
                            <span asp-validation-for="TargetRole" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="ExpiresAt" class="form-label" style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);">Expires On (Optional)</label>
                            <input asp-for="ExpiresAt" class="form-control" type="date" />
                            <span asp-validation-for="ExpiresAt" class="text-danger small"></span>
                            <div style="font-size:12.5px;color:var(--text-dim);margin-top:4px;">Leave blank for no expiry.</div>
                        </div>
                    </div>
                </div>

                <!-- FOOTER -->
                <div style="display:flex;justify-content:space-between;align-items:center;padding:14px 20px;border-top:1px solid var(--border);background:var(--bg-elevated);margin:20px -18px -20px;border-radius:0 0 12px 12px;">
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i> Send Announcement</button>
                </div>
            </form>
        </div>
    </div>
</div>
