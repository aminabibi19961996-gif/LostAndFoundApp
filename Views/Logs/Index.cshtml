@model LogListViewModel
@{
    ViewData["Title"] = "Activity Logs";
}

@section Styles {
<style>
    .log-header { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; }
    .log-header h1 { font-family: var(--font-display); font-size: 1.625rem; font-weight: 800; color: var(--text-primary); display: flex; align-items: center; gap: 8px; letter-spacing: -.02em; }
    .log-header h1 i { font-size: 20px; color: var(--accent); }
    .log-header .count { font-size: 14px; color: var(--text-muted); font-weight: 500; }
    .fc { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 16px; }
    .fc-body { padding: 18px 20px; }
    .fg { display: grid; grid-template-columns: 1fr 150px 140px 140px auto; gap: 12px; align-items: end; }
    .fg .form-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); margin-bottom: 6px; display: block; }
    .fg .form-control, .fg .form-select { background: var(--bg-elevated); border: 1px solid var(--border); color: var(--text-primary); padding: 9px 12px; border-radius: 8px; font-size: 13.5px; width: 100%; }
    .fg-actions { display: flex; gap: 8px; align-self: end; }
    .rc { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    .stable { width: 100%; border-collapse: collapse; }
    .stable thead th { padding: 11px 16px; text-align: left; font-size: 12px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .07em; border-bottom: 1px solid var(--border); background: var(--bg-elevated); white-space: nowrap; }
    .stable tbody td { padding: 12px 16px; font-size: 14px; font-weight: 500; border-bottom: 1px solid var(--border); color: var(--text-secondary); vertical-align: top; }
    .stable tbody tr:last-child td { border-bottom: none; }
    .stable tbody tr:hover td { background: var(--bg-elevated); color: var(--text-primary); }
    .stable tbody tr:hover td:first-child { box-shadow: inset 3px 0 0 var(--accent); }
    .rc-footer { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; padding: 12px 20px; border-top: 1px solid var(--border); background: var(--bg-elevated); }

    /* Category badges */
    .cat-badge { display: inline-flex; align-items: center; padding: 3px 10px; border-radius: 6px; font-size: 11.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; white-space: nowrap; }
    .cat-auth { background: rgba(124,143,255,0.12); color: #A5B4FC; border: 1px solid rgba(124,143,255,0.25); }
    .cat-items { background: rgba(74,222,128,0.10); color: #6EE7B7; border: 1px solid rgba(74,222,128,0.2); }
    .cat-masterdata { background: rgba(6,182,212,0.10); color: #67E8F9; border: 1px solid rgba(6,182,212,0.2); }
    .cat-usermanagement { background: rgba(245,158,11,0.10); color: #FDE68A; border: 1px solid rgba(245,158,11,0.2); }
    .cat-announcement { background: rgba(168,85,247,0.10); color: #C4B5FD; border: 1px solid rgba(168,85,247,0.2); }
    .cat-adsync { background: rgba(236,72,153,0.10); color: #F9A8D4; border: 1px solid rgba(236,72,153,0.2); }
    .cat-system { background: rgba(100,116,139,0.12); color: #94A3B8; border: 1px solid rgba(100,116,139,0.25); }

    /* Status badge */
    .status-ok { color: #4ade80; font-weight: 600; font-size: 13px; }
    .status-fail { color: #f87171; font-weight: 600; font-size: 13px; }

    /* Diff rendering */
    .diff-summary { font-size: 13.5px; color: var(--text-secondary); }
    .diff-toggle { display: inline-flex; align-items: center; gap: 4px; margin-top: 5px; font-size: 12px; font-weight: 600; color: var(--accent); cursor: pointer; border: 1px solid var(--accent); background: transparent; padding: 2px 8px; border-radius: 4px; opacity: .8; transition: opacity .14s, background .14s; }
    .diff-toggle:hover { opacity: 1; background: var(--accent-subtle); }
    .diff-panel { display: none; margin-top: 8px; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; }
    .diff-panel.open { display: block; }
    .diff-line { font-size: 12.5px; padding: 4px 0; display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; border-bottom: 1px solid rgba(255,255,255,0.04); }
    .diff-line:last-child { border-bottom: none; }
    .diff-field { font-weight: 700; color: var(--text-muted); min-width: 130px; flex-shrink: 0; font-size: 11.5px; text-transform: uppercase; letter-spacing: .04em; }
    .diff-old { color: #f87171; text-decoration: line-through; opacity: .85; font-size: 12.5px; }
    .diff-arrow { color: var(--text-dim); flex-shrink: 0; }
    .diff-new { color: #4ade80; font-weight: 600; font-size: 12.5px; }
    @@media (max-width: 768px) { .fg { grid-template-columns: 1fr 1fr; } }
</style>
}

<div class="log-header">
    <div>
        <h1><i class="bi bi-journal-text"></i> Activity Logs</h1>
        <div class="count">@Model.TotalCount record(s) found</div>
    </div>
    @if ((User.IsInRole("SuperAdmin") || User.IsInRole("Admin")) && Model.TotalCount > 0)
    {
        <div style="display:flex;gap:6px;">
            <a asp-action="Export" asp-route-category="@Model.CategoryFilter" asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")" class="btn btn-secondary"><i class="bi bi-download"></i> Export CSV</a>
            @if (User.IsInRole("SuperAdmin"))
            {
                <form asp-action="Clear" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="btn btn-danger" data-confirm="Clear ALL activity logs? This cannot be undone."><i class="bi bi-trash3"></i> Clear All</button></form>
            }
        </div>
    }
</div>

<div class="fc">
    <div class="fc-body">
        <form method="get" asp-action="Index">
            <input type="hidden" name="pageSize" value="@Model.PageSize" />
            <div class="fg">
                <div>
                    <label class="form-label">Search</label>
                    <input type="text" name="search" value="@Model.SearchTerm" class="form-control" placeholder="Action, details, user..." />
                </div>
                <div>
                    <label class="form-label">Category</label>
                    <select name="category" class="form-select">
                        <option value="">All</option>
                        <option value="Auth" selected="@(Model.CategoryFilter == "Auth" ? "selected" : null)">Auth</option>
                        <option value="Items" selected="@(Model.CategoryFilter == "Items" ? "selected" : null)">Items</option>
                        <option value="MasterData" selected="@(Model.CategoryFilter == "MasterData" ? "selected" : null)">MasterData</option>
                        <option value="UserManagement" selected="@(Model.CategoryFilter == "UserManagement" ? "selected" : null)">UserManagement</option>
                        <option value="Announcement" selected="@(Model.CategoryFilter == "Announcement" ? "selected" : null)">Announcement</option>
                        <option value="ADSync" selected="@(Model.CategoryFilter == "ADSync" ? "selected" : null)">ADSync</option>
                        <option value="System" selected="@(Model.CategoryFilter == "System" ? "selected" : null)">System</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Date From</label>
                    <input type="date" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div>
                    <label class="form-label">Date To</label>
                    <input type="date" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="fg-actions">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i></button>
                    <a asp-action="Index" class="btn btn-ghost"><i class="bi bi-x-circle"></i></a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="rc">
    @if (Model.Logs.Any())
    {
        <div style="overflow-x:auto;">
            <table class="stable">
                <thead>
                    <tr>
                        <th>Timestamp</th>
                        <th>Action</th>
                        <th>Details / Changes</th>
                        <th>Performed By</th>
                        <th>Category</th>
                        <th>IP</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int diffIdx = 0;
                    }
                    @foreach (var log in Model.Logs)
                    {
                        var catClass = log.Category?.ToLower() switch {
                            "auth"           => "cat-auth",
                            "items"          => "cat-items",
                            "masterdata"     => "cat-masterdata",
                            "usermanagement" => "cat-usermanagement",
                            "adsync"         => "cat-adsync",
                            "announcement"   => "cat-announcement",
                            "system"         => "cat-system",
                            _                => "cat-system"
                        };

                        // Detect structured diff (CHANGES: sentinel written by ItemDiffService)
                        var hasDiff = log.Details.Contains("CHANGES:");
                        string summaryLine;
                        List<string> changeLines;

                        if (hasDiff)
                        {
                            var parts = log.Details.Split("CHANGES:", 2);
                            summaryLine = parts[0].Trim();
                            changeLines = parts.Length > 1
                                ? parts[1]
                                      .Split('\n', StringSplitOptions.RemoveEmptyEntries)
                                      .Select(l => l.Trim())
                                      .Where(l => l.StartsWith("-"))
                                      .ToList()
                                : new List<string>();
                        }
                        else
                        {
                            summaryLine = log.Details;
                            changeLines = new List<string>();
                        }

                        var panelId = $"diff-{diffIdx++}";

                        <tr>
                            <td style="font-family:var(--font-mono);font-size:12px;color:var(--text-muted);white-space:nowrap;">@log.Timestamp.ToString("MM/dd/yyyy HH:mm")</td>
                            <td style="font-weight:600;color:var(--text-primary);white-space:nowrap;">@log.Action</td>
                            <td style="min-width:240px;max-width:400px;">
                                @if (hasDiff && changeLines.Any())
                                {
                                    <div class="diff-summary">@summaryLine</div>
                                    <button class="diff-toggle" onclick="toggleDiff('@panelId', this)" type="button">
                                        <i class="bi bi-list-ul"></i>&nbsp;@changeLines.Count change(s)
                                    </button>
                                    <div class="diff-panel" id="@panelId">
                                        @foreach (var line in changeLines)
                                        {
                                            var withoutBullet = line.TrimStart('-').Trim();
                                            var colonIdx = withoutBullet.IndexOf(':');
                                            if (colonIdx > 0)
                                            {
                                                var fieldLabel = withoutBullet[..colonIdx].Trim();
                                                var rest = withoutBullet[(colonIdx + 1)..].Trim();
                                                var arrowIdx = rest.IndexOf(" -> ");
                                                string oldVal, newVal;
                                                if (arrowIdx >= 0)
                                                {
                                                    oldVal = rest[..arrowIdx].Trim().Trim('"');
                                                    newVal = rest[(arrowIdx + 4)..].Trim().Trim('"');
                                                }
                                                else
                                                {
                                                    oldVal = "";
                                                    newVal = rest.Trim('"');
                                                }
                                                <div class="diff-line">
                                                    <span class="diff-field">@fieldLabel</span>
                                                    @if (!string.IsNullOrEmpty(oldVal))
                                                    {
                                                        <span class="diff-old">@oldVal</span>
                                                        <span class="diff-arrow">-></span>
                                                    }
                                                    <span class="diff-new">@newVal</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="diff-line"><span>@line</span></div>
                                            }
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span style="max-width:350px;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@log.Details">@log.Details</span>
                                }
                            </td>
                            <td>@log.PerformedBy</td>
                            <td><span class="cat-badge @catClass">@log.Category</span></td>
                            <td style="font-family:var(--font-mono);font-size:12px;color:var(--text-muted);">@log.IpAddress</td>
                            <td>
                                @if (log.Status == "Success")
                                {
                                    <span class="status-ok"><i class="bi bi-check-circle-fill"></i> Success</span>
                                }
                                else
                                {
                                    <span class="status-fail"><i class="bi bi-x-circle-fill"></i> @log.Status</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="rc-footer">
            <div style="display:flex;align-items:center;gap:8px;">
                <span style="font-size:12.5px;color:var(--text-dim);">
                    Page @Model.CurrentPage of @Model.TotalPages · @Model.TotalCount records
                </span>
                <span style="font-size:12.5px;color:var(--text-dim);">|</span>
                <span style="font-size:12px;color:var(--text-muted);">Per page</span>
                <select class="page-size-select" id="logPageSizeSelect" onchange="changePageSize(this.value)">
                    <option value="25" selected="@(Model.PageSize == 25)">25</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                    <option value="100" selected="@(Model.PageSize == 100)">100</option>
                    <option value="200" selected="@(Model.PageSize == 200)">200</option>
                    <option value="500" selected="@(Model.PageSize == 500)">500</option>
                </select>
            </div>
            @if (Model.TotalPages > 1)
            {
                <div style="display:flex;gap:6px;">
                    @if (Model.CurrentPage > 1) { <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-pageSize="@Model.PageSize" asp-route-category="@Model.CategoryFilter" asp-route-search="@Model.SearchTerm" asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")" class="btn btn-secondary btn-sm"><i class="bi bi-chevron-left"></i></a> }
                    @for (var i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++) { <a asp-action="Index" asp-route-page="@i" asp-route-pageSize="@Model.PageSize" asp-route-category="@Model.CategoryFilter" asp-route-search="@Model.SearchTerm" asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")" class="btn btn-sm @(i == Model.CurrentPage ? "btn-primary" : "btn-secondary")">@i</a> }
                    @if (Model.CurrentPage < Model.TotalPages) { <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-pageSize="@Model.PageSize" asp-route-category="@Model.CategoryFilter" asp-route-search="@Model.SearchTerm" asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")" class="btn btn-secondary btn-sm"><i class="bi bi-chevron-right"></i></a> }
                </div>
            }
        </div>
    }
    else
    {
        <div style="padding:48px 24px;text-align:center;">
            <i class="bi bi-journal-text" style="font-size:2.5rem;color:var(--text-dim);display:block;margin-bottom:12px;"></i>
            <div style="font-weight:700;color:var(--text-secondary);margin-bottom:4px;">No activity logs found</div>
            <div style="font-size:13px;color:var(--text-muted);">Activity will be logged as you use the application.</div>
        </div>
    }
</div>

@section Scripts {
<script>
    function toggleDiff(panelId, btn) {
        var panel = document.getElementById(panelId);
        var isOpen = panel.classList.toggle('open');
        var count = btn.textContent.trim().match(/\d+\s+change/)?.[0] ?? 'changes';
        btn.innerHTML = isOpen
            ? '<i class="bi bi-chevron-up"></i>&nbsp;' + count
            : '<i class="bi bi-list-ul"></i>&nbsp;' + count;
    }

    function changePageSize(size) {
        var url = new URL(window.location.href);
        url.searchParams.set('pageSize', size);
        url.searchParams.set('page', '1');
        window.location.href = url.toString();
    }
</script>
}