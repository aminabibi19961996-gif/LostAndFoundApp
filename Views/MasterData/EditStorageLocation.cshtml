@model StorageLocation
@{ ViewData["Title"] = "Edit Storage Location"; }

<div class="page page-full">
    <div class="page-header">
        <div>
            <div class="page-title">Edit Storage Location</div>
            <div class="page-subtitle">Update storage location details</div>
        </div>
    </div>

    <div class="card" style="max-width: 480px;">
        <div class="card-body">
            <form asp-action="EditStorageLocation" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="form-group">
                    <label asp-for="Name" class="form-label">Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="form-group">
                    <label class="checkbox-label">
                        <input asp-for="IsActive" type="checkbox" />
                        <span>Active</span>
                    </label>
                </div>
                <div class="form-actions">
                    <a asp-action="StorageLocations" class="btn btn-secondary">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
