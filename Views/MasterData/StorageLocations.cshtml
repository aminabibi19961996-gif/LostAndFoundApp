@model PaginatedList<StorageLocation>
@{ ViewData["Title"] = "Storage Locations"; }
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div><h1 class="page-title"><svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display:inline-block;vertical-align:middle;margin-right:8px;"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0l2-2m-2 2l-2-2m2 2l2 2M9 7h1m2 0h2M9 11h2m2 0h4"/></svg>Storage Locations</h1><p class="page-subtitle">@Model.TotalCount location(s)</p></div>
        <a asp-action="CreateStorageLocation" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Location</a>
    </div>
</div>
<div class="card">
    <div class="card-body p-0">
            @if (Model.Items.Any())
            {
                <div class="table-responsive">
                    <table class="table-modern">
                        <thead><tr><th>Name</th><th>Status</th><th>Actions</th></tr></thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td><strong>@item.Name</strong></td>
                                    <td><span class="badge-role @(item.IsActive ? "badge-active" : "badge-inactive")">@(item.IsActive ? "Active" : "Inactive")</span></td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <a asp-action="EditStorageLocation" asp-route-id="@item.Id" class="btn btn-ghost btn-icon" title="Edit"><i class="bi bi-pencil"></i></a>
                                            <form asp-action="ToggleStorageLocationActive" asp-route-id="@item.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="btn btn-ghost btn-icon"><i class="bi @(item.IsActive ? "bi-toggle-on text-success" : "bi-toggle-off text-muted")"></i></button></form>
                                            <form asp-action="DeleteStorageLocation" asp-route-id="@item.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="btn btn-ghost btn-icon text-danger" data-confirm="Delete this storage location?"><i class="bi bi-trash3"></i></button></form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer">
                    <partial name="_Pagination" model="Model" />
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon"><i class="bi bi-building"></i></div>
                    <div class="empty-title">No storage locations</div>
                    <div class="empty-desc">Add your first storage location to get started.</div>
                </div>
            }
        </div>
    </div>
</div>
