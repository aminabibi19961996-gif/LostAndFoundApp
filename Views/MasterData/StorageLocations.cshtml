@model PaginatedList<LostAndFoundApp.Models.StorageLocation>
@{
    ViewData["Title"] = "Storage Locations";
    var sortBy = Model.SortBy ?? "Name";
    var sortOrder = Model.SortOrder ?? "asc";
    var nameSort = sortBy == "Name" ? (sortOrder == "asc" ? "desc" : "asc") : "asc";
    var statusSort = sortBy == "Status" ? (sortOrder == "asc" ? "desc" : "asc") : "asc";
    var nameIcon = sortBy == "Name" ? (sortOrder == "asc" ? "bi-sort-alpha-down" : "bi-sort-alpha-up") : "bi-filter";
    var statusIcon = sortBy == "Status" ? (sortOrder == "asc" ? "bi-sort-down" : "bi-sort-up") : "bi-filter";
}

<!-- HEADER -->
<div class="md-header" style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;margin-bottom:20px;">
    <div>
        <h1 style="font-family:var(--font-display);font-size:1.625rem;font-weight:800;color:var(--text-primary);display:flex;align-items:center;gap:8px;">
            <i class="bi bi-building" style="color:var(--accent)"></i> Storage Locations
        </h1>
        <div style="font-size:14px;color:var(--text-muted);font-weight:500;">@Model.TotalCount location(s)</div>
    </div>
    <div style="display:flex;align-items:center;gap:8px;">
        <partial name="_CsvImportModal" model='("StorageLocations", "storage locations")' />
        <a asp-action="CreateStorageLocation" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Location</a>
    </div>
</div>


<!-- TABLE -->
<div class="md-card">
    @if (Model.Items.Any())
    {
        <div class="md-scroll">
            <table class="table-modern" style="width:100%;border-collapse:collapse;">
                <thead>
                    <tr>
                        <th style="padding:10px 16px;text-align:center;font-size:12px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.07em;border-bottom:1px solid var(--border);background:var(--bg-elevated);width:60px;">Sr#</th>
                        <th style="padding:10px 16px;text-align:left;font-size:12px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.07em;border-bottom:1px solid var(--border);background:var(--bg-elevated);">
                            <a href="@Url.Action("StorageLocations", "MasterData", new { pageIndex = 1, pageSize = Model.PageSize, sortBy = "Name", sortOrder = nameSort })" style="color:var(--text-muted);text-decoration:none;display:inline-flex;align-items:center;gap:4px;">
                                Name <i class="bi @nameIcon" style="font-size:11px;@(sortBy == "Name" ? "color:var(--accent);" : "opacity:.4;")"></i>
                            </a>
                        </th>
                        <th style="padding:10px 16px;text-align:left;font-size:12px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.07em;border-bottom:1px solid var(--border);background:var(--bg-elevated);">
                            <a href="@Url.Action("StorageLocations", "MasterData", new { pageIndex = 1, pageSize = Model.PageSize, sortBy = "Status", sortOrder = statusSort })" style="color:var(--text-muted);text-decoration:none;display:inline-flex;align-items:center;gap:4px;">
                                Status <i class="bi @statusIcon" style="font-size:11px;@(sortBy == "Status" ? "color:var(--accent);" : "opacity:.4;")"></i>
                            </a>
                        </th>
                        <th style="padding:10px 16px;text-align:left;font-size:12px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.07em;border-bottom:1px solid var(--border);background:var(--bg-elevated);width:100px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @{ var srNo = Model.StartRecord; }
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td style="padding:11px 16px;font-size:13px;font-weight:600;color:var(--text-muted);text-align:center;">@srNo</td>
                            <td style="padding:11px 16px;font-size:14.5px;font-weight:600;color:var(--text-primary);">@item.Name</td>
                            <td style="padding:11px 16px;">
                                <span class="badge-role @(item.IsActive ? "badge-active" : "badge-inactive")">@(item.IsActive ? "Active" : "Inactive")</span>
                            </td>
                            <td style="padding:11px 16px;">
                                <div style="display:flex;gap:3px;">
                                    <a asp-action="EditStorageLocation" asp-route-id="@item.Id" class="ra" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="ToggleStorageLocationActive" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="ra" title="@(item.IsActive ? "Deactivate" : "Activate")">
                                            <i class="bi @(item.IsActive ? "bi-toggle-on" : "bi-toggle-off")" style="color:@(item.IsActive ? "var(--green)" : "var(--text-muted)")"></i>
                                        </button>
                                    </form>
                                    <form asp-action="DeleteStorageLocation" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="ra" title="Delete" data-confirm="Delete this location?" style="color:var(--red);">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        srNo++;
                    }
                </tbody>
            </table>
        </div>
        @if (Model.TotalPages > 1)
        {
            <div class="md-pagination">
                <partial name="_Pagination" model="Model" />
            </div>
        }
    }
    else
    {
        <div style="padding:48px 24px;text-align:center;">
            <i class="bi bi-building" style="font-size:2.5rem;color:var(--text-dim);display:block;margin-bottom:12px;"></i>
            <div style="font-weight:700;color:var(--text-secondary);margin-bottom:4px;">No storage locations</div>
            <div style="font-size:13px;color:var(--text-muted);">Add your first storage location.</div>
        </div>
    }
</div>
