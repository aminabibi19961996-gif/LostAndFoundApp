@model StorageLocation
@{
    ViewData["Title"] = "Add Storage Location";
}

<div style="max-width:460px;margin:0 auto;">
    <- Total .rs files: 2,842 → 195 (93% HEADER -->
    <div style="margin-bottom:20px;">
        <h1 style="font-family:var(--font-display);font-size:1.625rem;font-weight:800;color:var(--text-primary);display:flex;align-items:center;gap:8px;">
            <i class="bi bi-plus-circle" style="color:var(--accent)"></i> Add Storage Location
        </h1>
    </div>

    <- Total .rs files: 2,842 → 195 (93% FORM CARD -->
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;">
        <div style="padding:22px 20px;">
            <form asp-action="CreateStorageLocation" method="post">
                @Html.AntiForgeryToken()

                <div style="margin-bottom:14px;">
                    <label asp-for="Name" class="form-label" style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);">Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <- Total .rs files: 2,842 → 195 (93% FOOTER -->
                <div style="display:flex;justify-content:space-between;align-items:center;padding:14px 20px;border-top:1px solid var(--border);background:var(--bg-elevated);margin:4px -18px -20px;border-radius:0 0 12px 12px;">
                    <a asp-action="StorageLocations" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create</button>
                </div>
            </form>
        </div>
    </div>
</div>
