@model PaginatedList<Status>
@{ ViewData["Title"] = "Statuses"; }
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div><h1 class="page-title"><svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display:inline-block;vertical-align:middle;margin-right:8px;"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>Statuses</h1><p class="page-subtitle">@Model.TotalCount status(es)</p></div>
        <a asp-action="CreateStatus" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Status</a>
    </div>
</div>
<div class="card">
    <div class="card-body p-0">
            @if (Model.Items.Any())
            {
                <div class="table-responsive">
                    <table class="table-modern">
                        <thead><tr><th>Name</th><th>Status</th><th>Actions</th></tr></thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td><strong>@item.Name</strong></td>
                                    <td><span class="badge-role @(item.IsActive ? "badge-active" : "badge-inactive")">@(item.IsActive ? "Active" : "Inactive")</span></td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <a asp-action="EditStatus" asp-route-id="@item.Id" class="btn btn-ghost btn-icon" title="Edit"><i class="bi bi-pencil"></i></a>
                                            <form asp-action="ToggleStatusActive" asp-route-id="@item.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="btn btn-ghost btn-icon"><i class="bi @(item.IsActive ? "bi-toggle-on text-success" : "bi-toggle-off text-muted")"></i></button></form>
                                            <form asp-action="DeleteStatus" asp-route-id="@item.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="btn btn-ghost btn-icon text-danger" data-confirm="Delete this status?"><i class="bi bi-trash3"></i></button></form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer">
                    <partial name="_Pagination" model="Model" />
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon"><i class="bi bi-tag"></i></div>
                    <div class="empty-title">No statuses</div>
                    <div class="empty-desc">Add your first status to get started.</div>
                </div>
            }
        </div>
    </div>
</div>
