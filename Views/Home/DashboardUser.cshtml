@model LostAndFoundApp.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var total = Model.TotalItems > 0 ? Model.TotalItems : 1;
}

@section Styles {
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
:root {
  --accent-db:#7C8FFF;
  --found-c:#4ADE80;--found-bg:rgba(74,222,128,0.08);--found-b:rgba(74,222,128,0.2);
  --claim-c:#60A5FA;--claim-bg:rgba(96,165,250,0.08);--claim-b:rgba(96,165,250,0.2);
  --store-c:#FCD34D;--store-bg:rgba(252,211,77,0.08);--store-b:rgba(252,211,77,0.2);
  --xfer-c:#C4B5FD;--xfer-bg:rgba(196,181,253,0.08);--xfer-b:rgba(196,181,253,0.2);
  --disp-c:#71717A;--disp-bg:rgba(113,113,122,0.07);--disp-b:rgba(113,113,122,0.16);
  --warn-db:#FCD34D;--danger-db:#F87171;--green-db:#4ADE80;
  --t1:#F5F5F5;--t2:#A3A3A3;--t3:#5C5C5C;--t4:#2E2E2E;
  --mono:'JetBrains Mono',monospace;--display:'Syne',sans-serif;--body-db:'Inter',sans-serif;
}
.dash-page{flex:1;overflow-y:auto;overflow-x:hidden;padding:24px;display:flex;flex-direction:column;gap:20px;width:100%;max-width:none;min-height:0}
.dash-page::-webkit-scrollbar{width:4px}.dash-page::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:2px}
.pg-head{display:flex;align-items:center;justify-content:space-between;flex-shrink:0;flex-wrap:wrap;gap:12px}
.pg-title{font-family:var(--display);font-size:26px;font-weight:800;color:var(--t1);letter-spacing:-.025em}
.pg-sub{font-size:14px;color:var(--t3);margin-top:3px;font-weight:500}
.pg-date{font-size:13.5px;color:var(--t3);margin-top:3px;font-weight:500}

/* Quick action strip */
.action-strip{display:flex;gap:10px;flex-wrap:wrap}
.action-btn{display:inline-flex;align-items:center;gap:8px;padding:14px 24px;border-radius:12px;font-size:15px;font-weight:700;text-decoration:none;transition:all .14s ease;border:1px solid transparent}
.action-btn.primary{background:linear-gradient(135deg,#7C8FFF,#A78BFA);color:#fff;box-shadow:0 4px 16px rgba(124,143,255,0.3)}
.action-btn.primary:hover{transform:translateY(-1px);box-shadow:0 6px 24px rgba(124,143,255,0.45);color:#fff}
.action-btn.secondary{background:var(--bg-card);border-color:var(--border);color:var(--t1)}
.action-btn.secondary:hover{border-color:rgba(255,255,255,0.2);background:var(--bg-elevated);color:var(--t1)}
.action-btn i{font-size:18px}

/* Alert bar for user */
.user-alerts{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px}
.u-alert{display:flex;align-items:center;gap:12px;padding:14px 18px;background:var(--bg-card);border:1px solid var(--border);border-radius:12px;transition:border-color .14s}
.u-alert.warn{border-color:rgba(252,211,77,0.25)}.u-alert.danger{border-color:rgba(248,113,113,0.25)}.u-alert.ok{border-color:rgba(74,222,128,0.25)}.u-alert.info{border-color:rgba(124,143,255,0.25)}
.u-alert-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.warn .u-alert-icon{background:rgba(252,211,77,0.1);color:var(--warn-db)}
.danger .u-alert-icon{background:rgba(248,113,113,0.1);color:var(--danger-db)}
.ok .u-alert-icon{background:rgba(74,222,128,0.1);color:var(--green-db)}
.info .u-alert-icon{background:rgba(124,143,255,0.1);color:var(--accent-db)}
.u-alert-num{font-family:var(--mono);font-size:24px;font-weight:700;line-height:1}
.warn .u-alert-num{color:var(--warn-db)}.danger .u-alert-num{color:var(--danger-db)}.ok .u-alert-num{color:var(--green-db)}.info .u-alert-num{color:var(--accent-db)}
.u-alert-lbl{font-size:12px;color:var(--t3);font-weight:600;text-transform:uppercase;letter-spacing:.06em}

/* My KPIs */
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.kpi-card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:18px 20px;position:relative;overflow:hidden;transition:border-color .14s,background .14s}
.kpi-card:hover{border-color:rgba(255,255,255,0.16);background:var(--bg-elevated)}
.kpi-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--t3);margin-bottom:8px}
.kpi-num{font-family:var(--mono);font-size:36px;font-weight:700;line-height:1;letter-spacing:-.04em;color:var(--t1)}
.kpi-context{font-size:12px;color:var(--t3);margin-top:6px;font-weight:500}
.kpi-context strong{font-weight:700}
.kpi-context .up{color:var(--green-db)}.kpi-context .down{color:var(--danger-db)}.kpi-context .neutral{color:var(--t3)}
.kpi-bar{position:absolute;bottom:0;left:0;right:0;height:2px}

/* Table */
.dtc{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;min-height:0;flex:1}
.dtc-head{display:flex;align-items:center;justify-content:space-between;padding:12px 18px;border-bottom:1px solid var(--border);background:var(--bg-elevated);flex-shrink:0}
.dtc-title{font-family:var(--display);font-size:15px;font-weight:700;color:var(--t1);display:flex;align-items:center;gap:8px}
.dtc-badge{padding:2px 8px;border-radius:20px;font-size:12px;font-weight:700;font-family:var(--body-db);background:var(--bg-hover);color:var(--t3)}
.dtc-link{font-size:13.5px;color:var(--accent-db);text-decoration:none;font-weight:600;opacity:.8}.dtc-link:hover{opacity:1}
.dtc-body{flex:1;overflow-y:auto;min-height:0}.dtc-body::-webkit-scrollbar{width:4px}.dtc-body::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.08);border-radius:2px}
.dtable{width:100%;border-collapse:collapse}
.dtable thead th{padding:10px 14px;text-align:left;font-size:11.5px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.08em;border-bottom:1px solid var(--border);background:var(--bg-elevated);white-space:nowrap}
.dtable thead th:first-child{padding-left:18px}
.dtable tbody td{padding:12px 14px;font-size:14.5px;font-weight:500;border-bottom:1px solid var(--border);color:var(--t2);vertical-align:middle}
.dtable tbody td:first-child{padding-left:18px}.dtable tbody tr:last-child td{border-bottom:none}
.dtable tbody tr:hover td{background:var(--bg-elevated);color:var(--t1)}.dtable tbody tr:hover td:first-child{box-shadow:inset 3px 0 0 var(--accent-db)}
.d-tid{font-family:var(--mono);font-size:13px;color:var(--t1);font-weight:600}
.d-item-name{color:var(--t1);font-weight:600}.d-loc-text{font-size:13px;color:var(--t3);font-weight:500}
.d-badge{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;font-size:12.5px;font-weight:700;border:1px solid transparent;white-space:nowrap}
.d-badge::before{content:'';width:5px;height:5px;border-radius:50%;background:currentColor;flex-shrink:0}
.db-found{background:var(--found-bg);color:var(--found-c);border-color:var(--found-b)}.db-claimed{background:var(--claim-bg);color:var(--claim-c);border-color:var(--claim-b)}.db-stored{background:var(--store-bg);color:var(--store-c);border-color:var(--store-b)}.db-xfer{background:var(--xfer-bg);color:var(--xfer-c);border-color:var(--xfer-b)}.db-disposed{background:var(--disp-bg);color:var(--disp-c);border-color:var(--disp-b)}
.days-num{font-family:var(--mono);font-size:14px;font-weight:600}.days-warn{color:var(--danger-db);font-weight:800;font-family:var(--mono);font-size:14px}
.d-row-actions{display:flex;align-items:center;gap:2px}
.d-ra{display:inline-flex;align-items:center;justify-content:center;width:30px;height:30px;border-radius:6px;background:transparent;border:none;color:var(--t4);cursor:pointer;font-size:14px;text-decoration:none;transition:background .1s,color .1s}
.d-ra:hover{background:var(--bg-hover);color:var(--accent-db)}
.dtc-foot{display:flex;align-items:center;justify-content:space-between;padding:9px 18px;border-top:1px solid var(--border);background:var(--bg-elevated);flex-shrink:0}
.dtc-foot-info{font-size:13px;color:var(--t4);font-weight:500}

@@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.dash-page>*{animation:fadeUp .3s ease both}.dash-page>*:nth-child(1){animation-delay:.04s}.dash-page>*:nth-child(2){animation-delay:.08s}.dash-page>*:nth-child(3){animation-delay:.12s}.dash-page>*:nth-child(4){animation-delay:.16s}.dash-page>*:nth-child(5){animation-delay:.20s}
@@media(max-width:1200px){.kpi-row{grid-template-columns:repeat(2,1fr)}}
@@media(max-width:768px){.kpi-row{grid-template-columns:1fr}.action-strip{flex-direction:column}.user-alerts{grid-template-columns:1fr}}
</style>
}

<div class="dash-page">

  <!-- ZONE 0: QUICK ACTIONS (Speed is king for Users) -->
  <div class="pg-head">
    <div>
      <div class="pg-title">Welcome, @Model.UserDisplayName!</div>
      <div class="pg-date">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</div>
    </div>
    <div class="action-strip">
      <a class="action-btn primary" asp-controller="LostFoundItem" asp-action="Create"><i class="bi bi-plus-lg"></i> New Record</a>
      <a class="action-btn secondary" asp-controller="LostFoundItem" asp-action="Search"><i class="bi bi-search"></i> Search</a>
    </div>
  </div>

  <!-- ZONE 1: PERSONAL ALERTS — What needs MY attention NOW -->
  <div class="user-alerts">
    <div class="u-alert @(Model.MyItemsAwaitingAction > 0 ? "warn" : "ok")">
      <div class="u-alert-icon"><i class="bi bi-hourglass-split"></i></div>
      <div>
        <div class="u-alert-num">@Model.MyItemsAwaitingAction</div>
        <div class="u-alert-lbl">My Items Pending</div>
      </div>
    </div>
    <div class="u-alert info">
      <div class="u-alert-icon"><i class="bi bi-box-seam"></i></div>
      <div>
        <div class="u-alert-num">@Model.MyItemsCount</div>
        <div class="u-alert-lbl">My Total Records</div>
      </div>
    </div>
    <div class="u-alert @(Model.MyItemsThisWeek > 0 ? "ok" : "info")">
      <div class="u-alert-icon"><i class="bi bi-lightning"></i></div>
      <div>
        <div class="u-alert-num">@Model.MyItemsThisWeek</div>
        <div class="u-alert-lbl">Created This Week</div>
      </div>
    </div>
    <div class="u-alert @(Model.ClaimRatePercent >= 50 ? "ok" : "warn")">
      <div class="u-alert-icon"><i class="bi bi-check-circle"></i></div>
      <div>
        <div class="u-alert-num">@Model.ClaimRatePercent%</div>
        <div class="u-alert-lbl">Claim Rate</div>
      </div>
    </div>
  </div>

  <!-- ZONE 2: MY KPIs — How am I performing -->
  <div class="kpi-row">
    <div class="kpi-card">
      <div class="kpi-label">Total Items</div>
      <div class="kpi-num">@Model.TotalItems</div>
      <div class="kpi-context"><strong class="@(Model.WeekOverWeekChangePercent >= 0 ? "up" : "down")">@(Model.WeekOverWeekChangePercent >= 0 ? "+" : "")@Model.WeekOverWeekChangePercent%</strong> vs last week</div>
      <div class="kpi-bar" style="background:var(--accent-db)"></div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">Found</div>
      <div class="kpi-num" style="color:var(--found-c)">@Model.FoundCount</div>
      <div class="kpi-context">@(Model.FoundCount * 100 / total)% of total</div>
      <div class="kpi-bar" style="background:var(--found-c)"></div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">Claimed</div>
      <div class="kpi-num" style="color:var(--claim-c)">@Model.ClaimedCount</div>
      <div class="kpi-context">Avg <strong>@Model.AvgDaysToClaim</strong> days to claim</div>
      <div class="kpi-bar" style="background:var(--claim-c)"></div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">Stored</div>
      <div class="kpi-num" style="color:var(--store-c)">@Model.StoredCount</div>
      <div class="kpi-context">Avg <strong>@Model.AvgStorageDuration</strong> days stored</div>
      <div class="kpi-bar" style="background:var(--store-c)"></div>
    </div>
  </div>

  <!-- ZONE 3: MY RECENT RECORDS — actionable table (only my items) -->
  <div class="dtc">
    <div class="dtc-head">
      <span class="dtc-title"><i class="bi bi-person-lines-fill" style="color:var(--accent-db)"></i> My Records <span class="dtc-badge">@Model.MyItemsCount total</span></span>
      <a class="dtc-link" asp-controller="LostFoundItem" asp-action="Search">View all →</a>
    </div>
    @if (!Model.RecentRecords.Any())
    {
      <div style="padding:64px 24px;text-align:center;">
        <i class="bi bi-inbox" style="font-size:3rem;display:block;margin-bottom:16px;color:var(--t4);"></i>
        <div style="font-size:1.1rem;font-weight:700;color:var(--t1);margin-bottom:6px;">No records yet</div>
        <div style="font-size:0.875rem;color:var(--t3);margin-bottom:24px;max-width:400px;margin-left:auto;margin-right:auto;">Start by creating your first lost &amp; found record.</div>
        <a class="action-btn primary" asp-controller="LostFoundItem" asp-action="Create" style="display:inline-flex">
          <i class="bi bi-plus-lg"></i> Create First Record
        </a>
      </div>
    }
    else
    {
      <div class="dtc-body">
        <table class="dtable">
          <thead>
            <tr>
              <th>ID</th>
              <th>Date Found</th>
              <th>Item</th>
              <th>Location</th>
              <th>Status</th>
              <th>Days</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            @foreach (var record in Model.RecentRecords)
            {
              var statusClass = (record.StatusName?.ToLower()) switch { "found" => "db-found", "claimed" => "db-claimed", "stored" => "db-stored", "transferred" => "db-xfer", "disposed" => "db-disposed", _ => "db-found" };
              <tr>
                <td><span class="d-tid">@record.CustomTrackingId</span></td>
                <td>@record.DateFound.ToString("MM/dd/yyyy")</td>
                <td><span class="d-item-name">@record.ItemName</span></td>
                <td><span class="d-loc-text">@record.LocationFound</span></td>
                <td><span class="d-badge @statusClass">@(record.StatusName ?? "Unknown")</span></td>
                <td>@if(record.DaysSinceFound > 30){<span class="days-warn">@record.DaysSinceFound</span>}else{<span class="days-num">@record.DaysSinceFound</span>}</td>
                <td>
                  <div class="d-row-actions">
                    <a class="d-ra" asp-controller="LostFoundItem" asp-action="Details" asp-route-id="@record.TrackingId" title="View"><i class="bi bi-eye"></i></a>
                    <a class="d-ra" asp-controller="LostFoundItem" asp-action="Edit" asp-route-id="@record.TrackingId" title="Edit"><i class="bi bi-pencil"></i></a>
                    <a class="d-ra" asp-controller="LostFoundItem" asp-action="PrintLabel" asp-route-id="@record.TrackingId" target="_blank" title="Print Label"><i class="bi bi-qr-code"></i></a>
                  </div>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
      <div class="dtc-foot">
        <span class="dtc-foot-info">Showing @Model.RecentRecords.Count most recent</span>
        <a class="dtc-link" asp-controller="LostFoundItem" asp-action="Search">Search all →</a>
      </div>
    }
  </div>

</div>
