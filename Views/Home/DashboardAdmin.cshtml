@model LostAndFoundApp.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    var maxTopItem = Model.TopItemTypes.Any() ? Model.TopItemTypes.Max(t => t.Count) : 1;
    var total = Model.TotalItems > 0 ? Model.TotalItems : 1;
}

@section Styles {
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
:root {
  --accent-db: #7C8FFF; --accent-s: rgba(124,143,255,0.10); --accent-b: rgba(124,143,255,0.22); --accent-g: linear-gradient(135deg,#7C8FFF,#A78BFA);
  --found-c:#4ADE80;--found-bg:rgba(74,222,128,0.08);--found-b:rgba(74,222,128,0.2);
  --claim-c:#60A5FA;--claim-bg:rgba(96,165,250,0.08);--claim-b:rgba(96,165,250,0.2);
  --store-c:#FCD34D;--store-bg:rgba(252,211,77,0.08);--store-b:rgba(252,211,77,0.2);
  --xfer-c:#C4B5FD;--xfer-bg:rgba(196,181,253,0.08);--xfer-b:rgba(196,181,253,0.2);
  --disp-c:#71717A;--disp-bg:rgba(113,113,122,0.07);--disp-b:rgba(113,113,122,0.16);
  --warn-db:#FCD34D;--danger-db:#F87171;--green-db:#4ADE80;
  --t1:#F5F5F5;--t2:#A3A3A3;--t3:#5C5C5C;--t4:#2E2E2E;
  --mono:'JetBrains Mono',monospace;--display:'Syne',sans-serif;--body-db:'Inter',sans-serif;
}
.dash-page{flex:1;overflow-y:auto;overflow-x:hidden;padding:24px;display:flex;flex-direction:column;gap:20px;width:100%;max-width:none;min-height:0}
.dash-page::-webkit-scrollbar{width:4px}.dash-page::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:2px}
.pg-head{display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.pg-title{font-family:var(--display);font-size:26px;font-weight:800;color:var(--t1);letter-spacing:-.025em}
.pg-sub{font-size:14px;color:var(--t3);margin-top:3px;font-weight:500}
.pg-date{font-size:13.5px;color:var(--t3);margin-top:3px;font-weight:500}
.metrics-strip{display:grid;grid-template-columns:1.5fr repeat(5,1fr);gap:12px;width:100%}
.metric{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:18px 20px;position:relative;overflow:hidden;transition:border-color .14s,background .14s}
.metric:hover{border-color:rgba(255,255,255,0.16);background:var(--bg-elevated)}
.metric.total{border-color:rgba(124,143,255,0.25)}
.metric.total::before{content:'';position:absolute;top:-30px;right:-30px;width:100px;height:100px;background:radial-gradient(circle,rgba(124,143,255,0.15) 0%,transparent 70%)}
.metric-label{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--t3);margin-bottom:8px}
.metric-num{font-family:var(--mono);font-size:48px;font-weight:700;line-height:1;letter-spacing:-.04em;color:var(--t1)}
.metric.total .metric-num{font-size:56px}
.metric-sub{font-size:13px;color:var(--t3);margin-top:6px;font-weight:500}.metric-sub strong{color:var(--green-db);font-weight:700}
.metric-bar{position:absolute;bottom:0;left:0;right:0;height:2px}
.metric.found-m .metric-bar{background:var(--found-c)}.metric.claimed-m .metric-bar{background:var(--claim-c)}.metric.stored-m .metric-bar{background:var(--store-c)}.metric.xfer-m .metric-bar{background:var(--xfer-c)}.metric.disposed-m .metric-bar{background:var(--disp-c)}
.metric.found-m .metric-num{color:var(--found-c)}.metric.claimed-m .metric-num{color:var(--claim-c)}.metric.stored-m .metric-num{color:var(--store-c)}.metric.xfer-m .metric-num{color:var(--xfer-c)}.metric.disposed-m .metric-num{color:var(--disp-c)}
.metric-pct{font-family:var(--mono);font-size:13px;color:var(--t4);margin-top:2px;font-weight:500}
.row2{display:grid;grid-template-columns:repeat(3,1fr) 200px;gap:12px}
.alert-card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:16px 18px;display:flex;align-items:center;gap:14px;transition:border-color .14s}
.alert-card.warn{border-color:rgba(252,211,77,0.25)}.alert-card.danger{border-color:rgba(248,113,113,0.25)}.alert-card.ok{border-color:rgba(74,222,128,0.25)}
.alert-icon{width:48px;height:48px;border-radius:10px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:20px}
.warn .alert-icon{background:rgba(252,211,77,0.1);color:var(--warn-db)}.danger .alert-icon{background:rgba(248,113,113,0.1);color:var(--danger-db)}.ok .alert-icon{background:rgba(74,222,128,0.1);color:var(--green-db)}
.alert-num{font-family:var(--mono);font-size:36px;font-weight:700;line-height:1}
.warn .alert-num{color:var(--warn-db)}.danger .alert-num{color:var(--danger-db)}.ok .alert-num{color:var(--green-db)}
.alert-lbl{font-size:14px;color:var(--t2);margin-top:3px;font-weight:600}
.mini-panel{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden}
.mini-head{padding:10px 14px;font-size:11.5px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--t3);border-bottom:1px solid var(--border);background:var(--bg-elevated)}
.mini-row{display:flex;align-items:center;justify-content:space-between;padding:9px 14px;border-bottom:1px solid var(--border)}.mini-row:last-child{border-bottom:none}
.mini-label{font-size:14px;color:var(--t2);font-weight:500}.mini-val{font-family:var(--mono);font-size:15px;font-weight:700;color:var(--t1)}.mini-val.ok{color:var(--green-db)}.mini-val.warn{color:var(--warn-db)}
.row3{display:grid;grid-template-columns:1fr 280px;gap:12px;flex:1;min-height:0;width:100%}
.dtc{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;min-height:0}
.dtc-head{display:flex;align-items:center;justify-content:space-between;padding:12px 18px;border-bottom:1px solid var(--border);background:var(--bg-elevated);flex-shrink:0}
.dtc-title{font-family:var(--display);font-size:15px;font-weight:700;color:var(--t1);display:flex;align-items:center;gap:8px}
.dtc-badge{padding:2px 8px;border-radius:20px;font-size:12px;font-weight:700;font-family:var(--body-db);background:var(--bg-hover);color:var(--t3)}
.dtc-link{font-size:13.5px;color:var(--accent-db);text-decoration:none;font-weight:600;opacity:.8}.dtc-link:hover{opacity:1}
.dtc-body{flex:1;overflow-y:auto;min-height:0}.dtc-body::-webkit-scrollbar{width:4px}.dtc-body::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.08);border-radius:2px}
.dtable{width:100%;border-collapse:collapse}
.dtable thead th{padding:10px 14px;text-align:left;font-size:11.5px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.08em;border-bottom:1px solid var(--border);background:var(--bg-elevated);white-space:nowrap}
.dtable thead th:first-child{padding-left:18px}
.dtable tbody td{padding:12px 14px;font-size:14.5px;font-weight:500;border-bottom:1px solid var(--border);color:var(--t2);vertical-align:middle}
.dtable tbody td:first-child{padding-left:18px}.dtable tbody tr:last-child td{border-bottom:none}
.dtable tbody tr:hover td{background:var(--bg-elevated);color:var(--t1)}.dtable tbody tr:hover td:first-child{box-shadow:inset 3px 0 0 var(--accent-db)}
.d-tid{font-family:var(--mono);font-size:13px;color:var(--t1);font-weight:600}
.d-item-name{color:var(--t1);font-weight:600}.d-loc-text{font-size:13px;color:var(--t3);font-weight:500}
.d-badge{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;font-size:12.5px;font-weight:700;border:1px solid transparent;white-space:nowrap}
.d-badge::before{content:'';width:5px;height:5px;border-radius:50%;background:currentColor;flex-shrink:0}
.db-found{background:var(--found-bg);color:var(--found-c);border-color:var(--found-b)}.db-claimed{background:var(--claim-bg);color:var(--claim-c);border-color:var(--claim-b)}.db-stored{background:var(--store-bg);color:var(--store-c);border-color:var(--store-b)}.db-xfer{background:var(--xfer-bg);color:var(--xfer-c);border-color:var(--xfer-b)}.db-disposed{background:var(--disp-bg);color:var(--disp-c);border-color:var(--disp-b)}
.days-num{font-family:var(--mono);font-size:14px;font-weight:600}.days-warn{color:var(--danger-db);font-weight:800;font-family:var(--mono);font-size:14px}
.d-row-actions{display:flex;align-items:center;gap:2px}
.d-ra{display:inline-flex;align-items:center;justify-content:center;width:30px;height:30px;border-radius:6px;background:transparent;border:none;color:var(--t4);cursor:pointer;font-size:14px;text-decoration:none;transition:background .1s,color .1s}
.d-ra:hover{background:var(--bg-hover);color:var(--accent-db)}
.dtc-foot{display:flex;align-items:center;justify-content:space-between;padding:9px 18px;border-top:1px solid var(--border);background:var(--bg-elevated);flex-shrink:0}
.dtc-foot-info{font-size:13px;color:var(--t4);font-weight:500}
.d-sbar{display:flex;flex-direction:column;gap:10px;overflow-y:auto;min-height:0}.d-sbar::-webkit-scrollbar{width:4px}.d-sbar::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.08);border-radius:2px}
.d-panel{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;flex-shrink:0}
.d-panel-head{padding:11px 16px;border-bottom:1px solid var(--border);font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--t3);background:var(--bg-elevated)}
.d-ti-row{display:flex;align-items:center;gap:8px;padding:9px 14px;border-bottom:1px solid var(--border);transition:background .1s}.d-ti-row:last-child{border-bottom:none}.d-ti-row:hover{background:var(--bg-elevated)}
.d-ti-rank{font-size:12px;color:var(--t4);font-family:var(--mono);width:16px;text-align:right;flex-shrink:0;font-weight:600}
.d-ti-name{flex:1;font-size:14.5px;color:var(--t2);font-weight:500}
.d-ti-bar{width:50px;height:4px;background:var(--bg-hover);border-radius:2px;overflow:hidden;flex-shrink:0}
.d-ti-fill{height:100%;background:linear-gradient(90deg,#7C8FFF,#A78BFA);border-radius:2px}
.d-ti-ct{font-family:var(--mono);font-size:14px;font-weight:700;color:var(--t1);width:24px;text-align:right;flex-shrink:0}
@@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.dash-page>*{animation:fadeUp .3s ease both}.dash-page>*:nth-child(1){animation-delay:.04s}.dash-page>*:nth-child(2){animation-delay:.08s}.dash-page>*:nth-child(3){animation-delay:.12s}.dash-page>*:nth-child(4){animation-delay:.16s}
@@media(max-width:1200px){.metrics-strip{grid-template-columns:repeat(3,1fr)}.row3{grid-template-columns:1fr}}
@@media(max-width:768px){.metrics-strip{grid-template-columns:repeat(2,1fr)}.row2{grid-template-columns:1fr 1fr}}
</style>
}

<div class="dash-page">

  <!-- PAGE HEADER -->
  <div class="pg-head">
    <div>
      <div class="pg-title">Admin Dashboard</div>
      <div class="pg-sub">Welcome back, @Model.UserDisplayName</div>
      <div class="pg-date">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</div>
    </div>
    <div style="display:flex;gap:8px;">
      <a class="btn btn-primary btn-sm" asp-controller="LostFoundItem" asp-action="Create"><i class="bi bi-plus"></i> New Record</a>
      <a class="btn btn-secondary btn-sm" asp-controller="UserManagement" asp-action="Index"><i class="bi bi-people"></i> Users</a>
    </div>
  </div>

  <!-- ROW 1: METRICS -->
  <div class="metrics-strip">
    <div class="metric total">
      <div class="metric-label">Total Items</div>
      <div class="metric-num">@Model.TotalItems</div>
      <div class="metric-sub"><strong>+@Model.ItemsThisWeek</strong> added this week</div>
      <div class="metric-bar" style="background:var(--accent-db)"></div>
    </div>
    <div class="metric found-m"><div class="metric-label">Found</div><div class="metric-num">@Model.FoundCount</div><div class="metric-pct">@(Model.FoundCount * 100 / total)%</div><div class="metric-bar"></div></div>
    <div class="metric claimed-m"><div class="metric-label">Claimed</div><div class="metric-num">@Model.ClaimedCount</div><div class="metric-pct">@(Model.ClaimedCount * 100 / total)%</div><div class="metric-bar"></div></div>
    <div class="metric stored-m"><div class="metric-label">Stored</div><div class="metric-num">@Model.StoredCount</div><div class="metric-pct">@(Model.StoredCount * 100 / total)%</div><div class="metric-bar"></div></div>
    <div class="metric xfer-m"><div class="metric-label">Transferred</div><div class="metric-num">@Model.TransferredCount</div><div class="metric-pct">@(Model.TransferredCount * 100 / total)%</div><div class="metric-bar"></div></div>
    <div class="metric disposed-m"><div class="metric-label">Disposed</div><div class="metric-num">@Model.DisposedCount</div><div class="metric-pct">@(Model.DisposedCount * 100 / total)%</div><div class="metric-bar"></div></div>
  </div>

  <!-- ROW 2: ALERTS -->
  <div class="row2">
    <div class="alert-card warn">
      <div class="alert-icon"><i class="bi bi-hourglass-split"></i></div>
      <div><div class="alert-num">@Model.ItemsAwaitingAction</div><div class="alert-lbl">Awaiting Action</div></div>
    </div>
    <div class="alert-card danger">
      <div class="alert-icon"><i class="bi bi-exclamation-triangle"></i></div>
      <div><div class="alert-num">@Model.UnclaimedOver30Days</div><div class="alert-lbl">Unclaimed 30+ Days</div></div>
    </div>
    <div class="alert-card ok">
      <div class="alert-icon"><i class="bi bi-graph-up-arrow"></i></div>
      <div><div class="alert-num">@Model.ItemsThisWeek</div><div class="alert-lbl">New This Week</div></div>
    </div>
    <div class="mini-panel">
      <div class="mini-head">Activity</div>
      <div class="mini-row"><span class="mini-label">This Month</span><span class="mini-val">@Model.ItemsThisMonth</span></div>
      <div class="mini-row"><span class="mini-label">Total Users</span><span class="mini-val ok">@Model.TotalUsers</span></div>
      <div class="mini-row"><span class="mini-label">Pending</span><span class="mini-val warn">@Model.ItemsAwaitingAction</span></div>
    </div>
  </div>

  <!-- ROW 3: TABLE + SIDEBAR -->
  <div class="row3">
    <div class="dtc">
      <div class="dtc-head">
        <span class="dtc-title">Recent Records <span class="dtc-badge">@Model.TotalItems total</span></span>
        <a class="dtc-link" asp-controller="LostFoundItem" asp-action="Search">View all →</a>
      </div>
      @if (!Model.RecentRecords.Any())
      {
        <div style="padding:56px 24px;text-align:center;">
          <i class="bi bi-inbox" style="font-size:2.5rem;display:block;margin-bottom:16px;color:var(--t4);"></i>
          <div style="font-size:1rem;font-weight:600;color:var(--t2);margin-bottom:6px;">No records yet</div>
          <div style="font-size:0.875rem;color:var(--t3);margin-bottom:20px;">Create your first lost &amp; found record to get started.</div>
          <a class="btn btn-primary" asp-controller="LostFoundItem" asp-action="Create"><i class="bi bi-plus"></i> New Record</a>
        </div>
      }
      else
      {
        <div class="dtc-body">
          <table class="dtable">
            <thead><tr><th>ID</th><th>Date Found</th><th>Item</th><th>Location</th><th>Status</th><th>Days</th><th>Claimed By</th><th></th></tr></thead>
            <tbody>
              @foreach (var record in Model.RecentRecords)
              {
                var statusClass = (record.StatusName?.ToLower()) switch { "found" => "db-found", "claimed" => "db-claimed", "stored" => "db-stored", "transferred" => "db-xfer", "disposed" => "db-disposed", _ => "db-found" };
                <tr>
                  <td><span class="d-tid">#@record.TrackingId</span></td>
                  <td>@record.DateFound.ToString("MM/dd/yyyy")</td>
                  <td><span class="d-item-name">@record.ItemName</span></td>
                  <td><span class="d-loc-text">@record.LocationFound</span></td>
                  <td><span class="d-badge @statusClass">@(record.StatusName ?? "Unknown")</span></td>
                  <td>@if(record.DaysSinceFound > 30){<span class="days-warn">@record.DaysSinceFound</span>}else{<span class="days-num">@record.DaysSinceFound</span>}</td>
                  <td>@(string.IsNullOrEmpty(record.ClaimedBy) ? "—" : record.ClaimedBy)</td>
                  <td>
                    <div class="d-row-actions">
                      <a class="d-ra" asp-controller="LostFoundItem" asp-action="Details" asp-route-id="@record.TrackingId" title="View"><i class="bi bi-eye"></i></a>
                      <a class="d-ra" asp-controller="LostFoundItem" asp-action="Edit" asp-route-id="@record.TrackingId" title="Edit"><i class="bi bi-pencil"></i></a>
                    </div>
                  </td>
                </tr>
              }
            </tbody>
          </table>
        </div>
        <div class="dtc-foot">
          <span class="dtc-foot-info">Showing @Model.RecentRecords.Count of @Model.TotalItems records</span>
          <a class="dtc-link" asp-controller="LostFoundItem" asp-action="Search">Search all →</a>
        </div>
      }
    </div>

    <!-- SIDEBAR: Operational Focus -->
    <div class="d-sbar">
      @if (Model.TopItemTypes.Any())
      {
        <div class="d-panel">
          <div class="d-panel-head">Top Categories</div>
          @{ var rank = 0; }
          @foreach (var item in Model.TopItemTypes)
          {
            rank++;
            var pct = maxTopItem > 0 ? (item.Count * 100 / maxTopItem) : 0;
            <div class="d-ti-row">
              <span class="d-ti-rank">@rank</span>
              <span class="d-ti-name">@item.ItemName</span>
              <div class="d-ti-bar"><div class="d-ti-fill" style="width:@(pct)%"></div></div>
              <span class="d-ti-ct">@item.Count</span>
            </div>
          }
        </div>
      }

      <div class="d-panel">
        <div class="d-panel-head">Master Data</div>
        <div class="d-ti-row"><span class="d-ti-name">Item Types</span><span class="d-ti-ct">@Model.MasterItemCount</span></div>
        <div class="d-ti-row"><span class="d-ti-name">Routes</span><span class="d-ti-ct">@Model.MasterRouteCount</span></div>
        <div class="d-ti-row"><span class="d-ti-name">Vehicles</span><span class="d-ti-ct">@Model.MasterVehicleCount</span></div>
        <div class="d-ti-row"><span class="d-ti-name">Locations</span><span class="d-ti-ct">@Model.MasterStorageLocationCount</span></div>
        <div class="d-ti-row"><span class="d-ti-name">Statuses</span><span class="d-ti-ct">@Model.MasterStatusCount</span></div>
      </div>

      <div class="d-panel">
        <div class="d-panel-head">Roles</div>
        <div class="d-ti-row"><span class="d-ti-name" style="color:var(--found-c)">Admin</span><span class="d-ti-ct" style="color:var(--found-c)">@Model.AdminCount</span></div>
        <div class="d-ti-row"><span class="d-ti-name" style="color:var(--xfer-c)">Supervisor</span><span class="d-ti-ct" style="color:var(--xfer-c)">@Model.SupervisorCount</span></div>
        <div class="d-ti-row"><span class="d-ti-name" style="color:var(--store-c)">User</span><span class="d-ti-ct" style="color:var(--store-c)">@Model.UserRoleCount</span></div>
      </div>

      <div class="d-panel">
        <div class="d-panel-head">Activity</div>
        <div class="d-ti-row"><span class="d-ti-name">This Week</span><span class="d-ti-ct">@Model.ItemsThisWeek</span></div>
        <div class="d-ti-row"><span class="d-ti-name">This Month</span><span class="d-ti-ct">@Model.ItemsThisMonth</span></div>
        <div class="d-ti-row"><span class="d-ti-name" style="color:var(--warn-db)">Awaiting Action</span><span class="d-ti-ct" style="color:var(--warn-db)">@Model.ItemsAwaitingAction</span></div>
      </div>
    </div>
  </div>

</div>
