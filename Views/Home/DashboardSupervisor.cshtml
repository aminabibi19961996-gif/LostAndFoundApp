@model LostAndFoundApp.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Supervisor Dashboard";
    var total = Model.TotalItems > 0 ? Model.TotalItems : 1;
}

@section Styles {
<style>
:root {
  --accent-db:#7C8FFF;--accent-s:rgba(124,143,255,0.10);
  --found-c:#4ADE80;--found-bg:rgba(74,222,128,0.08);--found-b:rgba(74,222,128,0.2);
  --claim-c:#60A5FA;--claim-bg:rgba(96,165,250,0.08);--claim-b:rgba(96,165,250,0.2);
  --store-c:#FCD34D;--store-bg:rgba(252,211,77,0.08);--store-b:rgba(252,211,77,0.2);
  --xfer-c:#C4B5FD;--xfer-bg:rgba(196,181,253,0.08);--xfer-b:rgba(196,181,253,0.2);
  --disp-c:#71717A;--disp-bg:rgba(113,113,122,0.07);--disp-b:rgba(113,113,122,0.16);
  --warn-db:#FCD34D;--danger-db:#F87171;--green-db:#4ADE80;
  --t1:#F5F5F5;--t2:#A3A3A3;--t3:#5C5C5C;--t4:#2E2E2E;
  --mono:'JetBrains Mono',monospace;--display:'Syne',sans-serif;--body-db:'Inter',sans-serif;
}
.dash-page{flex:1;overflow-y:auto;overflow-x:hidden;padding:0;display:flex;flex-direction:column;gap:20px;width:100%;max-width:none;min-height:0}
.dash-page::-webkit-scrollbar{width:4px}.dash-page::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:2px}
.pg-head{display:flex;align-items:center;justify-content:space-between;flex-shrink:0;flex-wrap:wrap;gap:12px}
.pg-title{font-family:var(--display);font-size:26px;font-weight:800;color:var(--t1);letter-spacing:-.025em}
.pg-sub{font-size:14px;color:var(--t3);margin-top:3px;font-weight:500}
.pg-date{font-size:13.5px;color:var(--t3);margin-top:3px;font-weight:500}

/* Critical alerts row */
.critical-alerts{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.crit-card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:16px 18px;display:flex;align-items:center;gap:14px;transition:border-color .14s;position:relative;overflow:hidden}
.crit-card.danger{border-color:rgba(248,113,113,0.3)}.crit-card.danger::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--danger-db)}
.crit-card.warn{border-color:rgba(252,211,77,0.3)}.crit-card.warn::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--warn-db)}
.crit-card.ok{border-color:rgba(74,222,128,0.3)}.crit-card.ok::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--green-db)}
.crit-card.info{border-color:rgba(124,143,255,0.3)}.crit-card.info::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--accent-db)}
.crit-icon{width:44px;height:44px;border-radius:10px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:20px}
.danger .crit-icon{background:rgba(248,113,113,0.1);color:var(--danger-db)}
.warn .crit-icon{background:rgba(252,211,77,0.1);color:var(--warn-db)}
.ok .crit-icon{background:rgba(74,222,128,0.1);color:var(--green-db)}
.info .crit-icon{background:rgba(124,143,255,0.1);color:var(--accent-db)}
.crit-num{font-family:var(--mono);font-size:28px;font-weight:700;line-height:1}
.danger .crit-num{color:var(--danger-db)}.warn .crit-num{color:var(--warn-db)}.ok .crit-num{color:var(--green-db)}.info .crit-num{color:var(--accent-db)}
.crit-lbl{font-size:12px;color:var(--t2);margin-top:3px;font-weight:600}
.crit-ctx{font-size:11px;color:var(--t3);margin-top:2px;font-weight:500}

/* KPI strip */
.kpi-strip{display:grid;grid-template-columns:repeat(5,1fr);gap:12px}
.kpi{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:16px 18px;position:relative;overflow:hidden;transition:border-color .14s}
.kpi:hover{border-color:rgba(255,255,255,0.16)}
.kpi-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--t3);margin-bottom:6px}
.kpi-num{font-family:var(--mono);font-size:32px;font-weight:700;line-height:1;color:var(--t1)}
.kpi-ctx{font-size:12px;color:var(--t3);margin-top:5px;font-weight:500}
.kpi-ctx strong{font-weight:700}.kpi-ctx .up{color:var(--green-db)}.kpi-ctx .down{color:var(--danger-db)}
.kpi-bar{position:absolute;bottom:0;left:0;right:0;height:2px}

/* Status count cards (Total, Found, Claimed, Stored, Disposed) */
.stat-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px}
.stat-card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:18px 20px;position:relative;overflow:hidden;transition:border-color .14s,background .14s}
.stat-card:hover{border-color:rgba(255,255,255,0.16);background:var(--bg-elevated)}
.stat-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--t3);margin-bottom:8px}
.stat-num{font-family:var(--mono);font-size:36px;font-weight:700;line-height:1;letter-spacing:-.04em;color:var(--t1)}
.stat-ctx{font-size:12px;color:var(--t3);margin-top:6px;font-weight:500}
.stat-ctx strong{font-weight:700}
.stat-ctx .up{color:var(--green-db)}.stat-ctx .down{color:var(--danger-db)}

/* Main content grid */
.main-grid{display:grid;grid-template-columns:1fr 300px;gap:14px;flex:1;min-height:0}

/* Table card */
.dtc{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;min-height:0}
.dtc-head{display:flex;align-items:center;justify-content:space-between;padding:12px 18px;border-bottom:1px solid var(--border);background:var(--bg-elevated);flex-shrink:0}
.dtc-title{font-family:var(--display);font-size:15px;font-weight:700;color:var(--t1);display:flex;align-items:center;gap:8px}
.dtc-badge{padding:2px 8px;border-radius:20px;font-size:12px;font-weight:700;font-family:var(--body-db);background:var(--bg-hover);color:var(--t3)}
.dtc-link{font-size:13.5px;color:var(--accent-db);text-decoration:none;font-weight:600;opacity:.8}.dtc-link:hover{opacity:1}
.dtc-body{flex:1;overflow-y:auto;min-height:0}.dtc-body::-webkit-scrollbar{width:4px}.dtc-body::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.08);border-radius:2px}
.dtable{width:100%;border-collapse:collapse}
.dtable thead th{padding:10px 14px;text-align:left;font-size:11.5px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.08em;border-bottom:1px solid var(--border);background:var(--bg-elevated);white-space:nowrap}
.dtable thead th:first-child{padding-left:18px}
.dtable tbody td{padding:12px 14px;font-size:14.5px;font-weight:500;border-bottom:1px solid var(--border);color:var(--t2);vertical-align:middle}
.dtable tbody td:first-child{padding-left:18px}.dtable tbody tr:last-child td{border-bottom:none}
.dtable tbody tr:hover td{background:var(--bg-elevated);color:var(--t1)}.dtable tbody tr:hover td:first-child{box-shadow:inset 3px 0 0 var(--accent-db)}
.d-tid{font-family:var(--mono);font-size:13px;color:var(--t1);font-weight:600}
.d-item-name{color:var(--t1);font-weight:600}.d-loc-text{font-size:13px;color:var(--t3);font-weight:500}
.d-badge{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;font-size:12.5px;font-weight:700;border:1px solid transparent;white-space:nowrap}
.d-badge::before{content:'';width:5px;height:5px;border-radius:50%;background:currentColor;flex-shrink:0}
.db-found{background:var(--found-bg);color:var(--found-c);border-color:var(--found-b)}.db-claimed{background:var(--claim-bg);color:var(--claim-c);border-color:var(--claim-b)}.db-stored{background:var(--store-bg);color:var(--store-c);border-color:var(--store-b)}.db-xfer{background:var(--xfer-bg);color:var(--xfer-c);border-color:var(--xfer-b)}.db-disposed{background:var(--disp-bg);color:var(--disp-c);border-color:var(--disp-b)}
.days-num{font-family:var(--mono);font-size:14px;font-weight:600}.days-warn{color:var(--danger-db);font-weight:800;font-family:var(--mono);font-size:14px}
.d-row-actions{display:flex;align-items:center;gap:2px}
.d-ra{display:inline-flex;align-items:center;justify-content:center;width:30px;height:30px;border-radius:6px;background:transparent;border:none;color:var(--t4);cursor:pointer;font-size:14px;text-decoration:none;transition:background .1s,color .1s}
.d-ra:hover{background:var(--bg-hover);color:var(--accent-db)}
.dtc-foot{display:flex;align-items:center;justify-content:space-between;padding:9px 18px;border-top:1px solid var(--border);background:var(--bg-elevated);flex-shrink:0}
.dtc-foot-info{font-size:13px;color:var(--t4);font-weight:500}

/* Sidebar panels */
.sidebar{display:flex;flex-direction:column;gap:12px;overflow-y:auto;min-height:0}
.sidebar::-webkit-scrollbar{width:4px}.sidebar::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.08);border-radius:2px}
.s-panel{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;flex-shrink:0}
.s-panel-head{padding:11px 16px;border-bottom:1px solid var(--border);font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--t3);background:var(--bg-elevated)}
.s-row{display:flex;align-items:center;gap:8px;padding:9px 14px;border-bottom:1px solid var(--border);transition:background .1s}
.s-row:last-child{border-bottom:none}.s-row:hover{background:var(--bg-elevated)}
.s-name{flex:1;font-size:14px;color:var(--t2);font-weight:500}
.s-bar{width:50px;height:4px;background:var(--bg-hover);border-radius:2px;overflow:hidden;flex-shrink:0}
.s-fill{height:100%;background:linear-gradient(90deg,#7C8FFF,#A78BFA);border-radius:2px}
.s-val{font-family:var(--mono);font-size:14px;font-weight:700;color:var(--t1);min-width:24px;text-align:right;flex-shrink:0}
.s-val.ok{color:var(--green-db)}.s-val.warn{color:var(--warn-db)}.s-val.danger{color:var(--danger-db)}

@@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.dash-page>*{animation:fadeUp .3s ease both}.dash-page>*:nth-child(1){animation-delay:.04s}.dash-page>*:nth-child(2){animation-delay:.08s}.dash-page>*:nth-child(3){animation-delay:.12s}.dash-page>*:nth-child(4){animation-delay:.16s}.dash-page>*:nth-child(5){animation-delay:.20s}
@@media(max-width:1200px){.critical-alerts{grid-template-columns:repeat(2,1fr)}.kpi-strip{grid-template-columns:repeat(3,1fr)}.stat-row{grid-template-columns:repeat(3,1fr)}.main-grid{grid-template-columns:1fr}}
@@media(max-width:768px){.critical-alerts{grid-template-columns:1fr}.kpi-strip{grid-template-columns:repeat(2,1fr)}.stat-row{grid-template-columns:repeat(2,1fr)}}
</style>
}

<div class="dash-page">

  <!-- HEADER -->
  <div class="pg-head">
    <div>
      <div class="pg-title">Dashboard <span style="display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:13px;font-weight:700;background:rgba(6,182,212,0.12);color:#67E8F9;border:1px solid rgba(6,182,212,0.25);vertical-align:middle;margin-left:6px;">Supervisor</span></div>
      <div class="pg-sub">Welcome back, @Model.UserDisplayName</div>
      <div class="pg-date">@DateTime.UtcNow.ToString("dddd, MMMM d, yyyy")</div>
    </div>
    <div style="display:flex;gap:8px;">
      <a class="btn btn-primary btn-sm" asp-controller="LostFoundItem" asp-action="Create"><i class="bi bi-plus"></i> New Record</a>
      <a class="btn btn-secondary btn-sm" asp-controller="LostFoundItem" asp-action="Search"><i class="bi bi-search"></i> Search</a>
      <a class="btn btn-secondary btn-sm" asp-controller="Announcement" asp-action="Create"><i class="bi bi-megaphone"></i> Post Announcement</a>
    </div>
  </div>

  <!-- ZONE 1: CRITICAL ALERTS — What needs attention NOW -->
  <div class="critical-alerts">
    <div class="crit-card @(Model.UnclaimedOver30Days > 0 ? "danger" : "ok")">
      <div class="crit-icon"><i class="bi bi-exclamation-triangle"></i></div>
      <div>
        <div class="crit-num">@Model.UnclaimedOver30Days</div>
        <div class="crit-lbl">Overdue (30+ days)</div>
        @if(Model.TotalItems > 0)
        {
          <div class="crit-ctx">@(Math.Round((double)Model.UnclaimedOver30Days / Model.TotalItems * 100, 1))% of all items</div>
        }
      </div>
    </div>

    <div class="crit-card @(Model.ItemsAwaitingAction > 0 ? "warn" : "ok")">
      <div class="crit-icon"><i class="bi bi-hourglass-split"></i></div>
      <div>
        <div class="crit-num">@Model.ItemsAwaitingAction</div>
        <div class="crit-lbl">Awaiting Action</div>
        <div class="crit-ctx">@Model.AwaitingActionPercent% of active items</div>
      </div>
    </div>
    <div class="crit-card info">
      <div class="crit-icon"><i class="bi bi-graph-up-arrow"></i></div>
      <div>
        <div class="crit-num">@Model.ItemsThisWeek</div>
        <div class="crit-lbl">New This Week</div>
        <div class="crit-ctx">
          <span class="@(Model.WeekOverWeekChangePercent >= 0 ? "up" : "down")">
            @(Model.WeekOverWeekChangePercent >= 0 ? "(+)" : "(-)")@Math.Abs(Model.WeekOverWeekChangePercent)%
          </span> vs last week
        </div>
      </div>
    </div>
    <div class="crit-card @(Model.ItemsOverdue7Days > 0 ? "danger" : "ok")">
      <div class="crit-icon"><i class="bi bi-clock-history"></i></div>
      <div>
        <div class="crit-num">@Model.ItemsOverdue7Days</div>
        <div class="crit-lbl">Overdue (7+ days)</div>
        <div class="crit-ctx">Entered 7+ days ago, unresolved</div>
      </div>
    </div>
  </div>

  <!-- ZONE 1B: STATUS COUNT CARDS (same as User dashboard + Disposed) -->
  <div class="stat-row">
    <div class="stat-card">
      <div class="stat-label">Total Items</div>
      <div class="stat-num">@Model.TotalItems</div>
      <div class="stat-ctx"><strong class="@(Model.WeekOverWeekChangePercent >= 0 ? "up" : "down")">@(Model.WeekOverWeekChangePercent >= 0 ? "+" : "")@Model.WeekOverWeekChangePercent%</strong> vs last week</div>
      <div class="kpi-bar" style="background:var(--accent-db)"></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Found</div>
      <div class="stat-num" style="color:var(--found-c)">@Model.FoundCount</div>
      <div class="stat-ctx">@(Model.FoundCount * 100 / total)% of total</div>
      <div class="kpi-bar" style="background:var(--found-c)"></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Claimed</div>
      <div class="stat-num" style="color:var(--claim-c)">@Model.ClaimedCount</div>
      <div class="stat-ctx">Avg <strong>@Model.AvgDaysToClaim</strong> days to claim</div>
      <div class="kpi-bar" style="background:var(--claim-c)"></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Stored</div>
      <div class="stat-num" style="color:var(--store-c)">@Model.StoredCount</div>
      <div class="stat-ctx">Avg <strong>@Model.AvgStorageDuration</strong> days stored</div>
      <div class="kpi-bar" style="background:var(--store-c)"></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Disposed</div>
      <div class="stat-num" style="color:var(--disp-c)">@Model.DisposedCount</div>
      <div class="stat-ctx">@(Model.DisposedCount * 100 / total)% of total</div>
      <div class="kpi-bar" style="background:var(--disp-c)"></div>
    </div>
  </div>

  <!-- ZONE 2: PERFORMANCE KPIs -->
  <div class="kpi-strip">
    <div class="kpi">
      <div class="kpi-label">Claim Rate</div>
      <div class="kpi-num" style="color:var(--claim-c)">@Model.ClaimRatePercent%</div>
      <div class="kpi-ctx">@Model.ClaimedCount of @Model.TotalItems items claimed</div>
      <div class="kpi-bar" style="background:var(--claim-c)"></div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Avg Claim Time</div>
      <div class="kpi-num">@Model.AvgDaysToClaim<span style="font-size:16px;color:var(--t3)">d</span></div>
      <div class="kpi-ctx">Time from found to claimed</div>
      <div class="kpi-bar" style="background:var(--accent-db)"></div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Avg Storage</div>
      <div class="kpi-num">@Model.AvgStorageDuration<span style="font-size:16px;color:var(--t3)">d</span></div>
      <div class="kpi-ctx">Current stored items age</div>
      <div class="kpi-bar" style="background:var(--store-c)"></div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Disposal Rate</div>
      <div class="kpi-num" style="color:var(--disp-c)">@Model.DisposalRatePercent%</div>
      <div class="kpi-ctx">@Model.DisposedCount items disposed</div>
      <div class="kpi-bar" style="background:var(--disp-c)"></div>
    </div>
    <div class="kpi">
      <div class="kpi-label">This Month</div>
      <div class="kpi-num">@Model.ItemsThisMonth</div>
      <div class="kpi-ctx"><strong class="@(Model.MonthOverMonthChangePercent >= 0 ? "up" : "down")">@(Model.MonthOverMonthChangePercent >= 0 ? "+" : "")@Model.MonthOverMonthChangePercent%</strong> vs last month</div>
      <div class="kpi-bar" style="background:var(--green-db)"></div>
    </div>
  </div>

  <!-- ZONE 3: TABLE + SIDEBAR -->
  <div class="main-grid">
    <!-- Recent Records -->
    <div class="dtc">
      <div class="dtc-head">
        <span class="dtc-title"><i class="bi bi-clock-history" style="color:var(--accent-db)"></i> Recent Records <span class="dtc-badge">@Model.TotalItems total</span></span>
        <a class="dtc-link" asp-controller="LostFoundItem" asp-action="Search">View all</a>
      </div>
      @if (!Model.RecentRecords.Any())
      {
        <div style="padding:56px 24px;text-align:center;">
          <i class="bi bi-inbox" style="font-size:2.5rem;display:block;margin-bottom:16px;color:var(--t4);"></i>
          <div style="font-size:1rem;font-weight:600;color:var(--t2);margin-bottom:6px;">No records yet</div>
          <a class="btn btn-primary" asp-controller="LostFoundItem" asp-action="Create"><i class="bi bi-plus"></i> New Record</a>
        </div>
      }
      else
      {
        <div class="dtc-body">
          <table class="dtable">
            <thead><tr><th>ID</th><th>Date</th><th>Item</th><th>Location</th><th>Status</th><th>Days</th><th>By</th><th></th></tr></thead>
            <tbody>
              @foreach (var record in Model.RecentRecords)
              {
                var statusClass = (record.StatusName?.ToLower()) switch { "found" => "db-found", "claimed" => "db-claimed", "stored" => "db-stored", "transferred" => "db-xfer", "disposed" => "db-disposed", _ => "db-found" };
                <tr>
                  <td><span class="d-tid">@record.CustomTrackingId</span></td>
                  <td>@record.DateFound.ToString("MM/dd")</td>
                  <td><span class="d-item-name">@record.ItemName</span></td>
                  <td><span class="d-loc-text">@record.LocationFound</span></td>
                  <td><span class="d-badge @statusClass">@(record.StatusName ?? "Unknown")</span></td>
                  <td>@if(record.DaysSinceFound > 30){<span class="days-warn">@record.DaysSinceFound</span>}else{<span class="days-num">@record.DaysSinceFound</span>}</td>
                  <td><span class="d-loc-text">@(record.CreatedBy ?? "—")</span></td>
                  <td>
                    <div class="d-row-actions">
                      <a class="d-ra" asp-controller="LostFoundItem" asp-action="Details" asp-route-id="@record.TrackingId" title="View"><i class="bi bi-eye"></i></a>
                      <a class="d-ra" asp-controller="LostFoundItem" asp-action="Edit" asp-route-id="@record.TrackingId" title="Edit"><i class="bi bi-pencil"></i></a>
                      <a class="d-ra" asp-controller="LostFoundItem" asp-action="PrintLabel" asp-route-id="@record.TrackingId" target="_blank" title="Print Label"><i class="bi bi-qr-code"></i></a>
                    </div>
                  </td>
                </tr>
              }
            </tbody>
          </table>
        </div>
        <div class="dtc-foot">
          <span class="dtc-foot-info">Showing @Model.RecentRecords.Count of @Model.TotalItems</span>
          <a class="dtc-link" asp-controller="LostFoundItem" asp-action="Search">Search all</a>
        </div>
      }
    </div>

    <!-- SIDEBAR: Top Categories + Contributors -->
    <div class="sidebar">
      @if (Model.TopItemTypes.Any())
      {
        var maxTopItem = Model.TopItemTypes.Max(t => t.Count);
        var topRank = 0;
        <div class="s-panel">
          <div class="s-panel-head">Top Categories</div>
          @foreach (var item in Model.TopItemTypes)
          {
            topRank++;
            var pct = maxTopItem > 0 ? (item.Count * 100 / maxTopItem) : 0;
            <div class="s-row">
              <span style="font-size:12px;color:var(--t4);font-family:var(--mono);width:16px;text-align:right;flex-shrink:0;font-weight:600">@topRank</span>
              <span class="s-name">@item.ItemName</span>
              <div class="s-bar"><div class="s-fill" style="width:@(pct)%"></div></div>
              <span class="s-val">@item.Count</span>
            </div>
          }
        </div>
      }

      @if (Model.TopContributors.Any())
      {
        var maxContrib = Model.TopContributors.Max(c => c.ItemsCreated);
        var contribRank = 0;
        <div class="s-panel">
          <div class="s-panel-head">Top Contributors (30d)</div>
          @foreach (var c in Model.TopContributors)
          {
            contribRank++;
            var pct2 = maxContrib > 0 ? (c.ItemsCreated * 100 / maxContrib) : 0;
            <div class="s-row">
              <span style="font-size:12px;color:var(--t4);font-family:var(--mono);width:16px;text-align:right;flex-shrink:0;font-weight:600">@contribRank</span>
              <span class="s-name">@c.DisplayName</span>
              <div class="s-bar"><div class="s-fill" style="width:@(pct2)%"></div></div>
              <span class="s-val">@c.ItemsCreated</span>
            </div>
          }
        </div>
      }

      <div class="s-panel">
        <div class="s-panel-head">Status Distribution</div>
        <div class="s-row"><span class="s-name" style="color:var(--found-c)">Found</span><span class="s-val" style="color:var(--found-c)">@Model.FoundCount</span></div>
        <div class="s-row"><span class="s-name" style="color:var(--claim-c)">Claimed</span><span class="s-val" style="color:var(--claim-c)">@Model.ClaimedCount</span></div>
        <div class="s-row"><span class="s-name" style="color:var(--store-c)">Stored</span><span class="s-val" style="color:var(--store-c)">@Model.StoredCount</span></div>
        <div class="s-row"><span class="s-name" style="color:var(--xfer-c)">Transferred</span><span class="s-val" style="color:var(--xfer-c)">@Model.TransferredCount</span></div>
        <div class="s-row"><span class="s-name" style="color:var(--disp-c)">Disposed</span><span class="s-val" style="color:var(--disp-c)">@Model.DisposedCount</span></div>
      </div>
    </div>
  </div>

</div>
