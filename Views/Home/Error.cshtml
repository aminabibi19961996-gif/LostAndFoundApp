@model ErrorViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="page page-full" style="display: flex; align-items: center; justify-content: center; min-height: 60vh;">
    <div style="text-align: center;">
        <div style="font-size: 4rem; color: var(--accent); margin-bottom: 1rem;">
            @if (Model.StatusCode == 403)
            {
                <svg width="80" height="80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            }
            else if (Model.StatusCode == 404)
            {
                <svg width="80" height="80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            }
            else
            {
                <svg width="80" height="80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            }
        </div>
        <h1 style="font-size: 4rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">@Model.StatusCode</h1>
        <h2 style="font-weight: 600; font-size: 1.25rem; color: var(--text-primary); margin-bottom: 0.75rem;">@Model.Title</h2>
        <p class="text-muted mb-4" style="max-width:360px; margin: 0 auto 1.5rem;">@Model.Message</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            Go to Dashboard
        </a>
    </div>
</div>
