@model LostAndFoundApp.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    
    var greeting = DateTime.Now.Hour < 12 ? "Good morning" : DateTime.Now.Hour < 17 ? "Good afternoon" : "Good evening";
    var totalUsers = Model.SuperAdminCount + Model.AdminCount + Model.UserRoleCount;
    var superPct = totalUsers > 0 ? (Model.SuperAdminCount * 100 / totalUsers) : 100;
    var adminPct = totalUsers > 0 ? (Model.AdminCount * 100 / totalUsers) : 100;
    var userPct  = totalUsers > 0 ? (Model.UserRoleCount  * 100 / totalUsers) : 100;
}



    <!-- HEADER -->
    <div class="page-header">
        <div>
            <div class="page-title">@greeting, @Model.UserDisplayName</div>
            <div class="page-subtitle">
                @DateTime.Now.ToString("dddd, MMMM d, yyyy") —
                <span class="badge badge-blue">@Model.UserRole</span>
            </div>
        </div>
    </div>

    <!-- STATS -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">Total Records</span>
                <div class="stat-icon blue">
                    <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                </div>
            </div>
            <div class="stat-value">@Model.TotalItems</div>
            @if (Model.TotalItems == 0)
            {
                <span class="stat-badge empty">No records yet</span>
            }
            else
            {
                <div class="stat-note">All time</div>
            }
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">Found</span>
                <div class="stat-icon green">
                    <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                </div>
            </div>
            <div class="stat-value">@Model.FoundCount</div>
            <div class="stat-note">Awaiting claim</div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">Claimed</span>
                <div class="stat-icon amber">
                    <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
            </div>
            <div class="stat-value">@Model.ClaimedCount</div>
            <div class="stat-note">Successfully returned</div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">Unclaimed 60d+</span>
                <div class="stat-icon red">
                    <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                </div>
            </div>
            <div class="stat-value">@Model.UnclaimedOver30Days</div>
            <div class="stat-note">Needs attention</div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="content-grid">

        <!-- Recent Records -->
        <div>
            <div class="card">
                <div class="card-header">
                    <span class="card-title">Recent Records</span>
                    <a class="card-action" asp-controller="LostFoundItem" asp-action="Index">View all →</a>
                </div>

                @if (!Model.RecentRecords.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">
                            <svg width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
                        </div>
                        <div class="empty-title">No records yet</div>
                        <div class="empty-desc">Create your first lost &amp; found record to get started.</div>
                        <a class="btn btn-primary" asp-controller="LostFoundItem" asp-action="Create" style="margin-top: 8px;">
                            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                            New Record
                        </a>
                    </div>
                }
                else
                {
                    <table class="records-table">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Status</th>
                                <th>Found By</th>
                                <th>Location</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var record in Model.RecentRecords)
                            {
                                <tr>
                                    <td>
                                        <div class="record-desc">@record.ItemName</div>
                                        <div style="font-size:11.5px; color: var(--text-muted); margin-top:2px;">Item</div>
                                    </td>
                                    <td>
                                        <span class="status-pill status-@record.StatusName.ToLower()">@record.StatusName</span>
                                    </td>
                                    <td>@record.CreatedBy</td>
                                    <td>@record.LocationFound</td>
                                    <td>@record.DateFound.ToString("MMM d")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- SIDEBAR -->
        <div class="sidebar">

            <!-- System Stats -->
            <div class="card">
                <div class="card-header">
                    <span class="card-title">System</span>
                </div>
                <div class="system-stats">
                    <div class="sys-stat">
                        <div class="sys-stat-value">@Model.TotalUsers</div>
                        <div class="sys-stat-label">Total Users</div>
                    </div>
                    <div class="sys-stat">
                        <div class="sys-stat-value">@Model.ActiveUsers</div>
                        <div class="sys-stat-label">Active Users</div>
                    </div>
                    <div class="sys-stat">
                        <div class="sys-stat-value">@Model.ItemsThisWeek</div>
                        <div class="sys-stat-label">This Week</div>
                    </div>
                    <div class="sys-stat">
                        <div class="sys-stat-value">@Model.ItemsAwaitingAction</div>
                        <div class="sys-stat-label">Awaiting Action</div>
                    </div>
                </div>
            </div>

            <!-- Configuration -->
            <div class="card">
                <div class="card-header">
                    <span class="card-title">Configuration</span>
                </div>
                <div class="config-grid">
                    <div class="config-item">
                        <div class="config-value">@Model.MasterItemCount</div>
                        <div class="config-label">Types</div>
                    </div>
                    <div class="config-item">
                        <div class="config-value">@Model.MasterRouteCount</div>
                        <div class="config-label">Routes</div>
                    </div>
                    <div class="config-item">
                        <div class="config-value">@Model.MasterStorageLocationCount</div>
                        <div class="config-label">Locations</div>
                    </div>
                    <div class="config-item">
                        <div class="config-value">@Model.MasterVehicleCount</div>
                        <div class="config-label">Vehicles</div>
                    </div>
                    <div class="config-item">
                        <div class="config-value">@Model.MasterStatusCount</div>
                        <div class="config-label">Statuses</div>
                    </div>
                    <div class="config-item">
                        <div class="config-value">@Model.MasterFoundByNameCount</div>
                        <div class="config-label">Names</div>
                    </div>
                </div>
            </div>

            <!-- Role Distribution -->
            <div class="card">
                <div class="card-header">
                    <span class="card-title">Role Distribution</span>
                </div>
                <div class="role-list">
                    <div class="role-item">
                        <div class="role-dot superadmin"></div>
                        <span class="role-name">Super Admin</span>
                        <div class="role-bar-wrap">
                            <div class="role-bar superadmin" style="width: @superPct%"></div>
                        </div>
                        <span class="role-count">@Model.SuperAdminCount</span>
                    </div>
                    <div class="role-item">
                        <div class="role-dot admin"></div>
                        <span class="role-name">Admin</span>
                        <div class="role-bar-wrap">
                            <div class="role-bar admin" style="width: @adminPct%"></div>
                        </div>
                        <span class="role-count">@Model.AdminCount</span>
                    </div>
                    <div class="role-item">
                        <div class="role-dot user"></div>
                        <span class="role-name">User</span>
                        <div class="role-bar-wrap">
                            <div class="role-bar user" style="width: @userPct%"></div>
                        </div>
                        <span class="role-count">@Model.UserRoleCount</span>
                    </div>
                </div>
            </div>

        </div>
    </div>


